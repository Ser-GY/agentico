#!/usr/bin/env bash
# VERSION=4.7.0
# ═══════════════════════════════════════════════════════════════════════════════
# AGENTIC - Multi-agent tmux session manager
# Layout: QB full width on top, specialists below (auto 2-row for 6+)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# AUTO-UPDATE CHECK
# ═══════════════════════════════════════════════════════════════════════════════
AGENTIC_VERSION="4.7.0"
UPDATE_URL="https://github.com/EliCrossDev/agentic/releases/latest/download/agentic-macos-arm64.tar.gz"

if [[ "$*" != *"--no-update"* ]]; then
    CONFIG_FILE="$HOME/.config/agents-projects.json"
    AUTO_UPDATE=$(jq -r '.settings.auto_update // true' "$CONFIG_FILE" 2>/dev/null)
    if [ "$AUTO_UPDATE" != "false" ]; then
        REMOTE_VERSION=$(curl -fsSL --connect-timeout 3 --max-time 5 "https://raw.githubusercontent.com/EliCrossDev/agentic/main/VERSION" 2>/dev/null | tr -d '[:space:]')
        if [ -n "$REMOTE_VERSION" ] && [ "$REMOTE_VERSION" != "$AGENTIC_VERSION" ] && [[ "$REMOTE_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            echo "Updating agentic $AGENTIC_VERSION → $REMOTE_VERSION..."
            TEMP_DIR=$(mktemp -d)
            if curl -fsSL --connect-timeout 5 --max-time 30 "$UPDATE_URL" -o "$TEMP_DIR/agentic.tar.gz" 2>/dev/null; then
                tar -xzf "$TEMP_DIR/agentic.tar.gz" -C "$TEMP_DIR" 2>/dev/null
                if [ -f "$TEMP_DIR/agentic" ]; then
                    for bin in "$TEMP_DIR"/*; do
                        local_name=$(basename "$bin")
                        [ "$local_name" = "agentic.tar.gz" ] && continue
                        [ -f "$bin" ] && cp "$bin" "$HOME/.local/bin/$local_name" && chmod +x "$HOME/.local/bin/$local_name"
                    done
                    rm -rf "$TEMP_DIR"
                    echo "Updated. Restarting..."
                    exec "$HOME/.local/bin/agentic" "$@" --no-update
                fi
            fi
            rm -rf "$TEMP_DIR"
        fi
    fi
fi
set -- "${@/--no-update/}"

SESSION="agentic"
CONFIG="$HOME/.config/agents-projects.json"
LAST_PROJECT_FILE="$HOME/.config/agents-last-project"

# Colors - Purple theme with cyan accent
PURPLE='\033[38;5;93m'
DEEP_PURPLE='\033[38;5;128m'
CYAN='\033[38;5;51m'
ORANGE='\033[38;5;208m'
GREEN='\033[38;5;118m'
RED='\033[38;5;196m'
YELLOW='\033[38;5;226m'
WHITE='\033[38;5;255m'
GRAY='\033[38;5;245m'
BOLD='\033[1m'
DIM='\033[2m'
REVERSE='\033[7m'
NC='\033[0m'

# Spinner for long-running operations
spin_while() {
    local pid=$1
    local message="${2:-Working...}"
    local spinchars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0

    tput civis  # Hide cursor
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${PURPLE}${spinchars:i++%${#spinchars}:1}${NC} ${message}"
        sleep 0.1
    done
    printf "\r  ${GREEN}✓${NC} ${message}\n"
    tput cnorm  # Show cursor
}

# Parse flags
FRESH=false
LOAD_ALL=false
LITE_MODE=false
LITE_PROJECT=""
SHOW_LIST=false
SKIP_MENU=false
SWITCH_MODE=false
SELECTED_PROJECT=""
MULTI_PROJECTS=""
SELECTED_EDITOR="terminal"
EDITOR_SET=false
SLOW_MODE_FLAG=""  # Can be "on", "off", or "" (use config)
NO_KILL=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -f|--fresh) FRESH=true; shift ;;
        -a|--all) LOAD_ALL=true; SKIP_MENU=true; shift ;;
        -l|--list) SHOW_LIST=true; shift ;;
        -p|--project)
            if [[ "$2" == *,* ]]; then
                MULTI_PROJECTS="$2"
            else
                SELECTED_PROJECT="$2"
            fi
            SKIP_MENU=true; shift 2 ;;
        -s|--switch) SWITCH_MODE=true; FRESH=true; shift ;;
        -k|--kill) tmux kill-server 2>/dev/null; echo "Killed all tmux sessions."; exit 0 ;;
        --no-kill) NO_KILL=true; shift ;;
        --editor) SELECTED_EDITOR="$2"; EDITOR_SET=true; shift 2 ;;
        --slow) SLOW_MODE_FLAG="on"; shift ;;
        --fast) SLOW_MODE_FLAG="off"; shift ;;
        -h|--help)
            echo "Usage: agentic [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  -f, --fresh       (Default behavior - always starts fresh)"
            echo "  -s, --switch      Switch projects (show menu)"
            echo "  -a, --all         Load ALL agents for ALL projects (mega mode)"
            echo "  -l, --list        List configured projects"
            echo "  -p, --project N[,N,...] Load project(s) directly (all agents)"
            echo "  -k, --kill        Kill all tmux sessions and exit"
            echo "  --no-kill         Add project to existing session (don't kill)"
            echo "  --slow            Staggered agent startup (waits for each to load)"
            echo "  --fast            Quick agent startup (override slow mode)"
            echo "  -h, --help        Show this help"
            exit 0
            ;;
        *) shift ;;
    esac
done

# Helper: check if a 1-based index is in a comma-separated list
is_in_list() { echo ",$1," | grep -q ",$2,"; }

# Check dependencies
command -v jq &>/dev/null || { echo -e "${RED}Need jq: brew install jq${NC}"; exit 1; }

# Create config if it doesn't exist
if [ ! -f "$CONFIG" ]; then
    mkdir -p "$(dirname "$CONFIG")"
    echo '{"projects": []}' > "$CONFIG"
fi

NUM_PROJECTS=$(jq '.projects | length' "$CONFIG")

# Read slow_mode setting from config (default: false for powerful systems)
SLOW_MODE_CONFIG=$(jq -r '.settings.slow_mode // false' "$CONFIG")

# Read dangerous_mode setting (--dangerously-skip-permissions)
DANGEROUS_MODE=$(jq -r '.settings.dangerous_mode // false' "$CONFIG")
AUTO_RELAY=$(jq -r '.settings.auto_relay // false' "$CONFIG")
SOLO_MODE=$(jq -r '.settings.solo_mode // true' "$CONFIG")
MULTI_PROJECT_SETTING=$(jq -r '.settings.multi_projects // ""' "$CONFIG")
CLAUDE_CMD="claude --model claude-opus-4-6"
[ "$DANGEROUS_MODE" = "true" ] && CLAUDE_CMD="claude --model claude-opus-4-6 --dangerously-skip-permissions"

# Determine final SLOW_MODE: flag overrides config
if [ "$SLOW_MODE_FLAG" = "on" ]; then
    SLOW_MODE=true
elif [ "$SLOW_MODE_FLAG" = "off" ]; then
    SLOW_MODE=false
elif [ "$SLOW_MODE_CONFIG" = "true" ]; then
    SLOW_MODE=true
else
    SLOW_MODE=false
fi

# List projects and exit
if [ "$SHOW_LIST" = true ]; then
    echo -e "${PURPLE}Configured Projects:${NC}"
    for ((i=0; i<NUM_PROJECTS; i++)); do
        NAME=$(jq -r ".projects[$i].name" "$CONFIG")
        NUM_SPEC=$(jq ".projects[$i].specialists | length" "$CONFIG")
        echo -e "  ${GREEN}$((i+1)))${NC} $NAME ($((NUM_SPEC+1)) agents)"
    done
    exit 0
fi

# Kill existing session and start fresh (unless --no-kill)
if tmux has-session -t $SESSION 2>/dev/null; then
    if [ "$NO_KILL" = true ]; then
        EXISTING_SESSION=true
    else
        tmux kill-session -t $SESSION
    fi
else
    EXISTING_SESSION=false
fi

# Get last used project
LAST_PROJECT=""
LAST_PROJECT_IDX=0
if [ -f "$LAST_PROJECT_FILE" ]; then
    LAST_PROJECT=$(cat "$LAST_PROJECT_FILE")
    for ((i=0; i<NUM_PROJECTS; i++)); do
        NAME=$(jq -r ".projects[$i].name" "$CONFIG")
        if [ "$NAME" = "$LAST_PROJECT" ]; then
            LAST_PROJECT_IDX=$i
            break
        fi
    done
fi

# ═══════════════════════════════════════════════════════════════════════════════
# HEADER
# ═══════════════════════════════════════════════════════════════════════════════

print_header() {
    echo -e "  ${CYAN} █████╗  ██████╗ ███████╗███╗   ██╗████████╗██╗ ██████╗${NC}"
    echo -e "  ${CYAN}██╔══██╗██╔════╝ ██╔════╝████╗  ██║╚══██╔══╝██║██╔════╝${NC}"
    echo -e "  ${CYAN}███████║██║  ███╗█████╗  ██╔██╗ ██║   ██║   ██║██║     ${NC}"
    echo -e "  ${CYAN}██╔══██║██║   ██║██╔══╝  ██║╚██╗██║   ██║   ██║██║     ${NC}"
    echo -e "  ${CYAN}██║  ██║╚██████╔╝███████╗██║ ╚████║   ██║   ██║╚██████╗${NC}"
    echo -e "  ${PURPLE}╚═╝  ╚═╝ ╚═════╝ ╚══════╝╚═╝  ╚═══╝   ╚═╝   ╚═╝ ╚═════╝${NC}"
    echo -e "       ${GRAY}━━━━ Multi-Agent Development Environment ━━━━${NC}"
}

# ═══════════════════════════════════════════════════════════════════════════════
# NEW PROJECT WIZARD
# ═══════════════════════════════════════════════════════════════════════════════

# Project type presets with suggested specialists
declare -A PROJECT_PRESETS
PROJECT_PRESETS["web"]="frontend,backend,api,database,tests"
PROJECT_PRESETS["mobile"]="ios,android,api,backend,tests"
PROJECT_PRESETS["fullstack"]="frontend,backend,api,database,devops,tests"
PROJECT_PRESETS["api"]="api,database,auth,tests,docs"
PROJECT_PRESETS["cli"]="core,parser,utils,tests,docs"
PROJECT_PRESETS["audio"]="dsp,ui,engine,tests"
PROJECT_PRESETS["game"]="engine,graphics,physics,audio,ui"
PROJECT_PRESETS["ml"]="model,data,training,inference,api"
PROJECT_PRESETS["custom"]=""

# Editor selection screen - Terminal vs Cursor
show_editor_selection() {
    local E_CUR=0
    local E_OPTS=("Terminal (Claude Code)" "Cursor IDE")

    draw_editor() {
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${ORANGE}SELECT EDITOR${NC}"
        echo -e "  ${GRAY}↑↓ or 1-2 to select   ⏎ confirm   q back${NC}"
        echo ""
        for i in "${!E_OPTS[@]}"; do
            if [[ $i -eq $E_CUR ]]; then
                echo -e "  ${REVERSE}${CYAN}${BOLD} ▸ $((i+1)). ${E_OPTS[$i]} ${NC}"
            else
                echo -e "    ${WHITE}$((i+1)). ${E_OPTS[$i]}${NC}"
            fi
        done
    }

    tput civis
    draw_editor
    while true; do
        read -rsn1 key
        case "$key" in
            $'\x1b') read -rsn2 key
                [[ "$key" = "[A" ]] && { E_CUR=$(((E_CUR+1)%2)); draw_editor; }
                [[ "$key" = "[B" ]] && { E_CUR=$(((E_CUR+1)%2)); draw_editor; }
                ;;
            1) E_CUR=0; break ;;
            2) E_CUR=1; break ;;
            q|Q) tput cnorm; exec "$0" "$@" ;;
            "") break ;;
        esac
    done
    tput cnorm

    if [[ $E_CUR -eq 0 ]]; then
        SELECTED_EDITOR="terminal"
    else
        SELECTED_EDITOR="cursor"
    fi
}

# Setup type selection - Smart vs Quick
show_setup_type_menu() {
    local ST_CUR=0
    local ST_OPTS=("Smart Setup (recommended)|Interactive agent config" "Quick Setup|Use template defaults")

    draw_setup_type() {
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${ORANGE}SETUP TYPE${NC}"
        echo -e "  ${GRAY}↑↓ or 1-2 to select   ⏎ confirm${NC}"
        echo ""
        for i in "${!ST_OPTS[@]}"; do
            IFS='|' read -r label desc <<< "${ST_OPTS[$i]}"
            if [[ $i -eq $ST_CUR ]]; then
                echo -e "  ${REVERSE}${CYAN}${BOLD} ▸ $((i+1)). ${label} ${NC}"
                echo -e "       ${GRAY}${desc}${NC}"
            else
                echo -e "    ${WHITE}$((i+1)). ${label}${NC}"
                echo -e "       ${GRAY}${desc}${NC}"
            fi
            echo ""
        done
    }

    tput civis
    draw_setup_type
    while true; do
        read -rsn1 key
        case "$key" in
            $'\x1b') read -rsn2 key
                if [[ "$key" = "[A" ]]; then ((ST_CUR=(ST_CUR+1)%2)) || true; draw_setup_type; fi
                if [[ "$key" = "[B" ]]; then ((ST_CUR=(ST_CUR+1)%2)) || true; draw_setup_type; fi
                ;;
            1) ST_CUR=0; break ;;
            2) ST_CUR=1; break ;;
            "") break ;;
        esac
    done
    tput cnorm

    [[ $ST_CUR -eq 0 ]] && echo "smart" || echo "quick"
}

# Extract role name from specialist directory path
# Usage: get_role_from_dir "/path/to/Vocal-DIH-backend" "/path/to/Vocal-DIH"
# Returns: "backend"
get_role_from_dir() {
    local dir_basename=$(basename "$1")
    local slug=$(basename "$2")
    echo "${dir_basename#${slug}-}"
}

# Agent count adjustment screen
# All TUI output goes to /dev/tty so it shows on screen even when called in subshell
show_agent_count_screen() {
    local MAX_TOTAL=${1:-12}; shift
    local -a raw_args=("$@")
    local -a agents=()   # Agent names
    local -a counts=()   # Current counts (parallel array)
    local -a mins=()     # Minimum counts (parallel array)
    local A_CUR=0
    local SCROLL_OFF=0
    local VISIBLE=6  # Show 6 agents at a time

    # Parse args: "name" (min=1) or "name:N" (min=N, start=N)
    for arg in "${raw_args[@]}"; do
        if [[ "$arg" == *:* ]]; then
            agents+=("${arg%%:*}")
            local init="${arg##*:}"
            counts+=(${init})
            mins+=(${init})
        else
            agents+=("$arg")
            counts+=(1)
            mins+=(1)
        fi
    done
    local NUM_AGENTS=${#agents[@]}

    # Calculate total agents
    get_total() {
        local total=0
        for c in "${counts[@]}"; do ((total+=c)); done
        echo $total
    }

    draw_counts() {
        local total=$(get_total)
        local remaining=$((MAX_TOTAL - total))

        # Adjust scroll to keep cursor visible
        [[ $A_CUR -lt $SCROLL_OFF ]] && SCROLL_OFF=$A_CUR
        [[ $A_CUR -ge $((SCROLL_OFF + VISIBLE)) ]] && SCROLL_OFF=$((A_CUR - VISIBLE + 1))

        {
            printf '\033[2J\033[3J\033[H'
            print_header
            echo ""
            echo -e "  ${ORANGE}AGENT COUNT ADJUSTMENT${NC}  ${GRAY}Total: ${total}/${MAX_TOTAL}${NC}"
            echo -e "  ${GRAY}↑↓ select   ←→ adjust   ⏎ confirm   q=back${NC}"
            # Scroll indicator - above
            [[ $SCROLL_OFF -gt 0 ]] && echo -e "  ${GRAY}  ↑ more above${NC}" || echo ""
            # Show visible portion
            for ((i=SCROLL_OFF; i<SCROLL_OFF+VISIBLE && i<NUM_AGENTS; i++)); do
                local a="${agents[$i]}"
                local c="${counts[$i]}"
                local left="◄" right="►"
                [[ $c -le ${mins[$i]} ]] && left=" "
                # Can't increase if at 3 OR if total would exceed max
                [[ $c -eq 3 || $remaining -eq 0 ]] && right=" "
                if [[ $i -eq $A_CUR ]]; then
                    printf "  ${REVERSE}${CYAN}${BOLD} %-10s ${NC}  %s [${c}] %s\n" "$a" "$left" "$right"
                else
                    printf "    ${WHITE}%-10s${NC}    [${c}]\n" "$a"
                fi
            done
            # Scroll indicator - below
            [[ $((SCROLL_OFF + VISIBLE)) -lt $NUM_AGENTS ]] && echo -e "  ${GRAY}  ↓ more below${NC}" || echo ""
            echo ""
            if [[ $remaining -eq 0 ]]; then
                echo -e "  ${YELLOW}Max agents reached (${MAX_TOTAL})${NC}"
            fi
            echo -e "  ${GREEN}⏎ Press Enter to confirm${NC}"
        } > /dev/tty
    }

    tput civis > /dev/tty
    draw_counts
    while true; do
        read -rsn1 key < /dev/tty
        case "$key" in
            $'\x1b') read -rsn2 key < /dev/tty
                case "$key" in
                    "[A") ((A_CUR=(A_CUR+NUM_AGENTS-1)%NUM_AGENTS)); draw_counts ;;
                    "[B") ((A_CUR=(A_CUR+1)%NUM_AGENTS)); draw_counts ;;
                    "[D") # Left arrow - decrease (respects minimum)
                        [[ ${counts[$A_CUR]} -gt ${mins[$A_CUR]} ]] && ((counts[$A_CUR]--))
                        draw_counts ;;
                    "[C") # Right arrow - increase
                        local total=$(get_total)
                        # Only increase if under max and under 3
                        if [[ ${counts[$A_CUR]} -lt 3 && $total -lt $MAX_TOTAL ]]; then
                            ((counts[$A_CUR]++))
                        fi
                        draw_counts ;;
                esac
                ;;
            [qQ]) tput cnorm > /dev/tty; echo "BACK"; return ;;
            "") break ;;
        esac
    done
    tput cnorm > /dev/tty

    # Return counts as CSV: agent1:count1,agent2:count2,... (skip count 0)
    local result=""
    for i in "${!agents[@]}"; do
        [[ ${counts[$i]} -eq 0 ]] && continue
        [[ -n "$result" ]] && result+=","
        result+="${agents[$i]}:${counts[$i]}"
    done
    echo "$result"
}

run_new_project_wizard() {
    trap 'echo ""; echo -e "  ${GRAY}Returning to menu...${NC}"; sleep 0.5; exec "$0"' INT

    # State variables
    local PROJECT_NAME="" PROJECT_SLUG="" MAIN_DIR="" PROJECT_TYPE="" SPECIALISTS_CSV="" USE_WORKTREES="y"
    local CURRENT_STEP=1
    local SETUP_MODE="quick"  # "smart" or "quick"

    # Role descriptions
    declare -A ROLE_DESCS=(
        ["frontend"]="React/Vue, CSS, UI"
        ["backend"]="Server, business logic"
        ["api"]="REST/GraphQL endpoints"
        ["database"]="Schema, queries"
        ["tests"]="Unit, integration, E2E"
        ["devops"]="CI/CD, deployment"
        ["docs"]="README, tutorials"
        ["auth"]="Security, login"
        ["ui"]="Design, experience"
        ["dsp"]="Audio/signal processing"
        ["engine"]="Core processing"
        ["mobile"]="iOS/Android"
        ["data"]="Pipelines, ETL"
        ["ml"]="Models, training"
        ["review"]="Code quality"
    )

    # Project types
    local -a PROJECT_TYPES=(
        "web:Web App:frontend,backend,api,tests"
        "mobile:Mobile App:ios,android,api,tests"
        "fullstack:Full Stack:frontend,backend,api,database,tests"
        "api:API/Backend:api,database,auth,tests"
        "cli:CLI Tool:core,parser,utils,tests"
        "audio:Audio/DSP:dsp,ui,engine,tests"
        "game:Game:engine,graphics,audio,ui"
        "ml:ML/AI:model,data,api,tests"
        "custom:Custom:based on description"
    )

    suggest_agents() {
        local name_lower=$(echo "$1" | tr '[:upper:]' '[:lower:]')
        if [[ "$name_lower" =~ (audio|sound|music|dsp|synth|plugin|vst) ]]; then echo "dsp,engine,ui,tests"
        elif [[ "$name_lower" =~ (web|site|dashboard|admin) ]]; then echo "frontend,backend,api,tests"
        elif [[ "$name_lower" =~ (mobile|app|ios|android) ]]; then echo "mobile,backend,api,tests"
        elif [[ "$name_lower" =~ (game|gaming|unity) ]]; then echo "engine,graphics,audio,ui"
        elif [[ "$name_lower" =~ (ml|ai|model|neural) ]]; then echo "ml,data,api,tests"
        elif [[ "$name_lower" =~ (cli|tool|command) ]]; then echo "engine,parser,utils,tests"
        elif [[ "$name_lower" =~ (api|server|backend) ]]; then echo "api,database,auth,tests"
        else echo "frontend,backend,tests"; fi
    }

    # Main wizard loop
    while true; do
        case $CURRENT_STEP in
            1) # Project Name
                printf '\033[2J\033[3J\033[H'
                print_header
                echo -e "  ${ORANGE}Step 1/6:${NC} ${WHITE}Project name?${NC}"
                echo -e "  ${GRAY}q=quit to menu${NC}"
                echo ""
                echo -n "  > "
                read -r PROJECT_NAME || true
                [[ -z "$PROJECT_NAME" || "$PROJECT_NAME" =~ ^[qQ]$ ]] && return 1
                PROJECT_SLUG=$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd '[:alnum:]-')
                # Use ~/projects/ in Docker, ~/code/ otherwise
                if [ -f /.dockerenv ] || grep -q docker /proc/1/cgroup 2>/dev/null; then
                    MAIN_DIR="$HOME/projects/$PROJECT_SLUG"
                else
                    MAIN_DIR="$HOME/code/$PROJECT_SLUG"
                fi
                ((CURRENT_STEP++))
                ;;

            2) # Directory
                local S2_OPTS=("Use default: ~/code/$PROJECT_SLUG" "Enter custom path" "← BACK")
                local S2_CUR=0
                draw_s2() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo -e "  ${CYAN}Project:${NC} $PROJECT_NAME"
                    echo ""
                    echo -e "  ${ORANGE}Step 2/6:${NC} ${WHITE}Where should it live?${NC}"
                    echo -e "  ${GRAY}↑↓ Enter  q=quit${NC}"
                    echo ""
                    for i in "${!S2_OPTS[@]}"; do
                        local c="$WHITE"; [[ $i -eq 2 ]] && c="$ORANGE"
                        [[ $i -eq $S2_CUR ]] && echo -e "  ${REVERSE}${c} ▸ ${S2_OPTS[$i]} ${NC}" || echo -e "    ${c}${S2_OPTS[$i]}${NC}"
                    done
                }
                tput civis; draw_s2
                while true; do
                    read -rsn1 key
                    [[ "$key" = $'\x1b' ]] && { read -rsn2 key; [[ "$key" = "[A" ]] && ((S2_CUR=(S2_CUR+2)%3)); [[ "$key" = "[B" ]] && ((S2_CUR=(S2_CUR+1)%3)); draw_s2; }
                    [[ "$key" = "" ]] && break
                    [[ "$key" =~ [qQ] ]] && { tput cnorm; return 1; }
                done
                tput cnorm
                case $S2_CUR in
                    0) ((CURRENT_STEP++)) ;;
                    1) printf '\033[2J\033[3J\033[H'; print_header; echo -e "  ${ORANGE}Enter path:${NC}"; echo -n "  > "; read -r p; [[ -n "$p" ]] && MAIN_DIR="${p/#\~/$HOME}"; ((CURRENT_STEP++)) ;;
                    2) ((CURRENT_STEP--)) ;;
                esac
                ;;

            3) # Setup Type - Smart (PRD) vs Quick (presets) vs Import PRD
                local ST_OPTS=("Smart Setup|AI-guided with PRD generation" "Quick Setup|Pick a preset template" "I have a PRD|Import your existing PRD file")
                local ST_NUM=${#ST_OPTS[@]}
                local ST_TOTAL=$((ST_NUM + 1))  # +1 for BACK option
                local ST_CUR=0
                draw_st() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo -e "  ${CYAN}Project:${NC} ${WHITE}${BOLD}$PROJECT_NAME${NC}  ${GRAY}($MAIN_DIR)${NC}"
                    echo -e "  ${ORANGE}Step 3/6:${NC} ${WHITE}Setup method?${NC}  ${GRAY}↑↓ enter=select q=quit${NC}"
                    echo ""
                    for i in "${!ST_OPTS[@]}"; do
                        IFS='|' read -r label desc <<< "${ST_OPTS[$i]}"
                        if [[ $i -eq $ST_CUR ]]; then
                            echo -e "  ${REVERSE}${CYAN}${BOLD} ▸ ${label} ${NC}"
                            echo -e "       ${GREEN}${desc}${NC}"
                        else
                            echo -e "    ${WHITE}${label}${NC}"
                            echo -e "       ${GRAY}${desc}${NC}"
                        fi
                        echo ""
                    done
                    echo ""
                    if [[ $ST_CUR -eq $ST_NUM ]]; then
                        echo -e "  ${REVERSE}${ORANGE}${BOLD} ← BACK ${NC}"
                    else
                        echo -e "    ${ORANGE}← BACK${NC}"
                    fi
                }
                tput civis; draw_st
                while true; do
                    read -rsn1 key
                    if [[ "$key" = $'\x1b' ]]; then
                        read -rsn2 key
                        [[ "$key" = "[A" ]] && ((ST_CUR=(ST_CUR+ST_TOTAL-1)%ST_TOTAL))
                        [[ "$key" = "[B" ]] && ((ST_CUR=(ST_CUR+1)%ST_TOTAL))
                        draw_st
                        continue
                    fi
                    [[ "$key" = "" ]] && break
                    [[ "$key" =~ [qQ] ]] && { tput cnorm; return 1; }
                done
                tput cnorm

                # Handle BACK option
                if [[ $ST_CUR -eq $ST_NUM ]]; then
                    ((CURRENT_STEP--))
                elif [[ $ST_CUR -eq 0 ]]; then
                    # Smart Setup - run PRD generator
                    SETUP_MODE="smart"
                    mkdir -p "$MAIN_DIR"
                    generate_prd_interactive "$MAIN_DIR" "$PROJECT_NAME"
                    local prd_result=$?
                    if [[ $prd_result -eq 0 ]]; then
                        # Success - analyze PRD for agent suggestions (spinner shown in function)
                        SPECIALISTS_CSV=$(analyze_prd "$MAIN_DIR/PRD.md" "$PROJECT_NAME")
                        PROJECT_TYPE="prd-generated"
                        echo -e "  ${GREEN}✓${NC} Suggested agents: ${SPECIALISTS_CSV}"
                        sleep 1
                        CURRENT_STEP=5  # Skip to specialist confirmation
                    elif [[ $prd_result -eq 2 ]]; then
                        # User pressed back on step 1, go to previous wizard step
                        ((CURRENT_STEP--))
                    else
                        # User quit PRD generator (q), return to main menu
                        return 1
                    fi
                elif [[ $ST_CUR -eq 1 ]]; then
                    # Quick Setup - use presets
                    SETUP_MODE="quick"
                    ((CURRENT_STEP++))
                else
                    # Import existing PRD
                    SETUP_MODE="smart"
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo -e "  ${ORANGE}IMPORT PRD${NC}"
                    echo ""
                    echo -e "  ${WHITE}How to import your PRD:${NC}"
                    echo -e "  ${GRAY}• Drag & drop the file into this terminal window${NC}"
                    echo -e "  ${GRAY}• Or paste/type the full path to your .md file${NC}"
                    echo -e "  ${GRAY}• Supports: ~/path, /full/path, or relative paths${NC}"
                    echo ""
                    echo -e "  ${GRAY}b=back  q=quit${NC}"
                    echo ""
                    echo -n "  Path: > "
                    tput cnorm
                    read -e -r prd_path || true
                    # Handle back/quit
                    [[ "$prd_path" =~ ^[bB]$ ]] && continue
                    [[ "$prd_path" =~ ^[qQ]$ ]] && return 1
                    # Clean path (remove quotes, escapes, prefixes from drag & drop)
                    prd_path="${prd_path//\'/}"
                    prd_path="${prd_path//\"/}"
                    prd_path="${prd_path//\\ / }"
                    prd_path="${prd_path#file://}"
                    prd_path="${prd_path//$'\r'/}"
                    prd_path="${prd_path/#\~/$HOME}"
                    # Convert Windows paths to Docker mount path
                    if [[ "$prd_path" =~ ^[A-Za-z]:\\.*\\projects\\ ]]; then
                        local win_relative="${prd_path#*\\projects\\}"
                        win_relative="${win_relative//\\//}"
                        prd_path="/home/agentic/projects/$win_relative"
                    fi
                    # Trim all whitespace
                    prd_path="$(echo -n "$prd_path" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

                    if [[ -f "$prd_path" ]]; then
                        mkdir -p "$MAIN_DIR"
                        cp "$prd_path" "$MAIN_DIR/PRD.md"
                        echo ""
                        echo -e "  ${GREEN}✓${NC} PRD imported to $MAIN_DIR/PRD.md"
                        # Analyze PRD for agent suggestions (spinner shown in function)
                        SPECIALISTS_CSV=$(analyze_prd "$MAIN_DIR/PRD.md" "$PROJECT_NAME")
                        PROJECT_TYPE="prd-generated"
                        echo -e "  ${GREEN}✓${NC} Suggested agents: ${SPECIALISTS_CSV}"
                        sleep 1.5
                        CURRENT_STEP=5  # Skip to specialist confirmation
                    else
                        echo ""
                        echo -e "  ${RED}✗${NC} File not found: $prd_path"
                        echo -e "  ${GRAY}Press any key to try again...${NC}"
                        read -rsn1
                        # Stay on this step to retry
                    fi
                fi
                ;;

            4) # Project Type (show all, inline custom input)
                local NUM_T=${#PROJECT_TYPES[@]}
                local T_CUR=0 BACK_IDX=$NUM_T CUSTOM_IDX=$((NUM_T-1))
                local CUSTOM_INPUT=""
                draw_s3() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo ""
                    echo -e "  ${CYAN}Project:${NC} ${WHITE}${BOLD}$PROJECT_NAME${NC}  ${GRAY}($MAIN_DIR)${NC}"
                    echo -e "  ${ORANGE}Step 4/6:${NC} ${WHITE}Project type?${NC}  ${GRAY}↑↓ enter=select q=quit${NC}"
                    echo ""
                    for i in "${!PROJECT_TYPES[@]}"; do
                        IFS=':' read -r tid tname tagents <<< "${PROJECT_TYPES[$i]}"
                        if [[ $i -eq $T_CUR ]]; then
                            if [[ $i -eq $CUSTOM_IDX ]]; then
                                echo -e "    ${REVERSE}${GREEN}${BOLD} ▸ $tname ${NC} ${GRAY}describe:${NC} ${GREEN}${CUSTOM_INPUT}${NC}"
                            else
                                echo -e "    ${REVERSE}${GREEN}${BOLD} ▸ $tname ${NC}  ${GREEN}$tagents${NC}"
                            fi
                        else
                            if [[ $i -eq $CUSTOM_IDX ]]; then
                                echo -e "      ${WHITE}$tname${NC}  ${GRAY}describe your project${NC}"
                            else
                                echo -e "      ${WHITE}$tname${NC}  ${GRAY}$tagents${NC}"
                            fi
                        fi
                    done
                    echo ""
                    if [[ $T_CUR -eq $BACK_IDX ]]; then
                        echo -e "    ${REVERSE}${ORANGE}${BOLD} ← BACK ${NC}"
                    else
                        echo -e "      ${ORANGE}← BACK${NC}"
                    fi
                }
                tput civis; draw_s3
                while true; do
                    read -rsn1 key
                    if [[ "$key" = $'\x1b' ]]; then
                        read -rsn2 key
                        [[ "$key" = "[A" ]] && ((T_CUR=(T_CUR+BACK_IDX)%(BACK_IDX+1)))
                        [[ "$key" = "[B" ]] && ((T_CUR=(T_CUR+1)%(BACK_IDX+1)))
                        draw_s3
                    elif [[ "$key" = "" ]]; then
                        if [[ $T_CUR -eq $CUSTOM_IDX ]]; then
                            # Custom input mode - redraw with input prompt
                            printf '\033[2J\033[3J\033[H'
                            print_header
                            echo ""
                            echo ""
                            echo -e "  ${CYAN}Project:${NC} ${WHITE}${BOLD}$PROJECT_NAME${NC}  ${GRAY}($MAIN_DIR)${NC}"
                            echo -e "  ${ORANGE}Step 4/6:${NC} ${WHITE}Project type?${NC}  ${GRAY}enter empty to cancel${NC}"
                            echo ""
                            for i in "${!PROJECT_TYPES[@]}"; do
                                IFS=':' read -r tid tname tagents <<< "${PROJECT_TYPES[$i]}"
                                if [[ $i -eq $CUSTOM_IDX ]]; then
                                    echo -ne "    ${REVERSE}${GREEN}${BOLD} ▸ $tname ${NC} ${GRAY}describe:${NC} "
                                else
                                    echo -e "      ${WHITE}$tname${NC}  ${GRAY}$tagents${NC}"
                                fi
                            done
                            tput cnorm
                            read -r CUSTOM_INPUT
                            tput civis
                            # Empty or whitespace-only = cancel, redraw and go back to selection
                            if [[ -z "${CUSTOM_INPUT// /}" ]]; then
                                CUSTOM_INPUT=""
                                draw_s3
                                continue
                            fi
                        fi
                        break
                    elif [[ "$key" =~ [qQ] ]]; then
                        tput cnorm; return 1
                    fi
                done
                tput cnorm
                if [[ $T_CUR -eq $BACK_IDX ]]; then ((CURRENT_STEP--))
                else
                    IFS=':' read -r PROJECT_TYPE _ SPECIALISTS_CSV <<< "${PROJECT_TYPES[$T_CUR]}"
                    [[ "$PROJECT_TYPE" = "custom" ]] && SPECIALISTS_CSV=$(suggest_agents "$PROJECT_NAME $CUSTOM_INPUT")
                    ((CURRENT_STEP++))
                fi
                ;;

            5) # Specialists
                # Clean SPECIALISTS_CSV: strip spinner/ANSI artifacts that get captured
                # when analyze_prd is called inside $(...) - the spin_while output
                # contaminates the variable with escape codes and newlines
                local _clean_csv
                _clean_csv=$(printf '%s' "$SPECIALISTS_CSV" | tr -d '\r' | tail -1 | sed $'s/\x1b\[[^a-zA-Z]*[a-zA-Z]//g' | tr -cd 'a-z,')
                _clean_csv="${_clean_csv#,}"
                _clean_csv="${_clean_csv%,}"
                [[ -n "$_clean_csv" && "$_clean_csv" == *,* ]] && SPECIALISTS_CSV="$_clean_csv"
                local S4_OPTS=("Use these agents" "Edit agents" "Adjust counts" "← BACK")
                local S4_CUR=0
                draw_s4() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo -e "  ${CYAN}Project:${NC} $PROJECT_NAME ${GRAY}($PROJECT_TYPE)${NC}"
                    echo -e "  ${ORANGE}Step 5/6:${NC} ${WHITE}Specialist agents${NC}  ${GRAY}↑↓ Enter q=quit${NC}"
                    echo ""
                    # Display suggested agents as a visible list
                    echo -e "  ${WHITE}Suggested:${NC} ${GREEN}${SPECIALISTS_CSV}${NC}"
                    echo ""
                    for i in "${!S4_OPTS[@]}"; do
                        local c="$WHITE"; [[ $i -eq 0 ]] && c="$GREEN"; [[ $i -eq 3 ]] && c="$ORANGE"
                        [[ $i -eq $S4_CUR ]] && echo -e "  ${REVERSE}${c} ▸ ${S4_OPTS[$i]} ${NC}" || echo -e "    ${c}${S4_OPTS[$i]}${NC}"
                    done
                }
                tput civis; draw_s4
                while true; do
                    read -rsn1 key
                    [[ "$key" = $'\x1b' ]] && { read -rsn2 key; [[ "$key" = "[A" ]] && ((S4_CUR=(S4_CUR+3)%4)); [[ "$key" = "[B" ]] && ((S4_CUR=(S4_CUR+1)%4)); draw_s4; }
                    [[ "$key" = "" ]] && break
                    [[ "$key" =~ [qQ] ]] && { tput cnorm; return 1; }
                done
                tput cnorm
                case $S4_CUR in
                    0) # Use these agents - accept suggestions and proceed directly
                        ((CURRENT_STEP++))
                        ;;
                    1) # Edit agents - role selector with suggestions pre-checked
                        local ALL_ROLES=(frontend backend api database tests devops docs auth ui dsp engine mobile data ml review)
                        local NUM_R=${#ALL_ROLES[@]} R_CUR=0
                        declare -a SEL; for i in "${!ALL_ROLES[@]}"; do SEL[$i]=0; done
                        # Pre-check the suggested agents (trim whitespace from each entry)
                        IFS=',' read -ra PRE <<< "$SPECIALISTS_CSV"
                        for p in "${PRE[@]}"; do
                            p="${p## }"; p="${p%% }"  # trim spaces
                            for i in "${!ALL_ROLES[@]}"; do [[ "${ALL_ROLES[$i]}" = "$p" ]] && SEL[$i]=1; done
                        done
                        local DONE_I=$NUM_R BACK_I=$((NUM_R+1)) TOT=$((NUM_R+2))
                        local SCROLL_OFF=0 VISIBLE=8
                        # Role descriptions
                        get_role_desc() {
                            case "$1" in
                                frontend) echo "React/Vue, CSS, UI" ;;
                                backend) echo "Server, business logic" ;;
                                api) echo "REST/GraphQL endpoints" ;;
                                database) echo "Schema, queries" ;;
                                tests) echo "Unit, integration, E2E" ;;
                                devops) echo "CI/CD, deployment" ;;
                                docs) echo "README, tutorials" ;;
                                auth) echo "Security, login" ;;
                                ui) echo "Design, experience" ;;
                                dsp) echo "Audio/signal processing" ;;
                                engine) echo "Core processing" ;;
                                mobile) echo "iOS/Android" ;;
                                data) echo "Pipelines, ETL" ;;
                                ml) echo "Models, training" ;;
                                review) echo "Code quality" ;;
                                *) echo "" ;;
                            esac
                        }
                        draw_roles() {
                            # Adjust scroll to keep cursor visible
                            if [[ $R_CUR -lt $NUM_R ]]; then
                                [[ $R_CUR -lt $SCROLL_OFF ]] && SCROLL_OFF=$R_CUR
                                [[ $R_CUR -ge $((SCROLL_OFF + VISIBLE)) ]] && SCROLL_OFF=$((R_CUR - VISIBLE + 1))
                            fi
                            printf '\033[2J\033[3J\033[H'
                            print_header
                            echo -e "  ${ORANGE}Step 5/6:${NC} ${WHITE}Edit agents${NC}  ${GRAY}↑↓ Space=toggle Enter=select${NC}"
                            # Show scroll indicator if needed
                            [[ $SCROLL_OFF -gt 0 ]] && echo -e "  ${GRAY}  ↑ more above${NC}" || echo ""
                            # Show visible portion of roles with descriptions
                            for ((i=SCROLL_OFF; i<SCROLL_OFF+VISIBLE && i<NUM_R; i++)); do
                                local r="${ALL_ROLES[$i]}" cb="○" clr="$WHITE"
                                local desc=$(get_role_desc "$r")
                                [[ "${SEL[$i]}" -eq 1 ]] && { cb="●"; clr="$GREEN"; }
                                if [[ $i -eq $R_CUR ]]; then
                                    printf "  ${REVERSE}${clr} $cb %-10s${NC} ${GRAY}$desc${NC}\n" "$r"
                                else
                                    printf "  ${clr} $cb %-10s${NC} ${GRAY}$desc${NC}\n" "$r"
                                fi
                            done
                            [[ $((SCROLL_OFF + VISIBLE)) -lt $NUM_R ]] && echo -e "  ${GRAY}  ↓ more below${NC}" || echo ""
                            echo ""
                            [[ $R_CUR -eq $DONE_I ]] && echo -e "  ${REVERSE}${GREEN} ✓ DONE ${NC}" || echo -e "    ${GREEN}✓ DONE${NC}"
                            [[ $R_CUR -eq $BACK_I ]] && echo -e "  ${REVERSE}${ORANGE} ← BACK ${NC}" || echo -e "    ${ORANGE}← BACK${NC}"
                        }
                        tput civis; draw_roles
                        local role_done=0
                        while [[ $role_done -eq 0 ]]; do
                            read -rsn1 key
                            [[ "$key" = $'\x1b' ]] && { read -rsn2 key; [[ "$key" = "[A" ]] && ((R_CUR=(R_CUR+TOT-1)%TOT)); [[ "$key" = "[B" ]] && ((R_CUR=(R_CUR+1)%TOT)); draw_roles; }
                            [[ "$key" = " " && $R_CUR -lt $NUM_R ]] && { SEL[$R_CUR]=$((1-SEL[$R_CUR])); draw_roles; }
                            [[ "$key" = "" ]] && {
                                [[ $R_CUR -eq $DONE_I ]] && role_done=1
                                [[ $R_CUR -eq $BACK_I ]] && { role_done=2; }
                                [[ $R_CUR -lt $NUM_R ]] && { SEL[$R_CUR]=$((1-SEL[$R_CUR])); draw_roles; }
                            }
                            [[ "$key" =~ [qQ] ]] && { tput cnorm; return 1; }
                        done
                        tput cnorm
                        [[ $role_done -eq 2 ]] && continue
                        # Rebuild SPECIALISTS_CSV from the checked items
                        SPECIALISTS_CSV=""
                        for i in "${!ALL_ROLES[@]}"; do [[ "${SEL[$i]}" -eq 1 ]] && SPECIALISTS_CSV="${SPECIALISTS_CSV:+$SPECIALISTS_CSV,}${ALL_ROLES[$i]}"; done
                        # After editing, return to this step to show updated suggestions
                        # (user can then "Use these agents" or "Adjust counts")
                        ;;
                    2) # Adjust counts - show count adjustment screen
                        IFS=',' read -ra agent_arr <<< "$SPECIALISTS_CSV"
                        local counts_result
                        counts_result=$(show_agent_count_screen 12 "${agent_arr[@]}")
                        if [[ "$counts_result" = "BACK" ]]; then
                            : # Stay on this step
                        elif [[ -n "$counts_result" ]]; then
                            # Parse counts and rebuild SPECIALISTS_CSV with duplicates
                            SPECIALISTS_CSV=""
                            IFS=',' read -ra count_pairs <<< "$counts_result"
                            for pair in "${count_pairs[@]}"; do
                                IFS=':' read -r agent count <<< "$pair"
                                for ((c=0; c<count; c++)); do
                                    SPECIALISTS_CSV="${SPECIALISTS_CSV:+$SPECIALISTS_CSV,}$agent"
                                done
                            done
                            ((CURRENT_STEP++))
                        fi
                        ;;
                    3) ((CURRENT_STEP--)) ;;
                esac
                ;;

            6) # Git Worktrees
                local S5_OPTS=("Yes - git worktrees (recommended)" "No - simple directories" "← BACK")
                local S5_CUR=0
                draw_s5() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo -e "  ${CYAN}Project:${NC} $PROJECT_NAME  ${GRAY}Agents: $SPECIALISTS_CSV${NC}"
                    echo -e "  ${ORANGE}Step 6/6:${NC} ${WHITE}Use git worktrees?${NC}  ${GRAY}↑↓ Enter q=quit${NC}"
                    echo ""
                    for i in "${!S5_OPTS[@]}"; do
                        local c="$WHITE"; [[ $i -eq 2 ]] && c="$ORANGE"
                        [[ $i -eq $S5_CUR ]] && echo -e "  ${REVERSE}${c} ▸ ${S5_OPTS[$i]} ${NC}" || echo -e "    ${c}${S5_OPTS[$i]}${NC}"
                    done
                }
                tput civis; draw_s5
                while true; do
                    read -rsn1 key
                    [[ "$key" = $'\x1b' ]] && { read -rsn2 key; [[ "$key" = "[A" ]] && ((S5_CUR=(S5_CUR+2)%3)); [[ "$key" = "[B" ]] && ((S5_CUR=(S5_CUR+1)%3)); draw_s5; }
                    [[ "$key" = "" ]] && break
                    [[ "$key" =~ [qQ] ]] && { tput cnorm; return 1; }
                done
                tput cnorm
                case $S5_CUR in
                    0) USE_WORKTREES="y"; ((CURRENT_STEP++)) ;;
                    1) USE_WORKTREES="n"; ((CURRENT_STEP++)) ;;
                    2) ((CURRENT_STEP--)) ;;
                esac
                ;;

            7) # Confirmation
                IFS=',' read -ra SPEC_ARR <<< "$SPECIALISTS_CSV"

                # Build display string with counts for duplicates (bash 3.x compatible)
                local _counts_str=""
                local _seen_types=""
                for s in "${SPEC_ARR[@]}"; do
                    local _cur=0
                    if [[ "$_counts_str" == *"$s:"* ]]; then
                        _cur=$(echo "$_counts_str" | grep -o "$s:[0-9]*" | cut -d: -f2)
                        _counts_str=$(echo "$_counts_str" | sed "s/$s:[0-9]*/$s:$((_cur + 1))/")
                    else
                        _counts_str="${_counts_str:+$_counts_str,}$s:1"
                        _seen_types="${_seen_types:+$_seen_types,}$s"
                    fi
                done
                local agents_display=""
                IFS=',' read -ra _types <<< "$_seen_types"
                for s in "${_types[@]}"; do
                    [[ -n "$agents_display" ]] && agents_display+=" "
                    local _cnt=$(echo "$_counts_str" | grep -o "$s:[0-9]*" | cut -d: -f2)
                    if [[ $_cnt -gt 1 ]]; then
                        agents_display+="${s}(x${_cnt})"
                    else
                        agents_display+="$s"
                    fi
                done

                local C_OPTS=("✓ CREATE PROJECT" "← BACK" "✕ CANCEL")
                local C_CUR=0
                draw_confirm() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo -e "  ${CYAN}${BOLD}PROJECT SUMMARY${NC}"
                    echo -e "  ${WHITE}Name:${NC} $PROJECT_NAME  ${WHITE}Type:${NC} $PROJECT_TYPE  ${WHITE}Worktrees:${NC} $([ "$USE_WORKTREES" = "y" ] && echo Yes || echo No)"
                    echo -e "  ${WHITE}Agents:${NC} QB + $agents_display  ${GRAY}(${#SPEC_ARR[@]} total)${NC}"
                    echo ""
                    for i in "${!C_OPTS[@]}"; do
                        local c="$GREEN"; [[ $i -eq 1 ]] && c="$ORANGE"; [[ $i -eq 2 ]] && c="$RED"
                        [[ $i -eq $C_CUR ]] && echo -e "  ${REVERSE}${c} ▸ ${C_OPTS[$i]} ${NC}" || echo -e "    ${c}${C_OPTS[$i]}${NC}"
                    done
                }
                tput civis; draw_confirm
                while true; do
                    read -rsn1 key
                    [[ "$key" = $'\x1b' ]] && { read -rsn2 key; [[ "$key" = "[A" ]] && ((C_CUR=(C_CUR+2)%3)); [[ "$key" = "[B" ]] && ((C_CUR=(C_CUR+1)%3)); draw_confirm; }
                    [[ "$key" = "" ]] && break
                    [[ "$key" =~ [qQ] ]] && { tput cnorm; return 1; }
                done
                tput cnorm
                case $C_CUR in
                    0) break ;;  # Create!
                    1) ((CURRENT_STEP--)) ;;
                    2) return 1 ;;
                esac
                ;;
        esac
    done

    # === CREATE PROJECT ===
    echo -e "  ${PURPLE}Creating project...${NC}"
    mkdir -p "$MAIN_DIR"
    echo -e "  ${GREEN}✓${NC} Created $MAIN_DIR"

    if [ ! -d "$MAIN_DIR/.git" ]; then
        git -C "$MAIN_DIR" init -q
        touch "$MAIN_DIR/.gitkeep"
        git -C "$MAIN_DIR" add . && git -C "$MAIN_DIR" commit -q -m "Initial commit"
        echo -e "  ${GREEN}✓${NC} Initialized git"
    fi

    setup_agent_config "$MAIN_DIR" "qb" "$PROJECT_NAME" "You are the QB (Quarterback) - the coordinator for $PROJECT_NAME. At the start of each session, read .claude/qb-dispatch.md for your specialist pane map and dispatch workflow. You coordinate by sending work to your existing specialist panes via tmux send-keys. Your specialists can use TeamCreate themselves for sub-agents."
    echo -e "  ${GREEN}✓${NC} Configured QB agent"

    IFS=',' read -ra SPEC_ARR <<< "$SPECIALISTS_CSV"
    declare -a SPEC_DIRS
    local SPEC_COUNTS=""  # Track counts as "type:count,type:count,..." string (bash 3.x compatible)

    for spec in "${SPEC_ARR[@]}"; do
        # Get current count for this spec type from our tracking string
        local current_count=0
        if [[ "$SPEC_COUNTS" == *"$spec:"* ]]; then
            current_count=$(echo "$SPEC_COUNTS" | grep -o "$spec:[0-9]*" | cut -d: -f2)
        fi
        local new_count=$((current_count + 1))

        # Update or add count in tracking string
        if [[ "$SPEC_COUNTS" == *"$spec:"* ]]; then
            SPEC_COUNTS=$(echo "$SPEC_COUNTS" | sed "s/$spec:[0-9]*/$spec:$new_count/")
        else
            SPEC_COUNTS="${SPEC_COUNTS:+$SPEC_COUNTS,}$spec:$new_count"
        fi

        # Add number suffix for duplicates (first one has no suffix)
        local SPEC_SUFFIX=""
        [[ $new_count -gt 1 ]] && SPEC_SUFFIX="-${new_count}"
        local SPEC_BASE="$HOME/code"
        if [ -f /.dockerenv ] || grep -q docker /proc/1/cgroup 2>/dev/null; then
            SPEC_BASE="$HOME/projects"
        fi
        local SPEC_DIR="$SPEC_BASE/${PROJECT_SLUG}-${spec}${SPEC_SUFFIX}"
        local BRANCH_NAME="feature/${spec}${SPEC_SUFFIX}"

        SPEC_DIRS+=("$SPEC_DIR")
        if [ "$USE_WORKTREES" = "y" ]; then
            git -C "$MAIN_DIR" branch "$BRANCH_NAME" 2>/dev/null || true
            git -C "$MAIN_DIR" worktree add -q "$SPEC_DIR" "$BRANCH_NAME" 2>/dev/null || mkdir -p "$SPEC_DIR"
        else
            mkdir -p "$SPEC_DIR"
        fi
        local display_name="$spec"
        [[ $new_count -gt 1 ]] && display_name="${spec}-${new_count}"
        setup_agent_config "$SPEC_DIR" "$spec" "$PROJECT_NAME" "$(get_role_description "$spec" "$PROJECT_NAME")"
        # Add .cursorrules for Cursor support
        add_cursorrules_to_project "$SPEC_DIR" "$PROJECT_NAME" "$spec"
        echo -e "  ${GREEN}✓${NC} Created $display_name"
    done

    # Add .cursorrules to QB/main directory
    add_cursorrules_to_project "$MAIN_DIR" "$PROJECT_NAME" "qb"

    # Generate PRD if not already created (quick mode)
    if [[ ! -f "$MAIN_DIR/PRD.md" ]]; then
        generate_prd_basic "$MAIN_DIR" "$PROJECT_NAME"
        echo -e "  ${GREEN}✓${NC} Created PRD.md template"
    fi

    # Generate .code-workspace file for Cursor
    local workspace_file
    workspace_file=$(generate_code_workspace "$MAIN_DIR" "$PROJECT_NAME" "$PROJECT_SLUG" "${SPEC_DIRS[@]}")
    echo -e "  ${GREEN}✓${NC} Created Cursor workspace"

    # Add to config
    local SPEC_JSON="[]"
    for dir in "${SPEC_DIRS[@]}"; do
        local dir_short="${dir/$HOME/~}"
        SPEC_JSON=$(echo "$SPEC_JSON" | jq --arg d "$dir_short" '. + [$d]')
    done
    local main_dir_short="${MAIN_DIR/$HOME/~}"
    jq --arg name "$PROJECT_NAME" --arg main "$main_dir_short" --argjson specs "$SPEC_JSON" \
        '.projects += [{"name": $name, "main_dir": $main, "specialists": $specs}]' \
        "$CONFIG" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "$CONFIG"

    sleep 0.5
    printf '\033[2J\033[3J\033[H'
    print_header
    echo ""
    echo -e "  ${GREEN}${BOLD}✓ Project '$PROJECT_NAME' created!${NC}"
    echo ""
    echo -e "  ${WHITE}Main:${NC} $MAIN_DIR"
    echo -e "  ${WHITE}Specialists:${NC} ${#SPEC_DIRS[@]}"
    echo ""
    echo -e "  Launch now? (y/n)"
    while true; do
        read -rsn1 launch
        if [[ "$launch" =~ [yY] ]]; then
            NUM_PROJECTS=$(jq '.projects | length' "$CONFIG")
            SELECTED_PROJECT=$NUM_PROJECTS
            echo "$PROJECT_NAME" > "$LAST_PROJECT_FILE"
            return 0
        elif [[ "$launch" =~ [nN] ]]; then
            exec "$0"
        fi
        # Ignore other keys, keep waiting
    done
}
# Helper function to setup agent config files
setup_agent_config() {
    local dir="$1"
    local role="$2"
    local project="$3"
    local description="$4"

    # Append TeamCreate instructions to every specialist role
    local team_instructions=""
    if [ "$role" != "qb" ]; then
        team_instructions="

TeamCreate Workflow:
For any task that involves 3+ files or building/implementing features, use TeamCreate to spin up a team of sub-agents. Break your work into sub-tasks and delegate to a team. For simple single-file edits (1-2 files), you can work solo.

Team Lifecycle — Cleanup After Completion:
When you use TeamCreate to spawn agent teams, please shut them down when the work is complete. After all teammates finish:
1. Send shutdown_request to every teammate: SendMessage type=shutdown_request to each by name
2. Wait for shutdown confirmations
3. Call TeamDelete to remove the team
4. Then commit your work and report back
Note: The QB handles tmux pane layout restoration, so you don't need to worry about that. Just focus on: shutdown teammates, TeamDelete, commit, done."
    else
        team_instructions="

Team Lifecycle Note:
You coordinate via tmux send-keys, not TeamCreate. Your specialists will use TeamCreate on their own — that's expected and you don't need to manage their teams."
    fi
    local full_description="$description $team_instructions"

    # Create .envrc
    cat > "$dir/.envrc" << EOF
export CLAUDE_AGENT_ROLE="$role"
export PROJECT_NAME="$project"
EOF

    # Create .claude/settings.local.json (use jq to properly escape special chars)
    mkdir -p "$dir/.claude"
    jq -n --arg role "$role" --arg prompt "$full_description" \
        '{
            agentRole: $role,
            systemPromptPrefix: $prompt,
            permissions: {
                allow: [
                    "Bash(echo:*)",
                    "Bash(npm run:*)",
                    "Bash(npm test:*)",
                    "Bash(git status)",
                    "Bash(git diff:*)",
                    "Bash(git log:*)",
                    "Bash(git add:*)",
                    "Bash(git commit:*)",
                    "Bash(ls:*)"
                ]
            }
        }' > "$dir/.claude/settings.local.json"

    # Allow direnv if available
    if command -v direnv &>/dev/null; then
        direnv allow "$dir" 2>/dev/null || true
    fi
}

# Generate a basic PRD.md for a project (fallback/quick mode)
generate_prd_basic() {
    local project_path="$1"
    local project_name="$2"

    cat > "$project_path/PRD.md" << EOF
# Product Requirements Document: $project_name

## Overview
Brief description of the project and its purpose.

## Goals
- Primary objective 1
- Primary objective 2

## Features
### Core Features
- Feature 1: Description
- Feature 2: Description

### Future Enhancements
- Enhancement 1
- Enhancement 2

## Technical Requirements
- Requirement 1
- Requirement 2

## Success Metrics
- Metric 1
- Metric 2

---
*Generated by AGENTIC - Customize this document for your project*
EOF
}

# Auto-generate PRD by reading project files
generate_prd_from_code() {
    local project_path="$1"
    local project_name="$2"

    echo ""
    echo -e "  ${CYAN}Analyzing $project_name codebase...${NC}"

    # Collect key files for analysis
    local files_content=""
    local max_chars=4000  # Keep small for fast PRD generation

    # Priority files to read (standard project files)
    local -a key_files=(
        "README.md" "readme.md" "README"
        "package.json" "CMakeLists.txt" "Cargo.toml" "setup.py" "pyproject.toml"
        "Makefile" "build.gradle" "pom.xml"
        "src/main.ts" "src/index.ts" "src/main.js" "src/index.js"
        "src/main.cpp" "src/main.c" "src/main.rs" "src/main.py"
        "src/App.tsx" "src/App.jsx" "src/App.vue"
        "app/main.py" "app/app.py" "main.py" "app.py"
        "lib/main.dart" "src/lib.rs"
        "AGENT_IDENTITY.md" "PRD.md" "CONTRIBUTING.md"
    )

    # Find and read key files
    local current_chars=0
    for file in "${key_files[@]}"; do
        local full_path="$project_path/$file"
        if [ -f "$full_path" ]; then
            local content=$(head -c 1500 "$full_path" 2>/dev/null)
            local file_chars=${#content}
            if [ $((current_chars + file_chars)) -lt $max_chars ]; then
                files_content+="
=== FILE: $file ===
$content
"
                current_chars=$((current_chars + file_chars))
                echo -e "    ${GREEN}✓${NC} Found $file"
            fi
        fi
    done

    # Scan for any .md files in root (documentation, identity files, etc.)
    for mdfile in "$project_path"/*.md; do
        if [ -f "$mdfile" ] && [ $current_chars -lt $max_chars ]; then
            local basename=$(basename "$mdfile")
            # Skip if already processed in key_files
            [[ " ${key_files[*]} " =~ " $basename " ]] && continue
            local content=$(head -c 2000 "$mdfile" 2>/dev/null)
            local file_chars=${#content}
            if [ $((current_chars + file_chars)) -lt $max_chars ]; then
                files_content+="
=== FILE: $basename ===
$content
"
                current_chars=$((current_chars + file_chars))
                echo -e "    ${GREEN}✓${NC} Found $basename"
            fi
        fi
    done

    # Scan for shell scripts in root (setup scripts, build scripts)
    for shfile in "$project_path"/*.sh; do
        if [ -f "$shfile" ] && [ $current_chars -lt $max_chars ]; then
            local basename=$(basename "$shfile")
            local content=$(head -c 2000 "$shfile" 2>/dev/null)
            local file_chars=${#content}
            if [ $((current_chars + file_chars)) -lt $max_chars ]; then
                files_content+="
=== FILE: $basename ===
$content
"
                current_chars=$((current_chars + file_chars))
                echo -e "    ${GREEN}✓${NC} Found $basename"
            fi
        fi
    done

    # Also scan src/ directory structure
    if [ -d "$project_path/src" ]; then
        local src_tree=$(find "$project_path/src" -type f \( -name "*.ts" -o -name "*.js" -o -name "*.tsx" -o -name "*.jsx" -o -name "*.cpp" -o -name "*.h" -o -name "*.py" -o -name "*.rs" \) 2>/dev/null | head -20)
        if [ -n "$src_tree" ]; then
            files_content+="
=== SOURCE FILES STRUCTURE ===
$src_tree
"
        fi
    fi

    # Scan subdirectories for project structure (helps with non-standard layouts)
    local dir_structure=$(find "$project_path" -maxdepth 2 -type d ! -name ".*" ! -name "node_modules" ! -name "__pycache__" ! -name "build" ! -name "dist" 2>/dev/null | head -30)
    if [ -n "$dir_structure" ]; then
        files_content+="
=== DIRECTORY STRUCTURE ===
$dir_structure
"
    fi

    # Look for AGENT_IDENTITY.md files in subdirectories (AGENTIC-style projects)
    local identity_files=$(find "$project_path" -maxdepth 2 -name "AGENT_IDENTITY.md" 2>/dev/null | head -5)
    for idfile in $identity_files; do
        if [ -f "$idfile" ] && [ $current_chars -lt $max_chars ]; then
            local relpath="${idfile#$project_path/}"
            local content=$(head -c 1500 "$idfile" 2>/dev/null)
            local file_chars=${#content}
            if [ $((current_chars + file_chars)) -lt $max_chars ]; then
                files_content+="
=== FILE: $relpath ===
$content
"
                current_chars=$((current_chars + file_chars))
                echo -e "    ${GREEN}✓${NC} Found $relpath"
            fi
        fi
    done

    # Fallback: if still nothing, scan for any code files
    if [ -z "$files_content" ]; then
        echo -e "  ${GRAY}Scanning for code files...${NC}"
        local code_files=$(find "$project_path" -maxdepth 3 -type f \( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.cpp" -o -name "*.c" -o -name "*.h" -o -name "*.rs" -o -name "*.go" -o -name "*.java" -o -name "*.swift" -o -name "*.kt" \) ! -path "*/node_modules/*" ! -path "*/.git/*" 2>/dev/null | head -10)
        for codefile in $code_files; do
            if [ -f "$codefile" ] && [ $current_chars -lt $max_chars ]; then
                local relpath="${codefile#$project_path/}"
                local content=$(head -c 2000 "$codefile" 2>/dev/null)
                local file_chars=${#content}
                if [ $((current_chars + file_chars)) -lt $max_chars ]; then
                    files_content+="
=== FILE: $relpath ===
$content
"
                    current_chars=$((current_chars + file_chars))
                    echo -e "    ${GREEN}✓${NC} Found $relpath"
                fi
            fi
        done
    fi

    if [ -z "$files_content" ]; then
        echo -e "  ${YELLOW}No recognizable files found. Using basic template.${NC}"
        generate_prd_basic "$project_path" "$project_name"
        return
    fi

    # Clear screen and show generating message
    printf '\033[2J\033[3J\033[H'
    print_header
    echo ""
    echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$project_name${NC}"
    echo ""

    # Build prompt
    local prompt="Analyze this codebase and generate a detailed Product Requirements Document (PRD) in markdown.

PROJECT NAME: $project_name

PROJECT FILES:
$files_content

Generate a SHORT PRD (under 60 lines) with these sections:
1. Overview (2-3 sentences)
2. Target Users (3-5 bullet points)
3. Core Features (5-8 bullet points)
4. Tech Stack (list only)
5. Future Enhancements (3-5 bullet points)

Maximum brevity. No paragraphs. Bullet points only."

    # Call Claude with spinner
    local tmp_prd="/tmp/agentic-prd-$$.md"
    local tmp_prompt="/tmp/agentic-prompt-$$.txt"
    echo "$prompt" > "$tmp_prompt"
    claude -p --model haiku --output-format text < "$tmp_prompt" > "$tmp_prd" 2>/dev/null &
    local claude_pid=$!
    spin_while $claude_pid "Generating PRD with Claude..."
    wait $claude_pid
    local prd_content=$(cat "$tmp_prd" 2>/dev/null)
    local raw_len=${#prd_content}

    # Retry once if empty (transient failure)
    if [ $raw_len -lt 50 ]; then
        sleep 2
        claude -p --model haiku --output-format text < "$tmp_prompt" > "$tmp_prd" 2>/dev/null &
        claude_pid=$!
        spin_while $claude_pid "Retrying PRD generation..."
        wait $claude_pid
        prd_content=$(cat "$tmp_prd" 2>/dev/null)
        raw_len=${#prd_content}
    fi

    rm -f "$tmp_prompt" "$tmp_prd"

    if [ -n "$prd_content" ] && [ $raw_len -gt 100 ]; then
        # Strip Claude preamble (anything before first markdown heading # or ##)
        local cleaned="$prd_content"
        if echo "$cleaned" | grep -qE '^#{1,2} '; then
            cleaned=$(echo "$cleaned" | sed '1,/^#\{1,2\} /{ /^#\{1,2\} /!d; }')
        fi
        # Strip trailing commentary (permission requests, save prompts, etc.)
        cleaned=$(echo "$cleaned" | sed '/^The PRD is ready/d; /^Would you like/d; /^I.ve generated/d; /permission needed/d; /save.*to.*file/Id')
        # Strip trailing --- and anything after
        if echo "$cleaned" | grep -q '^---$'; then
            cleaned=$(echo "$cleaned" | sed -n '/^---$/q;p'; echo "---")
        fi
        # Use cleaned if it's still substantial, otherwise use raw
        if [ ${#cleaned} -gt 100 ]; then
            echo "$cleaned" > "$project_path/PRD.md"
        else
            echo "$prd_content" > "$project_path/PRD.md"
        fi
        echo -e "  ${GREEN}✓${NC} PRD generated from codebase!"
    else
        echo -e "  ${YELLOW}Claude unavailable. Creating basic template.${NC}"
        echo -e "  ${GRAY}(Raw output: ${raw_len} chars)${NC}"
        generate_prd_basic "$project_path" "$project_name"
    fi
}

# Interactive PRD Generator with structured questions and step navigation
generate_prd_interactive() {
    local project_path="$1"
    local project_name="$2"

    # Question options
    local -a PROJ_TYPES=("Web Application" "Mobile App" "API/Backend Service" "CLI Tool" "Desktop App" "Other")
    local -a USER_TYPES=("Developers" "General public" "Internal team" "Enterprise clients" "Small businesses/Startups" "Technical admins/DevOps" "Non-technical users" "API integrators" "Students/Education")
    local -a TECH_OPTIONS=("React/Next.js" "TypeScript" "Python" "Node.js" "PostgreSQL" "MongoDB" "Go" "Rust" "Let AI decide")
    local -a COMPLEXITY=("Simple - MVP, 1-2 features" "Medium - Multiple features" "Complex - Enterprise scale")

    # State
    local PRD_STEP=1
    local prd_project_type="" prd_users="" prd_features="" prd_tech="" prd_complexity="" prd_description=""
    local -a Q2_SEL=(0 0 0 0 0 0 0 0 0)
    local -a Q4_SEL=(0 0 0 0 0 0 0 0 0)
    local Q1_CUR=0 Q2_CUR=0 Q4_CUR=0 Q5_CUR=0
    local Q1_NUM=${#PROJ_TYPES[@]}
    local Q2_NUM=${#USER_TYPES[@]}
    local Q4_NUM=${#TECH_OPTIONS[@]}
    local Q5_NUM=${#COMPLEXITY[@]}

    while true; do
        case $PRD_STEP in
            1) # Project Type (single select)
                local _q1_draw
                draw_q1() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo -e "  ${ORANGE}PRD GENERATOR${NC}  ${GRAY}Step 1/6${NC}"
                    echo -e "  ${WHITE}What type of project is this?${NC}"
                    echo -e "  ${GRAY}↑↓ select   ⏎ confirm   b=back   q=home${NC}"
                    echo ""
                    for i in "${!PROJ_TYPES[@]}"; do
                        if [[ $i -eq $Q1_CUR ]]; then
                            echo -e "  ${REVERSE}${CYAN}${BOLD} ▸ ${PROJ_TYPES[$i]} ${NC}"
                        else
                            echo -e "    ${WHITE}${PROJ_TYPES[$i]}${NC}"
                        fi
                    done
                }
                tput civis; draw_q1
                while true; do
                    read -rsn1 key
                    if [[ "$key" = $'\x1b' ]]; then
                        read -rsn2 key
                        [[ "$key" = "[A" ]] && ((Q1_CUR=(Q1_CUR+Q1_NUM-1)%Q1_NUM))
                        [[ "$key" = "[B" ]] && ((Q1_CUR=(Q1_CUR+1)%Q1_NUM))
                        draw_q1
                        continue
                    fi
                    [[ "$key" = "" ]] && { prd_project_type="${PROJ_TYPES[$Q1_CUR]}"; ((PRD_STEP++)); break; }
                    [[ "$key" = "b" || "$key" = "B" ]] && { tput cnorm; return 2; }
                    [[ "$key" = "q" || "$key" = "Q" ]] && { tput cnorm; return 1; }
                done
                ;;

            2) # Target Users (multi-select with Done option)
                local Q2_TOTAL=$((Q2_NUM + 1))  # +1 for Done option
                draw_q2() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo -e "  ${ORANGE}PRD GENERATOR${NC}  ${GRAY}Step 2/6${NC}"
                    echo -e "  ${WHITE}Who are the target users?${NC}  ${GRAY}(select all that apply)${NC}"
                    echo -e "  ${GRAY}↑↓ move   ⏎ select   b=back   q=home${NC}"
                    echo ""
                    for i in "${!USER_TYPES[@]}"; do
                        local cb="○" clr="$WHITE"
                        [[ "${Q2_SEL[$i]}" -eq 1 ]] && { cb="●"; clr="$GREEN"; }
                        if [[ $i -eq $Q2_CUR ]]; then
                            echo -e "  ${REVERSE}${clr} $cb ${USER_TYPES[$i]} ${NC}"
                        else
                            echo -e "    ${clr}$cb ${USER_TYPES[$i]}${NC}"
                        fi
                    done
                    echo ""
                    if [[ $Q2_CUR -eq $Q2_NUM ]]; then
                        echo -e "  ${REVERSE}${GREEN}${BOLD} ✓ Done - Continue ${NC}"
                    else
                        echo -e "    ${GREEN}✓ Done - Continue${NC}"
                    fi
                }
                tput civis; draw_q2
                while true; do
                    read -rsn1 key
                    if [[ "$key" = $'\x1b' ]]; then
                        read -rsn2 key
                        [[ "$key" = "[A" ]] && ((Q2_CUR=(Q2_CUR+Q2_TOTAL-1)%Q2_TOTAL))
                        [[ "$key" = "[B" ]] && ((Q2_CUR=(Q2_CUR+1)%Q2_TOTAL))
                        draw_q2
                        continue
                    fi
                    # Enter or Space = select/toggle
                    if [[ -z "$key" || "$key" = $'\x20' ]]; then
                        if [[ $Q2_CUR -eq $Q2_NUM ]]; then
                            # On "Done" option - proceed
                            ((PRD_STEP++)); break
                        else
                            # Toggle selection
                            Q2_SEL[$Q2_CUR]=$((1-${Q2_SEL[$Q2_CUR]}))
                            draw_q2
                        fi
                        continue
                    fi
                    [[ "$key" = "b" || "$key" = "B" ]] && { ((PRD_STEP--)); break; }
                    [[ "$key" = "q" || "$key" = "Q" ]] && { tput cnorm; return 1; }
                done
                # Collect selections when moving forward
                if [[ $PRD_STEP -eq 3 ]]; then
                    prd_users=""
                    for i in "${!USER_TYPES[@]}"; do
                        [[ "${Q2_SEL[$i]}" -eq 1 ]] && prd_users="${prd_users:+$prd_users, }${USER_TYPES[$i]}"
                    done
                    [[ -z "$prd_users" ]] && prd_users="General users"
                fi
                ;;

            3) # Core Features (text input)
                printf '\033[2J\033[3J\033[H'
                print_header
                echo ""
                echo -e "  ${ORANGE}PRD GENERATOR${NC}  ${GRAY}Step 3/6${NC}"
                echo -e "  ${WHITE}List the main features${NC}  ${GRAY}(comma-separated)${NC}"
                echo -e "  ${GRAY}Type features   empty=back   q=home${NC}"
                echo ""
                echo -n "  > "
                tput cnorm
                prd_features=""
                read -e -r prd_features || true
                if [[ "$prd_features" =~ ^[qQ]$ ]]; then
                    tput cnorm; return 1
                elif [[ -z "$prd_features" ]]; then
                    ((PRD_STEP--))
                else
                    ((PRD_STEP++))
                fi
                ;;

            4) # Tech Preferences (multi-select with Done option)
                local Q4_TOTAL=$((Q4_NUM + 1))  # +1 for Done option
                draw_q4() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo -e "  ${ORANGE}PRD GENERATOR${NC}  ${GRAY}Step 4/6${NC}"
                    echo -e "  ${WHITE}Tech preferences?${NC}  ${GRAY}(optional)${NC}"
                    echo -e "  ${GRAY}↑↓ move   ⏎ select   b=back   q=home${NC}"
                    echo ""
                    for i in "${!TECH_OPTIONS[@]}"; do
                        local cb="○" clr="$WHITE"
                        [[ "${Q4_SEL[$i]}" -eq 1 ]] && { cb="●"; clr="$GREEN"; }
                        if [[ $i -eq $Q4_CUR ]]; then
                            echo -e "  ${REVERSE}${clr} $cb ${TECH_OPTIONS[$i]} ${NC}"
                        else
                            echo -e "    ${clr}$cb ${TECH_OPTIONS[$i]}${NC}"
                        fi
                    done
                    echo ""
                    if [[ $Q4_CUR -eq $Q4_NUM ]]; then
                        echo -e "  ${REVERSE}${GREEN}${BOLD} ✓ Done - Continue ${NC}"
                    else
                        echo -e "    ${GREEN}✓ Done - Continue${NC}"
                    fi
                }
                tput civis; draw_q4
                while true; do
                    read -rsn1 key
                    if [[ "$key" = $'\x1b' ]]; then
                        read -rsn2 key
                        [[ "$key" = "[A" ]] && ((Q4_CUR=(Q4_CUR+Q4_TOTAL-1)%Q4_TOTAL))
                        [[ "$key" = "[B" ]] && ((Q4_CUR=(Q4_CUR+1)%Q4_TOTAL))
                        draw_q4
                        continue
                    fi
                    # Enter or Space = select/toggle
                    if [[ -z "$key" || "$key" = $'\x20' ]]; then
                        if [[ $Q4_CUR -eq $Q4_NUM ]]; then
                            # On "Done" option - proceed
                            ((PRD_STEP++)); break
                        else
                            # Toggle selection with mutual exclusivity for "Let AI decide"
                            local AI_IDX=$((Q4_NUM - 1))  # Last tech option is "Let AI decide"
                            if [[ $Q4_CUR -eq $AI_IDX ]]; then
                                # Selecting "Let AI decide" - clear all others
                                if [[ ${Q4_SEL[$AI_IDX]} -eq 0 ]]; then
                                    for i in "${!TECH_OPTIONS[@]}"; do Q4_SEL[$i]=0; done
                                fi
                                Q4_SEL[$AI_IDX]=$((1-${Q4_SEL[$AI_IDX]}))
                            else
                                # Selecting a specific tech - clear "Let AI decide"
                                Q4_SEL[$AI_IDX]=0
                                Q4_SEL[$Q4_CUR]=$((1-${Q4_SEL[$Q4_CUR]}))
                            fi
                            draw_q4
                        fi
                        continue
                    fi
                    [[ "$key" = "b" || "$key" = "B" ]] && { ((PRD_STEP--)); break; }
                    [[ "$key" = "q" || "$key" = "Q" ]] && { tput cnorm; return 1; }
                done
                # Collect selections when moving forward
                if [[ $PRD_STEP -eq 5 ]]; then
                    prd_tech=""
                    for i in "${!TECH_OPTIONS[@]}"; do
                        [[ "${Q4_SEL[$i]}" -eq 1 && "${TECH_OPTIONS[$i]}" != "Let AI decide" ]] && prd_tech="${prd_tech:+$prd_tech, }${TECH_OPTIONS[$i]}"
                    done
                    [[ -z "$prd_tech" ]] && prd_tech="To be determined based on requirements"
                fi
                ;;

            5) # Complexity (single select)
                draw_q5() {
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo -e "  ${ORANGE}PRD GENERATOR${NC}  ${GRAY}Step 5/6${NC}"
                    echo -e "  ${WHITE}What's the scope/complexity?${NC}"
                    echo -e "  ${GRAY}↑↓ select   ⏎ confirm   b=back   q=home${NC}"
                    echo ""
                    for i in "${!COMPLEXITY[@]}"; do
                        if [[ $i -eq $Q5_CUR ]]; then
                            echo -e "  ${REVERSE}${CYAN}${BOLD} ▸ ${COMPLEXITY[$i]} ${NC}"
                        else
                            echo -e "    ${WHITE}${COMPLEXITY[$i]}${NC}"
                        fi
                    done
                }
                tput civis; draw_q5
                while true; do
                    read -rsn1 key
                    if [[ "$key" = $'\x1b' ]]; then
                        read -rsn2 key
                        [[ "$key" = "[A" ]] && ((Q5_CUR=(Q5_CUR+Q5_NUM-1)%Q5_NUM))
                        [[ "$key" = "[B" ]] && ((Q5_CUR=(Q5_CUR+1)%Q5_NUM))
                        draw_q5
                        continue
                    fi
                    [[ "$key" = "" ]] && { prd_complexity="${COMPLEXITY[$Q5_CUR]}"; ((PRD_STEP++)); break; }
                    [[ "$key" = "b" || "$key" = "B" ]] && { ((PRD_STEP--)); break; }
                    [[ "$key" = "q" || "$key" = "Q" ]] && { tput cnorm; return 1; }
                done
                ;;

            6) # One-liner description
                printf '\033[2J\033[3J\033[H'
                print_header
                echo ""
                echo -e "  ${ORANGE}PRD GENERATOR${NC}  ${GRAY}Step 6/6${NC}"
                echo -e "  ${WHITE}Describe the project in one sentence:${NC}"
                echo -e "  ${GRAY}Type description   empty=back   q=home${NC}"
                echo ""
                echo -n "  > "
                tput cnorm
                read -e -r prd_description || true
                if [[ "$prd_description" =~ ^[qQ]$ ]]; then
                    tput cnorm; return 1
                elif [[ -z "$prd_description" ]]; then
                    ((PRD_STEP--))
                else
                    prd_description="${prd_description:-A $prd_project_type project}"
                    ((PRD_STEP++))
                fi
                ;;

            7) # Generate PRD
                printf '\033[2J\033[3J\033[H'
                print_header
                echo ""
                echo -e "  ${CYAN}Generating PRD with Claude...${NC}"
                echo -e "  ${GRAY}This may take 1-3 minutes${NC}"
                echo ""

                local prompt="Generate a detailed Product Requirements Document (PRD) in markdown format for a project called '$project_name'.

Project Details:
- Type: $prd_project_type
- Target Users: $prd_users
- Core Features: $prd_features
- Tech Stack: $prd_tech
- Complexity: $prd_complexity
- Description: $prd_description

Create a well-structured PRD with these sections:
1. Overview - Expand on the description
2. Target Users - Detail the user personas
3. Core Features - Break down each feature with acceptance criteria
4. Technical Requirements - Based on tech preferences and project type
5. Success Criteria - Measurable goals
6. Out of Scope (v1) - What's not included initially

Output ONLY the markdown content, no code fences or explanations."

                if command -v claude &>/dev/null; then
                    # Run claude in background and show progress bar
                    local tmp_smartprompt="/tmp/agentic-smartprompt-$$.txt"
                    echo "$prompt" > "$tmp_smartprompt"
                    claude -p --model haiku --output-format text < "$tmp_smartprompt" > "$project_path/PRD.md" 2>/dev/null &
                    local pid=$!
                    local bar_width=50
                    local filled=0
                    local est_time=45  # estimated seconds (sonnet is fast)
                    local elapsed=0
                    local loading_msgs=("Analyzing requirements..." "Structuring document..." "Writing features..." "Adding technical specs..." "Defining success metrics..." "Almost done...")

                    tput civis  # Hide cursor during progress bar
                    echo ""
                    while kill -0 $pid 2>/dev/null; do
                        # Calculate progress (cap at 95% until actually done)
                        local pct=$((elapsed * 100 / est_time))
                        [[ $pct -gt 95 ]] && pct=95
                        filled=$((pct * bar_width / 100))

                        # Pick loading message based on progress
                        local msg_idx=$((pct / 17))
                        [[ $msg_idx -gt 5 ]] && msg_idx=5
                        local loading_msg="${loading_msgs[$msg_idx]}"

                        # Build progress bar
                        local bar=""
                        for ((b=0; b<filled; b++)); do bar+="█"; done
                        for ((b=filled; b<bar_width; b++)); do bar+="░"; done

                        printf "\r  ${CYAN}[${bar}]${NC} ${pct}%%  \n"
                        printf "\r  ${GRAY}${loading_msg}${NC}                    "
                        printf "\033[1A"  # Move cursor up one line
                        sleep 0.5
                        ((elapsed++))
                    done
                    wait $pid
                    local exit_code=$?
                    rm -f "$tmp_smartprompt"

                    # Complete the bar
                    local bar=""
                    for ((b=0; b<bar_width; b++)); do bar+="█"; done
                    printf "\r  ${GREEN}[${bar}]${NC} 100%%  \n"
                    printf "\r  ${GREEN}Complete!${NC}                         \n"

                    if [[ $exit_code -eq 0 && -s "$project_path/PRD.md" ]]; then
                        # Strip any text before the first markdown heading
                        if [[ "$(uname)" == "Darwin" ]]; then
                            sed -i '' '1,/^#/{/^#/!d;}' "$project_path/PRD.md" 2>/dev/null
                        else
                            sed -i '1,/^#/{/^#/!d;}' "$project_path/PRD.md" 2>/dev/null
                        fi
                        echo -e "  ${GREEN}✓${NC} PRD generated successfully"
                    else
                        echo -e "  ${YELLOW}⚠${NC} Claude generation failed, using template"
                        generate_prd_basic "$project_path" "$project_name"
                    fi
                else
                    echo -e "  ${YELLOW}⚠${NC} Claude CLI not found, using template"
                    generate_prd_basic "$project_path" "$project_name"
                fi

                sleep 1
                tput cnorm
                return 0
                ;;
        esac
    done
}

# Analyze PRD and suggest agents using Claude
analyze_prd() {
    local prd_file="$1"
    local project_name="$2"

    if [[ ! -f "$prd_file" ]]; then
        echo "frontend,backend,tests"
        return 1
    fi

    local prd_content
    # Truncate very long PRDs to first 8000 chars (keeps overview + main features)
    prd_content=$(head -c 8000 "$prd_file")

    local prompt="Analyze this PRD and suggest the optimal agent team structure for a multi-agent development environment.

PRD Content:
$prd_content

AGENT TYPES AND WHEN TO USE THEM:
- ui: UI/UX specialist. ALWAYS INCLUDE for any visual app. Count 2-3 for complex interfaces.
- frontend: Web frontend (React/Vue/etc). USE for web apps. Count 2 for complex dashboards.
- backend: Server logic, business rules. USE for any server-side app. Count 2 for complex logic.
- api: REST/GraphQL endpoints. USE when API layer exists.
- database: Schema, queries, migrations. USE for apps with data persistence.
- mobile: iOS/Android. USE for mobile apps. Count 2-3 for complex mobile.
- auth: Authentication, security. USE for user systems, multi-role apps.
- tests: Testing, QA. ALWAYS INCLUDE - every project needs tests.
- devops: CI/CD, deployment. USE for production apps.
- docs: Documentation. USE for platforms, SDKs.
- data: Data pipelines, analytics. USE for data-heavy apps.
- ml: Machine learning. USE if AI/ML features mentioned.
- engine: Core processing logic. USE for apps with complex algorithms.
- dsp: Audio/signal processing. USE for audio/music apps.
- synth: Sound synthesis. USE for music production apps.
- core: Core library code. USE for libraries, frameworks.
- parser: Input parsing. USE for compilers, interpreters, CLI tools.

Guidelines:
1. Aim for at least 5 agents for any real project - be generous
2. Include 'ui' if the project has any visual interface (web, mobile, desktop)
3. Include 'tests' for any production-quality project
4. Complex projects (DAWs, IDEs, games, platforms): 7-12 agents
5. Medium projects: 5-7 agents
6. Audio/music apps should have: ui, dsp, engine, synth, tests (minimum 5)
7. Web apps should have: ui, frontend, backend, api, tests (minimum 5)
8. Mobile apps should have: ui, mobile, backend, api, tests (minimum 5)
9. For complex areas, suggest count 2 (e.g., ui: 2 for rich interfaces)
10. More agents is better - don't be stingy

Output a JSON object with:
1. 'agents' - array of agent types from the list above
2. 'counts' - object mapping each agent type to count (1-3)
3. 'reasoning' - brief explanation of why these agents

Example for a complex mobile-first social platform:
{\"agents\":[\"mobile\",\"frontend\",\"backend\",\"api\",\"database\",\"auth\",\"tests\"],\"counts\":{\"mobile\":2,\"frontend\":1,\"backend\":2,\"api\":1,\"database\":1,\"auth\":1,\"tests\":1},\"reasoning\":\"Mobile-first app needs 2 mobile agents for iOS/Android. Complex business logic (social features, subscriptions) needs 2 backend agents. Web dashboard for admin. Auth for multi-role system.\"}

Output ONLY valid JSON, nothing else."

    if command -v claude &>/dev/null; then
        local result
        local tmp_result="/tmp/agentic-analyze-$$.txt"
        local tmp_anzprompt="/tmp/agentic-anzprompt-$$.txt"
        echo "$prompt" > "$tmp_anzprompt"
        claude -p --model haiku --output-format text < "$tmp_anzprompt" > "$tmp_result" 2>/dev/null &
        local analyze_pid=$!
        spin_while $analyze_pid "Analyzing PRD for agent suggestions..."
        wait $analyze_pid
        local exit_code=$?
        result=$(cat "$tmp_result" 2>/dev/null)
        rm -f "$tmp_result" "$tmp_anzprompt"

        if [[ $exit_code -eq 0 && -n "$result" ]]; then
            # Extract JSON - use python to reliably parse JSON from mixed content
            local agents_csv
            # Write Python script to temp file to avoid escaping issues
            cat > /tmp/agentic_parse.py << 'PYPARSEOF'
import sys, json

text = sys.stdin.read()
marker = chr(96) * 3  # triple backtick

# Find content between ```json and ```
lines = text.split('\n')
in_json = False
json_lines = []
for line in lines:
    if line.strip().startswith(marker + 'json'):
        in_json = True
        continue
    elif line.strip() == marker and in_json:
        break
    elif in_json:
        json_lines.append(line)

json_str = '\n'.join(json_lines) if json_lines else text

try:
    data = json.loads(json_str)
    agents = data.get('agents', [])
    if agents and isinstance(agents[0], dict):
        types = [a.get('type') for a in agents if a.get('type')]
        print(','.join(dict.fromkeys(types)))
    else:
        print(','.join(agents))
except:
    pass
PYPARSEOF
            agents_csv=$(echo "$result" | python3 /tmp/agentic_parse.py 2>/dev/null)

            if [[ -n "$agents_csv" && "$agents_csv" != "null" ]]; then
                # Extract counts if available
                local counts_json
                counts_json=$(echo "$json_block" | jq -c '.counts // {}' 2>/dev/null)
                PRD_ANALYSIS_RESULT="{\"agents\":\"$agents_csv\",\"counts\":$counts_json}"
                echo "$agents_csv"
                return 0
            fi
        fi
    else
        echo -e "  ${GRAY}[DEBUG] Claude command not found${NC}" >&2
    fi

    # Fallback: suggest based on common patterns
    echo "frontend,backend,api,tests"
    return 1
}

# Open project in Cursor using workspace file
open_in_cursor() {
    local project_path="$1"
    local project_name="$2"
    local project_slug="$3"

    # Find workspace file
    local workspace_file="$project_path/${project_slug}.code-workspace"

    # Check if Cursor is installed
    if [ ! -d "/Applications/Cursor.app" ]; then
        echo -e "  ${RED}✗${NC} Cursor not found. Install from https://cursor.sh"
        echo -e "  ${GRAY}Falling back to Terminal...${NC}"
        sleep 2
        SELECTED_EDITOR="terminal"
        return 1
    fi

    if [ ! -f "$workspace_file" ]; then
        echo -e "  ${YELLOW}⚠${NC} No workspace file found, opening folder directly"
        open -a "Cursor" "$project_path"
    else
        echo -e "  ${GREEN}✓${NC} Opening $project_name in Cursor..."
        open -a "Cursor" "$workspace_file"
    fi

    echo ""
    echo -e "${GREEN}Cursor launched!${NC} All specialists are in the workspace sidebar."
    echo -e "${GRAY}Switch between them using the Explorer panel.${NC}"
}

# Generate .code-workspace file for Cursor multi-root workspace
generate_code_workspace() {
    local project_path="$1"
    local project_name="$2"
    local project_slug="$3"
    shift 3
    local -a specialist_dirs=("$@")

    local workspace_file="$project_path/${project_slug}.code-workspace"

    # Build folders array
    local folders_json="["
    folders_json+="{\"path\": \".\", \"name\": \"QB ($project_name)\"},"

    for spec_dir in "${specialist_dirs[@]}"; do
        local spec_name=$(basename "$spec_dir" | sed "s/${project_slug}-//")
        local spec_name_cap="$(echo "$spec_name" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
        local rel_path="../$(basename "$spec_dir")"
        folders_json+="{\"path\": \"$rel_path\", \"name\": \"$spec_name_cap\"},"
    done

    # Remove trailing comma and close array
    folders_json="${folders_json%,}]"

    cat > "$workspace_file" << EOF
{
  "folders": $folders_json,
  "settings": {
    "files.exclude": {
      "**/.git": true,
      "**/.DS_Store": true
    }
  }
}
EOF

    echo "$workspace_file"
}

# PRD generation for upgrade flow - offers Auto-Generate or Wizard
generate_prd() {
    local project_path="$1"
    local project_name="$2"

    echo ""
    echo -e "  ${CYAN}Generate PRD for $project_name${NC}"
    echo ""
    echo -e "  ${WHITE}1${NC}) Auto-Generate - AI reads your code and writes PRD ${GREEN}(recommended)${NC}"
    echo -e "  ${WHITE}2${NC}) PRD Wizard - Answer 5 questions"
    echo ""
    echo -n "  Choice: "
    read -r prd_choice

    case "$prd_choice" in
        2)
            generate_prd_interactive "$project_path" "$project_name"
            ;;
        *)
            generate_prd_from_code "$project_path" "$project_name"
            ;;
    esac
}

# Add .cursorrules to a project
add_cursorrules_to_project() {
    local project_path="$1"
    local project_name="$2"
    local role="${3:-general}"
    local role_upper=$(echo "$role" | tr '[:lower:]' '[:upper:]')

    local role_desc=""
    case "$role" in
        qb) role_desc="You are the QB (Quarterback) - the coordinator agent. You oversee all specialists and ensure cohesive development. At the start of each session, read .claude/qb-dispatch.md for your specialist pane map and dispatch workflow. You coordinate by sending work to your existing specialist panes via tmux send-keys. Your specialists can use TeamCreate themselves for sub-agents." ;;
        frontend) role_desc="You are the FRONTEND specialist. Focus: React/Vue components, CSS/styling, client-side logic, UI/UX implementation." ;;
        backend) role_desc="You are the BACKEND specialist. Focus: Server logic, business rules, data processing, APIs." ;;
        api) role_desc="You are the API specialist. Focus: REST/GraphQL endpoints, request/response handling, API design." ;;
        database) role_desc="You are the DATABASE specialist. Focus: Schema design, migrations, queries, data modeling." ;;
        tests) role_desc="You are the TESTS specialist. Focus: Unit tests, integration tests, E2E tests, test coverage." ;;
        devops) role_desc="You are the DEVOPS specialist. Focus: CI/CD, deployment, infrastructure, monitoring." ;;
        ui) role_desc="You are the UI specialist. Focus: User interface components, design system, accessibility, visual polish." ;;
        mobile) role_desc="You are the MOBILE specialist. Focus: iOS/Android development, mobile UX, native features." ;;
        auth) role_desc="You are the AUTH specialist. Focus: Authentication, authorization, security, user sessions." ;;
        data) role_desc="You are the DATA specialist. Focus: Data pipelines, analytics, reporting, data models." ;;
        docs) role_desc="You are the DOCS specialist. Focus: Documentation, API docs, user guides, technical writing." ;;
        *) role_desc="You are a specialist for $project_name." ;;
    esac

    cat > "$project_path/.cursorrules" << EOF
# Cursor Rules for $project_name - $role_upper Agent
# Generated by AGENTIC

## Agent Role
$role_desc

## Project Context
Read PRD.md in the project root for full project requirements and context.

## Code Style
- Follow existing patterns in the codebase
- Write clear, maintainable code
- Add comments for complex logic

## Best Practices
- Test changes before committing
- Keep functions focused and small
- Use meaningful variable names
- Coordinate with other specialists through the QB
EOF
}

# Helper function to get role descriptions
get_role_description() {
    local role="$1"
    local project="$2"

    case "$role" in
        frontend)
            echo "You are the FRONTEND agent for $project. Your domain: React/Vue components, CSS/styling, client-side logic, UI/UX implementation. You do NOT touch backend code." ;;
        backend)
            echo "You are the BACKEND agent for $project. Your domain: Server logic, business rules, data processing. You do NOT touch frontend components." ;;
        api)
            echo "You are the API agent for $project. Your domain: REST/GraphQL endpoints, request/response handling, API design. Focus on clean, well-documented APIs." ;;
        database)
            echo "You are the DATABASE agent for $project. Your domain: Schema design, migrations, queries, data modeling. Ensure data integrity and performance." ;;
        tests)
            echo "You are the TESTS agent for $project. Your domain: Unit tests, integration tests, E2E tests. Ensure comprehensive test coverage." ;;
        devops)
            echo "You are the DEVOPS agent for $project. Your domain: CI/CD, deployment, infrastructure, monitoring. Keep the pipeline healthy." ;;
        docs)
            echo "You are the DOCS agent for $project. Your domain: Documentation, README files, API docs, tutorials. Make the project accessible." ;;
        auth)
            echo "You are the AUTH agent for $project. Your domain: Authentication, authorization, security, user management. Keep things secure." ;;
        ios)
            echo "You are the iOS agent for $project. Your domain: Swift/SwiftUI, iOS-specific features, App Store guidelines. Native iOS excellence." ;;
        android)
            echo "You are the ANDROID agent for $project. Your domain: Kotlin/Java, Android-specific features, Play Store guidelines. Native Android excellence." ;;
        dsp)
            echo "You are the DSP agent for $project. Your domain: Digital signal processing, audio algorithms, real-time processing. Make it sound good." ;;
        ui)
            echo "You are the UI agent for $project. Your domain: User interface, controls, visual design, user experience. Make it look and feel great." ;;
        engine)
            echo "You are the ENGINE agent for $project. Your domain: Core engine logic, main processing loop, performance optimization." ;;
        core)
            echo "You are the CORE agent for $project. Your domain: Core functionality, main business logic, central algorithms." ;;
        parser)
            echo "You are the PARSER agent for $project. Your domain: Input parsing, syntax analysis, data transformation." ;;
        utils)
            echo "You are the UTILS agent for $project. Your domain: Utility functions, helpers, common tools used across the project." ;;
        graphics)
            echo "You are the GRAPHICS agent for $project. Your domain: Rendering, shaders, visual effects, graphics optimization." ;;
        physics)
            echo "You are the PHYSICS agent for $project. Your domain: Physics simulation, collision detection, movement systems." ;;
        audio)
            echo "You are the AUDIO agent for $project. Your domain: Sound effects, music, audio playback, spatial audio." ;;
        model)
            echo "You are the MODEL agent for $project. Your domain: ML model architecture, neural networks, model design." ;;
        data)
            echo "You are the DATA agent for $project. Your domain: Data pipelines, preprocessing, dataset management, feature engineering." ;;
        training)
            echo "You are the TRAINING agent for $project. Your domain: Model training, hyperparameter tuning, experiment tracking." ;;
        inference)
            echo "You are the INFERENCE agent for $project. Your domain: Model deployment, prediction serving, optimization for production." ;;
        *)
            local role_upper=$(echo "$role" | tr '[:lower:]' '[:upper:]')
            echo "You are the $role_upper agent for $project. Focus on your specialized domain and collaborate with other agents." ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════════════════
# IMPORT HELPERS
# ═══════════════════════════════════════════════════════════════════════════════

# Search common directories for folders matching the search term
find_project() {
    local search="$1"

    # Common locations to search (deeper search)
    local SEARCH_DIRS=("$HOME/code" "$HOME/projects" "$HOME/Desktop" "$HOME/Documents" "$HOME")

    # Stop words to ignore
    local STOP_WORDS="a an the or and is it to for of my your this that with"

    # Split search into individual words and filter stop words
    local -a search_words=()
    for word in $search; do
        local word_lower=$(echo "$word" | tr '[:upper:]' '[:lower:]')
        # Skip if it's a stop word or too short (1-2 chars)
        if [[ ! " $STOP_WORDS " =~ " $word_lower " ]] && [ ${#word_lower} -gt 2 ]; then
            search_words+=("$word_lower")
        fi
    done

    # If no valid words after filtering, try the whole string
    if [ ${#search_words[@]} -eq 0 ]; then
        search_words+=("$(echo "$search" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')")
    fi

    # Create flexible search patterns
    # Strip hyphens/underscores and also create wildcard versions
    local -a all_patterns=()
    for word in "${search_words[@]}"; do
        # Original word
        all_patterns+=("$word")

        # Word with wildcards between each character group (handles any separator)
        # e.g., "vocaldih" -> "v*o*c*a*l*d*i*h" is too broad, so just insert one wildcard
        # at common positions (3, 4, 5 chars in)
        if [ ${#word} -gt 5 ]; then
            for pos in 3 4 5; do
                local part1="${word:0:$pos}"
                local part2="${word:$pos}"
                if [ ${#part2} -gt 2 ]; then
                    all_patterns+=("${part1}*${part2}")
                fi
            done
        fi
    done

    # Search for each pattern
    local -a results=()
    for base in "${SEARCH_DIRS[@]}"; do
        [ -d "$base" ] || continue
        for pattern in "${all_patterns[@]}"; do
            while IFS= read -r dir; do
                # Skip internal/config/build directories - these aren't projects
                local dirname=$(basename "$dir")
                # Skip hidden directories (start with .)
                [[ "$dirname" == .* ]] && continue
                # Skip common non-project directories
                [[ "$dirname" == "node_modules" ]] && continue
                [[ "$dirname" == "__pycache__" ]] && continue
                [[ "$dirname" == "vendor" ]] && continue
                [[ "$dirname" == "Pods" ]] && continue
                [[ "$dirname" == "build" ]] && continue
                [[ "$dirname" == "dist" ]] && continue
                [[ "$dirname" == "out" ]] && continue
                [[ "$dirname" == "target" ]] && continue
                [[ "$dirname" == "DerivedData" ]] && continue
                [[ "$dirname" == "agents" ]] && continue
                # Skip paths containing internal directories
                [[ "$dir" == *"/.claude/"* ]] && continue
                [[ "$dir" == *"/.git/"* ]] && continue
                [[ "$dir" == *"/node_modules/"* ]] && continue
                [[ "$dir" == *"/.venv/"* ]] && continue
                [[ "$dir" == *"/__pycache__/"* ]] && continue
                [[ "$dir" == *"/vendor/"* ]] && continue
                [[ "$dir" == *"/Pods/"* ]] && continue
                [[ "$dir" == *"/build/"* ]] && continue
                [[ "$dir" == *"/dist/"* ]] && continue
                [[ "$dir" == *"/out/"* ]] && continue
                [[ "$dir" == *"/target/"* ]] && continue
                [[ "$dir" == *"/.build/"* ]] && continue
                [[ "$dir" == *"/DerivedData/"* ]] && continue
                [[ "$dir" == *"/Saved Application State/"* ]] && continue
                [[ "$dir" == *"/Application Support/"* ]] && continue
                [[ "$dir" == *"/Caches/"* ]] && continue
                # Skip system/cache/config folders (not projects)
                [[ "$dir" == "$HOME/.cache/"* ]] && continue
                [[ "$dir" == "$HOME/.local/share/"* ]] && continue
                [[ "$dir" == "$HOME/.local/state/"* ]] && continue
                [[ "$dir" == "$HOME/Library/"* ]] && continue
                [[ "$dir" == *"/com.apple."* ]] && continue
                # Skip audio/video project folders (Pro Tools, Logic, etc.)
                [[ "$dir" == *"/Audio Files/"* ]] && continue
                [[ "$dir" == *"/Bounced Files/"* ]] && continue
                [[ "$dir" == *"/Session File Backups/"* ]] && continue
                [[ "$dir" == *"/Rendered Files/"* ]] && continue
                [[ "$dir" == *".ptx" ]] && continue
                [[ "$dir" == *".logicx"* ]] && continue
                [[ "$dir" == *".band"* ]] && continue
                # Skip if parent is a Pro Tools style "projects" folder (lowercase in audio apps)
                [[ "$dir" == */projects/* && ! "$dir" == *"/code/"* && ! "$dir" == *"/Documents/"* ]] && continue
                [[ "$dir" == *"/Application Scripts/"* ]] && continue
                # Skip Trash
                [[ "$dir" == *"/.Trash/"* ]] && continue
                [[ "$dir" == *"/.Trash" ]] && continue
                # Skip Deliverables/delivery folders
                [[ "$dir" == *"/Deliverables/"* ]] && continue
                [ -n "$dir" ] && results+=("$dir")
            done < <(find "$base" -maxdepth 3 -type d -iname "*${pattern}*" 2>/dev/null)
        done
    done

    # Dedupe and sort by relevance
    # Score: lower = better
    # Priority: direct children of ~/code > deeper folders > system folders
    printf '%s\n' "${results[@]}" | sort -u | while read -r dir; do
        local basename_lower=$(basename "$dir" | tr '[:upper:]' '[:lower:]')
        local score=100  # Start high, reduce for good matches

        # Calculate depth from base directories
        local depth=99
        for base in "$HOME/code" "$HOME/projects" "$HOME/Desktop"; do
            if [[ "$dir" == "$base/"* ]]; then
                local rel_path="${dir#$base/}"
                local d=$(echo "$rel_path" | tr -cd '/' | wc -c)
                [ $d -lt $depth ] && depth=$d
            fi
        done

        # HUGE bonus for direct children (depth 0 = ~/code/ProjectName)
        if [ $depth -eq 0 ]; then
            score=5  # Top priority
        elif [ $depth -eq 1 ]; then
            score=20  # Still good
        elif [ $depth -lt 99 ]; then
            score=$((30 + depth * 10))  # Penalize deeper folders
        fi

        # Bonus for being in good locations at all
        if [[ "$dir" == "$HOME/Library/"* ]] || [[ "$dir" == "$HOME/."* ]]; then
            score=80  # Penalize system/hidden folders
        fi

        # Bonus for exact name match (folder name = search term)
        for word in "${search_words[@]}"; do
            if [ "$basename_lower" = "$word" ]; then
                score=$((score - 3))
                break
            fi
        done

        echo "$score $dir"
    done | sort -t' ' -k1,1n | cut -d' ' -f2-
}

# Find sibling directories with same prefix (e.g., myapp-frontend, myapp-backend)
find_specialists() {
    local main_dir="$1"
    local project_name=$(basename "$main_dir")
    local project_name_lower=$(echo "$project_name" | tr '[:upper:]' '[:lower:]')
    local parent_dir=$(dirname "$main_dir")

    # Look for sibling directories with same prefix (case-insensitive)
    find "$parent_dir" -maxdepth 1 -type d -iname "${project_name_lower}-*" 2>/dev/null | sort
}

# Check if a git repo has worktrees set up
check_has_worktrees() {
    local main_dir="$1"
    if [ -d "$main_dir/.git" ]; then
        local worktree_count=$(cd "$main_dir" && git worktree list 2>/dev/null | wc -l)
        [ "$worktree_count" -gt 1 ] && return 0  # Has worktrees
    fi
    return 1  # No worktrees
}

# ═══════════════════════════════════════════════════════════════════════════════
# INTERACTIVE MENU WITH SECTIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Section-based menu: arrows move between section headers by default.
# Enter expands a section, then arrows move within items. Esc collapses back.

# --- Build per-section item arrays ---

# PROJECTS section items
# Build project list with MULTI or MEGA inserted after 2nd project for visibility
declare -a SEC_PROJ_ITEMS SEC_PROJ_TYPES SEC_PROJ_COLORS
MULTI_LAUNCH_IDX=-1
SPECIAL_INSERT_POS=2  # Insert special item after 2nd project
SPECIAL_INSERTED=false
if [ -n "$MULTI_PROJECT_SETTING" ]; then
    MULTI_LABEL=""
    IFS=',' read -ra _mp_nums <<< "$MULTI_PROJECT_SETTING"
    for _mp in "${_mp_nums[@]}"; do
        _mpname=$(jq -r ".projects[$((_mp-1))].name" "$CONFIG")
        [ -n "$MULTI_LABEL" ] && MULTI_LABEL="$MULTI_LABEL + $_mpname" || MULTI_LABEL="$_mpname"
    done
fi
for ((i=0; i<NUM_PROJECTS; i++)); do
    NAME=$(jq -r ".projects[$i].name" "$CONFIG")
    NUM_SPEC=$(jq ".projects[$i].specialists | length" "$CONFIG")
    TOTAL=$((NUM_SPEC + 1))
    if [ "$NAME" = "$LAST_PROJECT" ]; then
        SEC_PROJ_ITEMS+=("$NAME ($TOTAL agents) <- last used")
    else
        SEC_PROJ_ITEMS+=("$NAME ($TOTAL agents)")
    fi
    SEC_PROJ_TYPES+=("project:$((i+1))")
    SEC_PROJ_COLORS+=("$GREEN")
    # After 2nd project, insert MULTI (if configured) or MEGA (if not)
    if [ $((i+1)) -eq $SPECIAL_INSERT_POS ] && [ "$SPECIAL_INSERTED" = false ]; then
        if [ -n "$MULTI_PROJECT_SETTING" ]; then
            MULTI_LAUNCH_IDX=${#SEC_PROJ_ITEMS[@]}
            SEC_PROJ_ITEMS+=("MULTI: $MULTI_LABEL")
            SEC_PROJ_TYPES+=("multi_launch")
            SEC_PROJ_COLORS+=("$ORANGE")
        else
            SEC_PROJ_ITEMS+=("MEGA MODE - Load ALL projects")
            SEC_PROJ_TYPES+=("mega")
            SEC_PROJ_COLORS+=("$RED")
        fi
        SPECIAL_INSERTED=true
    fi
done
# If fewer than 2 projects, insert special at the end
if [ "$SPECIAL_INSERTED" = false ]; then
    if [ -n "$MULTI_PROJECT_SETTING" ]; then
        MULTI_LAUNCH_IDX=${#SEC_PROJ_ITEMS[@]}
        SEC_PROJ_ITEMS+=("MULTI: $MULTI_LABEL")
        SEC_PROJ_TYPES+=("multi_launch")
        SEC_PROJ_COLORS+=("$ORANGE")
    else
        SEC_PROJ_ITEMS+=("MEGA MODE - Load ALL projects")
        SEC_PROJ_TYPES+=("mega")
        SEC_PROJ_COLORS+=("$RED")
    fi
fi
# When MULTI is on, MEGA goes at the very bottom (hidden below scroll)
if [ -n "$MULTI_PROJECT_SETTING" ]; then
    SEC_PROJ_ITEMS+=("MEGA MODE - Load ALL projects")
    SEC_PROJ_TYPES+=("mega")
    SEC_PROJ_COLORS+=("$RED")
fi

# CREATE section items
declare -a SEC_CREATE_ITEMS SEC_CREATE_TYPES SEC_CREATE_COLORS
SEC_CREATE_ITEMS=("+ NEW PROJECT" "+ IMPORT EXISTING" "↑ UPGRADE PROJECTS")
SEC_CREATE_TYPES=("new" "import" "upgrade")
SEC_CREATE_COLORS=("$CYAN" "$CYAN" "$CYAN")

# LITE section items
declare -a SEC_LITE_ITEMS SEC_LITE_TYPES SEC_LITE_COLORS
for ((i=0; i<NUM_PROJECTS; i++)); do
    NAME=$(jq -r ".projects[$i].name" "$CONFIG")
    SEC_LITE_ITEMS+=("$NAME - QB only")
    SEC_LITE_TYPES+=("lite:$((i+1))")
    SEC_LITE_COLORS+=("$GREEN")
done

# Section names and counts
SECTION_NAMES=("PROJECTS" "CREATE" "LITE" "SETTINGS")
SECTION_COUNT=4
CURRENT_SECTION=0        # Which section header is highlighted
EXPANDED_SECTION=-1       # -1 = none expanded, 0-3 = which section
ITEM_SELECTION=0          # Index within expanded section
ITEM_SCROLL=0             # Scroll offset within expanded section

# Max visible items per section (preview when collapsed, scroll when expanded)
PROJ_PREVIEW=3
LITE_PREVIEW=3
CREATE_PREVIEW=2

draw_menu() {
    printf '\033[2J\033[3J\033[H'
    print_header
    # Dark green for preview items (visible but clearly unselected)
    local DK_GREEN='\033[38;5;28m'

    # Legend under subtitle
    if [ $EXPANDED_SECTION -ge 0 ]; then
        echo -e "  ${GRAY}↑↓ select  enter=launch  esc=back  d=delete  r=rename  q=quit${NC}"
    else
        echo -e "  ${GRAY}↑↓ navigate  enter=open  d=delete  r=rename  q=quit${NC}"
    fi

    # --- PROJECTS ---
    local is_expanded=$([ $EXPANDED_SECTION -eq 0 ] && echo true || echo false)
    if [ $CURRENT_SECTION -eq 0 ] && [ $EXPANDED_SECTION -lt 0 ]; then
        echo -e "  ${REVERSE}${PURPLE} ▶ ${NC} ${REVERSE}${CYAN}${BOLD} PROJECTS ${NC}"
    elif [ "$is_expanded" = true ]; then
        echo -e "  ${PURPLE}▼${NC} ${CYAN}${BOLD}PROJECTS${NC}"
    else
        echo -e "  ${PURPLE}▶${NC} ${CYAN}PROJECTS${NC}"
    fi

    # Show project items
    local proj_count=${#SEC_PROJ_ITEMS[@]}
    if [ "$is_expanded" = true ]; then
        # Expanded: show scrollable list (same count as preview to keep layout stable)
        local show_max=$PROJ_PREVIEW
        local show_start=$ITEM_SCROLL
        if [ $proj_count -le $show_max ]; then
            show_start=0
            show_max=$proj_count
        fi
        local shown=0
        for ((i=show_start; i<proj_count && shown<show_max; i++)); do
            if [ $i -eq $ITEM_SELECTION ]; then
                echo -e "     ${SEC_PROJ_COLORS[$i]}${BOLD} ▸ ${SEC_PROJ_ITEMS[$i]}${NC}"
            else
                echo -e "     ${SEC_PROJ_COLORS[$i]}  ${SEC_PROJ_ITEMS[$i]}${NC}"
            fi
            ((shown++))
        done
    else
        # Collapsed: show first 3 items (MULTI is already inserted at position 3 if configured)
        local preview=$PROJ_PREVIEW
        [ $proj_count -lt $preview ] && preview=$proj_count
        for ((i=0; i<preview; i++)); do
            echo -e "     ${DIM}${SEC_PROJ_COLORS[$i]}${SEC_PROJ_ITEMS[$i]}${NC}"
        done
    fi
    echo ""

    # --- CREATE ---
    is_expanded=$([ $EXPANDED_SECTION -eq 1 ] && echo true || echo false)
    if [ $CURRENT_SECTION -eq 1 ] && [ $EXPANDED_SECTION -lt 0 ]; then
        echo -e "  ${REVERSE}${PURPLE} ▶ ${NC} ${REVERSE}${CYAN}${BOLD} CREATE ${NC}"
    elif [ "$is_expanded" = true ]; then
        echo -e "  ${PURPLE}▼${NC} ${CYAN}${BOLD}CREATE${NC}"
    else
        echo -e "  ${PURPLE}▶${NC} ${CYAN}CREATE${NC}"
    fi

    local create_count=${#SEC_CREATE_ITEMS[@]}
    if [ "$is_expanded" = true ]; then
        for ((i=0; i<create_count; i++)); do
            if [ $i -eq $ITEM_SELECTION ]; then
                echo -e "     ${CYAN}${BOLD} ▸ ${SEC_CREATE_ITEMS[$i]}${NC}"
            else
                echo -e "     ${SEC_CREATE_COLORS[$i]}  ${SEC_CREATE_ITEMS[$i]}${NC}"
            fi
        done
    else
        local preview=$CREATE_PREVIEW
        [ $create_count -lt $preview ] && preview=$create_count
        for ((i=0; i<preview; i++)); do
            echo -e "     ${DIM}${SEC_CREATE_COLORS[$i]}${SEC_CREATE_ITEMS[$i]}${NC}"
        done
    fi
    echo ""

    # --- LITE ---
    is_expanded=$([ $EXPANDED_SECTION -eq 2 ] && echo true || echo false)
    if [ $CURRENT_SECTION -eq 2 ] && [ $EXPANDED_SECTION -lt 0 ]; then
        echo -e "  ${REVERSE}${PURPLE} ▶ ${NC} ${REVERSE}${CYAN}${BOLD} LITE ${NC} ${GRAY}(QB only)${NC}"
    elif [ "$is_expanded" = true ]; then
        echo -e "  ${PURPLE}▼${NC} ${CYAN}${BOLD}LITE${NC} ${GRAY}(QB only)${NC}"
    else
        echo -e "  ${PURPLE}▶${NC} ${CYAN}LITE${NC} ${GRAY}(QB only)${NC}"
    fi

    local lite_count=${#SEC_LITE_ITEMS[@]}
    if [ "$is_expanded" = true ]; then
        local show_max=$LITE_PREVIEW
        local show_start=$ITEM_SCROLL
        if [ $lite_count -le $show_max ]; then
            show_start=0
            show_max=$lite_count
        fi
        local shown=0
        for ((i=show_start; i<lite_count && shown<show_max; i++)); do
            if [ $i -eq $ITEM_SELECTION ]; then
                echo -e "     ${GREEN}${BOLD} ▸ ${SEC_LITE_ITEMS[$i]}${NC}"
            else
                echo -e "     ${SEC_LITE_COLORS[$i]}  ${SEC_LITE_ITEMS[$i]}${NC}"
            fi
            ((shown++))
        done
    else
        local preview=$LITE_PREVIEW
        [ $lite_count -lt $preview ] && preview=$lite_count
        for ((i=0; i<preview; i++)); do
            echo -e "     ${DIM}${SEC_LITE_COLORS[$i]}${SEC_LITE_ITEMS[$i]}${NC}"
        done
    fi

    # --- SETTINGS ---
    local SLOW_STATUS="OFF"
    [ "$(jq -r '.settings.slow_mode // false' "$CONFIG")" = "true" ] && SLOW_STATUS="ON"
    local DANGER_STATUS="OFF"
    [ "$(jq -r '.settings.dangerous_mode // false' "$CONFIG")" = "true" ] && DANGER_STATUS="ON"
    local RELAY_STATUS="OFF"
    [ "$(jq -r '.settings.auto_relay // false' "$CONFIG")" = "true" ] && RELAY_STATUS="ON"
    local SOLO_STATUS="OFF"
    [ "$(jq -r '.settings.solo_mode // false' "$CONFIG")" = "true" ] && SOLO_STATUS="ON"
    local MULTI_STATUS="OFF"
    local MULTI_VAL=$(jq -r '.settings.multi_projects // ""' "$CONFIG")
    [ -n "$MULTI_VAL" ] && MULTI_STATUS="$MULTI_VAL"

    if [ $CURRENT_SECTION -eq 3 ] && [ $EXPANDED_SECTION -lt 0 ]; then
        echo -e "  ${REVERSE}${PURPLE} ▶ ${NC} ${REVERSE}${YELLOW}${BOLD} SETTINGS ${NC}  ${GRAY}Slow:${NC}${YELLOW}${SLOW_STATUS}${NC} ${GRAY}Danger:${NC}${RED}${DANGER_STATUS}${NC} ${GRAY}Relay:${NC}${CYAN}${RELAY_STATUS}${NC} ${GRAY}Solo:${NC}${GREEN}${SOLO_STATUS}${NC} ${GRAY}Multi:${NC}${ORANGE}${MULTI_STATUS}${NC}"
    else
        echo -e "  ${PURPLE}▶${NC} ${CYAN}SETTINGS${NC}  ${GRAY}Slow:${NC}${YELLOW}${SLOW_STATUS}${NC} ${GRAY}Danger:${NC}${RED}${DANGER_STATUS}${NC} ${GRAY}Relay:${NC}${CYAN}${RELAY_STATUS}${NC} ${GRAY}Solo:${NC}${GREEN}${SOLO_STATUS}${NC} ${GRAY}Multi:${NC}${ORANGE}${MULTI_STATUS}${NC}"
    fi
}

# Get item count for a section
section_item_count() {
    case $1 in
        0) echo ${#SEC_PROJ_ITEMS[@]} ;;
        1) echo ${#SEC_CREATE_ITEMS[@]} ;;
        2) echo ${#SEC_LITE_ITEMS[@]} ;;
        3) echo 0 ;;  # Settings has no sub-items, opens directly
    esac
}

# Update scroll to keep item visible
update_item_scroll() {
    local count=$(section_item_count $EXPANDED_SECTION)
    local max_show=$PROJ_PREVIEW
    [ $EXPANDED_SECTION -eq 1 ] && max_show=$CREATE_PREVIEW
    [ $EXPANDED_SECTION -eq 2 ] && max_show=$LITE_PREVIEW
    if [ $count -le $max_show ]; then
        ITEM_SCROLL=0
        return
    fi
    if [ $ITEM_SELECTION -lt $ITEM_SCROLL ]; then
        ITEM_SCROLL=$ITEM_SELECTION
    elif [ $ITEM_SELECTION -ge $((ITEM_SCROLL + max_show)) ]; then
        ITEM_SCROLL=$((ITEM_SELECTION - max_show + 1))
    fi
}

import_existing_project() {
    trap 'echo ""; echo -e "  ${GRAY}Returning to menu...${NC}"; sleep 0.5; exec "$0"' INT

    local PROJECT_NAME="" MAIN_DIR=""
    local -a SPEC_DIRS=()
    local -a FOUND_RESULTS=()
    local -a FOUND_SPECIALISTS=()

    # Role descriptions helper function
    get_role_desc() {
        case "$1" in
            frontend) echo "React/Vue, CSS, UI" ;;
            backend) echo "Server, business logic" ;;
            api) echo "REST/GraphQL endpoints" ;;
            database) echo "Schema, queries" ;;
            tests) echo "Unit, integration, E2E" ;;
            devops) echo "CI/CD, deployment" ;;
            docs) echo "README, tutorials" ;;
            auth) echo "Security, login" ;;
            ui) echo "Design, experience" ;;
            dsp) echo "Audio/signal processing" ;;
            engine) echo "Core processing" ;;
            mobile) echo "iOS/Android" ;;
            data) echo "Pipelines, ETL" ;;
            ml) echo "Models, training" ;;
            review) echo "Code quality" ;;
            cloud) echo "Cloud services" ;;
            sync) echo "Synchronization" ;;
            core) echo "Core logic, main" ;;
            parser) echo "Input parsing, syntax" ;;
            utils) echo "Utilities, helpers" ;;
            *) echo "" ;;
        esac
    }

    # Project types for multi-agent setup
    local -a PROJECT_TYPES=(
        "web:Web App:frontend,backend,api,tests"
        "mobile:Mobile App:ios,android,api,tests"
        "fullstack:Full Stack:frontend,backend,api,database,tests"
        "api:API/Backend:api,database,auth,tests"
        "cli:CLI Tool:core,parser,utils,tests"
        "audio:Audio/DSP:dsp,ui,engine,tests"
        "game:Game:engine,graphics,audio,ui"
        "ml:ML/AI:model,data,api,tests"
        "custom:Custom:based on description"
    )

    # ─── STEP 1: Ask for project name ───
    while true; do
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${CYAN}${BOLD}IMPORT EXISTING PROJECT${NC}"
        echo ""
        echo -e "  ${WHITE}What's your project called?${NC}  ${GRAY}(q=quit)${NC}"
        echo ""
        echo -n "  > "
        read -r PROJECT_NAME
        [[ -z "$PROJECT_NAME" || "$PROJECT_NAME" =~ ^[qQ]$ ]] && return 1

        # ─── STEP 2: Auto-search and show results ───
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
        echo ""
        echo -e "  ${GRAY}Searching...${NC}"

        # Search for matching directories
        local -a RAW_RESULTS=()
        while IFS= read -r dir; do
            [ -n "$dir" ] && RAW_RESULTS+=("$dir")
        done < <(find_project "$PROJECT_NAME")

        local RAW_COUNT=${#RAW_RESULTS[@]}

        # Filter out already-imported projects AND their specialists/subfolders
        FOUND_RESULTS=()
        local -a FILTERED_BECAUSE=()  # Track what project each filtered result belongs to
        for dir in "${RAW_RESULTS[@]}"; do
            local dir_tilde="${dir/$HOME/~}"
            local dir_lower=$(echo "$dir" | tr '[:upper:]' '[:lower:]')
            local filtered_by=""

            # Check each existing project
            while IFS= read -r proj_json; do
                [ -z "$proj_json" ] && continue
                local proj_name=$(echo "$proj_json" | jq -r '.name')
                local proj_main=$(echo "$proj_json" | jq -r '.main_dir')
                local proj_main_expanded="${proj_main/#\~/$HOME}"
                local proj_main_lower=$(echo "$proj_main_expanded" | tr '[:upper:]' '[:lower:]')
                local proj_basename=$(basename "$proj_main_expanded")
                local proj_basename_lower=$(echo "$proj_basename" | tr '[:upper:]' '[:lower:]')

                # Check 1: Exact match on main_dir (case-insensitive)
                local dir_tilde_lower=$(echo "$dir_tilde" | tr '[:upper:]' '[:lower:]')
                local proj_main_lower_tilde=$(echo "$proj_main" | tr '[:upper:]' '[:lower:]')
                if [ "$dir_tilde_lower" = "$proj_main_lower_tilde" ]; then
                    filtered_by="$proj_name"
                    break
                fi

                # Check 2: Is this dir a subfolder of an existing project?
                if [[ "$dir_lower" == "$proj_main_lower/"* ]]; then
                    filtered_by="$proj_name"
                    break
                fi

                # Check 3: Is this dir a known specialist (sibling with same prefix AND in specialists array)?
                local dir_basename=$(basename "$dir")
                local dir_basename_lower=$(echo "$dir_basename" | tr '[:upper:]' '[:lower:]')
                if [[ "$dir_basename_lower" == "$proj_basename_lower-"* ]]; then
                    local dir_parent=$(dirname "$dir")
                    local proj_parent=$(dirname "$proj_main_expanded")
                    if [ "$dir_parent" = "$proj_parent" ]; then
                        # Only filter if it's actually a registered specialist, not just a similarly-named project
                        local dir_tilde_check="${dir/$HOME/~}"
                        local is_registered=$(echo "$proj_json" | jq -r ".specialists[]? | select(. == \"$dir_tilde_check\")" 2>/dev/null)
                        if [ -n "$is_registered" ]; then
                            filtered_by="$proj_name"
                            break
                        fi
                    fi
                fi

                # Check 4: Is this dir in the specialists array?
                local in_specialists=$(echo "$proj_json" | jq -r ".specialists[]? | select(. == \"$dir_tilde\")" 2>/dev/null)
                if [ -n "$in_specialists" ]; then
                    filtered_by="$proj_name"
                    break
                fi
            done < <(jq -c '.projects[]' "$CONFIG" 2>/dev/null)

            if [ -z "$filtered_by" ]; then
                FOUND_RESULTS+=("$dir")
            else
                FILTERED_BECAUSE+=("$filtered_by")
            fi
        done

        local FILTERED_COUNT=${#FOUND_RESULTS[@]}

        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
        echo ""

        # Scenario 1: Nothing found at all
        if [ $RAW_COUNT -eq 0 ]; then
            echo -e "  ${YELLOW}No folders found matching \"$PROJECT_NAME\"${NC}"
            echo ""
            echo -e "  ${GRAY}Options:${NC}"
            local NF_OPTS=("Search again with different name" "Type full path manually" "← BACK")
            local NF_CUR=0
            draw_nf() {
                printf '\033[14;1H\033[J'
                for i in "${!NF_OPTS[@]}"; do
                    local c="$WHITE"; [[ $i -eq 2 ]] && c="$ORANGE"
                    [[ $i -eq $NF_CUR ]] && echo -e "    ${REVERSE}${c} ▸ ${NF_OPTS[$i]} ${NC}" || echo -e "      ${c}${NF_OPTS[$i]}${NC}"
                done
            }
            tput civis; draw_nf
            while true; do
                read -rsn1 key
                [[ "$key" = $'\x1b' ]] && { read -rsn2 key; [[ "$key" = "[A" ]] && ((NF_CUR=(NF_CUR+2)%3)); [[ "$key" = "[B" ]] && ((NF_CUR=(NF_CUR+1)%3)); draw_nf; }
                [[ "$key" = "" ]] && break
                [[ "$key" =~ [qQ] ]] && { tput cnorm; return 1; }
            done
            tput cnorm
            case $NF_CUR in
                0) continue ;;  # Search again
                1) # Manual path entry
                    echo ""
                    echo -e "  ${WHITE}Enter full path:${NC}"
                    echo -n "  > "
                    read -r MAIN_DIR
                    MAIN_DIR="${MAIN_DIR/#\~/$HOME}"
                    if [ ! -d "$MAIN_DIR" ]; then
                        echo -e "  ${RED}Directory not found: $MAIN_DIR${NC}"
                        sleep 2
                        continue
                    fi
                    PROJECT_NAME=$(basename "$MAIN_DIR")
                    break
                    ;;
                2) return 1 ;;  # Back
            esac

        # Scenario 2: Found folders but ALL are already in AGENTIC (nothing left to import)
        elif [ ${#FOUND_RESULTS[@]} -eq 0 ] && [ ${#FILTERED_BECAUSE[@]} -gt 0 ]; then
            printf '\033[2J\033[3J\033[H'
            print_header
            echo ""
            echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
            echo ""
            # Get unique project names that matched
            local unique_projects=$(printf '%s\n' "${FILTERED_BECAUSE[@]}" | sort -u | head -3)
            echo -e "  ${RED}${BOLD}⚠ ALREADY IN AGENTIC!${NC}"
            echo ""
            echo -e "  ${WHITE}Matched project(s):${NC}"
            while IFS= read -r pname; do
                [ -n "$pname" ] && echo -e "    ${CYAN}• $pname${NC}"
            done <<< "$unique_projects"
            echo ""
            echo -e "  ${GRAY}To load this project, go back and select it from the menu.${NC}"
            echo ""
            echo -e "  ${ORANGE}N${NC}=search again  ${RED}Q${NC}=back to menu"
            while true; do
                read -rsn1 choice
                case "$choice" in
                    n|N) continue 2 ;;
                    q|Q|"") return 1 ;;
                esac
            done

        # Scenario 3: Found results available for import (none filtered)
        else
            local NUM_FOUND=$FILTERED_COUNT
            local NUM_FILTERED=0

            # Let user select with scrolling
            local SEL_CUR=0
            local VISIBLE_ROWS=6  # Keep it small so header stays visible in 24-row terminal
            local SCROLL_OFFSET=0

            # Determine which are "recommended" (ONLY direct children of ~/code, ~/projects, ~/Desktop)
            # A direct child has no additional slashes after the base path
            local -a IS_RECOMMENDED=()
            for dir in "${FOUND_RESULTS[@]}"; do
                local is_rec=0
                for base in "$HOME/code" "$HOME/projects" "$HOME/Desktop"; do
                    if [[ "$dir" == "$base/"* ]]; then
                        local rel_path="${dir#$base/}"
                        # Direct child = no slashes in relative path
                        if [[ "$rel_path" != *"/"* ]]; then
                            is_rec=1
                            break
                        fi
                    fi
                done
                IS_RECOMMENDED+=($is_rec)
            done

            draw_results() {
                printf '\033[2J\033[3J\033[H'
                print_header
                echo ""
                echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
                echo ""
                echo -e "  ${GREEN}Found ${NUM_FOUND} folder(s)${NC}"
                echo -e "  ${GRAY}↑↓=scroll  ${WHITE}ENTER${GRAY}=select  ${ORANGE}N${GRAY}=search again  ${RED}Q${GRAY}=back to menu${NC}"
                echo ""

                # Adjust scroll offset to keep selection visible
                if [ $SEL_CUR -lt $SCROLL_OFFSET ]; then
                    SCROLL_OFFSET=$SEL_CUR
                elif [ $SEL_CUR -ge $((SCROLL_OFFSET + VISIBLE_ROWS)) ]; then
                    SCROLL_OFFSET=$((SEL_CUR - VISIBLE_ROWS + 1))
                fi

                # Show scroll indicator at top if not at start
                if [ $SCROLL_OFFSET -gt 0 ]; then
                    echo -e "      ${GRAY}↑ $SCROLL_OFFSET more above${NC}"
                fi

                # Show visible window of results
                local end_idx=$((SCROLL_OFFSET + VISIBLE_ROWS))
                [ $end_idx -gt $NUM_FOUND ] && end_idx=$NUM_FOUND

                for ((i=SCROLL_OFFSET; i<end_idx; i++)); do
                    local dir="${FOUND_RESULTS[$i]}"
                    local short_dir="${dir/$HOME/~}"
                    local badge=""

                    # Add RECOMMENDED badge only for direct children of ~/code etc
                    if [ "${IS_RECOMMENDED[$i]:-0}" -eq 1 ]; then
                        badge=" ${CYAN}RECOMMENDED${NC}"
                    fi

                    # Truncate long paths to fit terminal (leave room for badge)
                    local max_len=45
                    if [ ${#short_dir} -gt $max_len ]; then
                        short_dir="...${short_dir: -$((max_len-3))}"
                    fi

                    if [ $i -eq $SEL_CUR ]; then
                        echo -e "    ${REVERSE}${GREEN} ▸ $short_dir ${NC}$badge"
                    else
                        echo -e "      ${WHITE}$short_dir${NC}$badge"
                    fi
                done

                # Show scroll indicator at bottom if more below
                local remaining=$((NUM_FOUND - end_idx))
                if [ $remaining -gt 0 ]; then
                    echo -e "      ${GRAY}↓ $remaining more below${NC}"
                fi
            }

            tput civis; draw_results
            local sel_done=0
            while [ $sel_done -eq 0 ]; do
                read -rsn1 key
                if [[ "$key" = $'\x1b' ]]; then
                    read -rsn2 key
                    if [[ "$key" = "[A" ]]; then
                        # Up arrow
                        ((SEL_CUR--))
                        [ $SEL_CUR -lt 0 ] && SEL_CUR=$((NUM_FOUND - 1))
                        draw_results
                    elif [[ "$key" = "[B" ]]; then
                        # Down arrow
                        ((SEL_CUR++))
                        [ $SEL_CUR -ge $NUM_FOUND ] && SEL_CUR=0
                        draw_results
                    fi
                elif [[ "$key" = "" ]]; then
                    sel_done=1
                elif [[ "$key" =~ [nN] ]]; then
                    tput cnorm
                    continue 2  # Search again
                elif [[ "$key" =~ [qQ] ]]; then
                    tput cnorm
                    return 1
                fi
            done
            tput cnorm
            MAIN_DIR="${FOUND_RESULTS[$SEL_CUR]}"
        fi

        # Set PROJECT_NAME from selected directory
        PROJECT_NAME=$(basename "$MAIN_DIR")

        # Find related specialist directories
        FOUND_SPECIALISTS=()
        while IFS= read -r spec; do
            [ -n "$spec" ] && [ "$spec" != "$MAIN_DIR" ] && FOUND_SPECIALISTS+=("$spec")
        done < <(find_specialists "$MAIN_DIR")

        # Also check search results for related dirs
        local main_basename=$(basename "$MAIN_DIR")
        for dir in "${FOUND_RESULTS[@]}"; do
            [ "$dir" = "$MAIN_DIR" ] && continue
            local dir_basename=$(basename "$dir")
            if [[ "$dir_basename" == "${main_basename}-"* ]]; then
                local already_found=0
                for s in "${FOUND_SPECIALISTS[@]}"; do
                    [ "$s" = "$dir" ] && already_found=1 && break
                done
                [ $already_found -eq 0 ] && FOUND_SPECIALISTS+=("$dir")
            fi
        done

        # Check for duplicate BEFORE showing options (comprehensive check)
        local dir_check="${MAIN_DIR/$HOME/~}"
        local dir_lower=$(echo "$MAIN_DIR" | tr '[:upper:]' '[:lower:]')
        local dir_basename_lower=$(basename "$MAIN_DIR" | tr '[:upper:]' '[:lower:]')
        local is_duplicate=""

        # Check each existing project for conflicts
        while IFS= read -r proj_json; do
            [ -z "$proj_json" ] && continue
            local proj_name=$(echo "$proj_json" | jq -r '.name')
            local proj_main=$(echo "$proj_json" | jq -r '.main_dir')
            local proj_main_expanded="${proj_main/#\~/$HOME}"
            local proj_main_lower=$(echo "$proj_main_expanded" | tr '[:upper:]' '[:lower:]')
            local proj_basename_lower=$(basename "$proj_main_expanded" | tr '[:upper:]' '[:lower:]')

            # Check 1: Exact match on main_dir or name
            if [ "$dir_check" = "$proj_main" ]; then
                is_duplicate="$proj_name"
                break
            fi

            # Check 2: Is this dir a subfolder of an existing project?
            if [[ "$dir_lower" == "$proj_main_lower/"* ]]; then
                is_duplicate="$proj_name (subfolder)"
                break
            fi

            # Check 3: Is this dir a specialist (sibling with same prefix)?
            if [[ "$dir_basename_lower" == "$proj_basename_lower-"* ]]; then
                local dir_parent=$(dirname "$MAIN_DIR")
                local proj_parent=$(dirname "$proj_main_expanded")
                if [ "$dir_parent" = "$proj_parent" ]; then
                    is_duplicate="$proj_name (specialist)"
                    break
                fi
            fi

            # Check 4: Is this dir in the specialists array?
            local in_specialists=$(echo "$proj_json" | jq -r ".specialists[]? | select(. == \"$dir_check\")" 2>/dev/null)
            if [ -n "$in_specialists" ]; then
                is_duplicate="$proj_name (specialist)"
                break
            fi
        done < <(jq -c '.projects[]' "$CONFIG" 2>/dev/null)

        # Show final selection and specialists
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
        echo ""

        if [ -n "$is_duplicate" ]; then
            # DUPLICATE - show warning
            echo -e "  ${RED}✗ Selected:${NC} ${CYAN}$MAIN_DIR${NC}"
            echo ""
            echo -e "  ${RED}${BOLD}⚠ Already in AGENTIC as '$is_duplicate'${NC}"
            echo ""
            echo -e "  ${ORANGE}n${NC}=search again  ${RED}q${NC}=back to menu"

            read -rsn1 choice
            case "$choice" in
                n|N) continue ;;  # Search again
                *) return 1 ;;    # Back to menu
            esac
        else
            echo -e "  ${GREEN}✓ Selected:${NC} ${CYAN}$MAIN_DIR${NC}"

            if [ ${#FOUND_SPECIALISTS[@]} -gt 0 ]; then
                echo ""
                echo -e "  ${WHITE}Also found related directories:${NC}"
                for spec in "${FOUND_SPECIALISTS[@]}"; do
                    echo -e "    ${GREEN}✓${NC} $spec"
                done
            fi

            echo ""
            if [ ${#FOUND_SPECIALISTS[@]} -gt 0 ]; then
                echo -e "  ${GREEN}enter${NC}=import all  ${CYAN}s${NC}=skip specialists  ${ORANGE}n${NC}=search again  ${RED}q${NC}=quit"
            else
                echo -e "  ${GREEN}enter${NC}=import  ${ORANGE}n${NC}=search again  ${RED}q${NC}=quit"
            fi

            read -rsn1 choice
            case "$choice" in
                "") break ;;  # Proceed with import
                n|N) continue ;;  # Search again
                s|S) FOUND_SPECIALISTS=(); break ;;  # Skip specialists
                q|Q) return 1 ;;
                *) continue ;;
            esac
        fi
    done

    # Already checked for duplicates above, this is just a safety check
    local dir_check="${MAIN_DIR/$HOME/~}"
    local basename_check=$(basename "$MAIN_DIR" | tr '[:upper:]' '[:lower:]')
    local existing=$(jq -r ".projects[] | select(.main_dir == \"$dir_check\" or (.name | ascii_downcase) == \"$basename_check\") | .name" "$CONFIG" | head -1)
    if [ -n "$existing" ]; then
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${YELLOW}Project '$existing' already exists in AGENTIC!${NC}"
        echo ""
        echo -e "  ${GRAY}Press any key to return to menu...${NC}"
        read -rsn1
        return 1
    fi

    # Use found specialists as SPEC_DIRS
    SPEC_DIRS=("${FOUND_SPECIALISTS[@]}")

    # ─── PRD GENERATION (before agent setup for smart suggestions) ───
    local PRD_GENERATED=false
    local PRD_REGENERATED=false
    local SMART_AGENTS=""

    if [ -f "$MAIN_DIR/PRD.md" ]; then
        # PRD already exists - skip generation by default
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
        echo ""
        echo -e "  ${GREEN}✓${NC} PRD already exists"
        echo ""
        echo -e "  ${WHITE}1${NC}) Keep existing PRD ${GREEN}(recommended)${NC}"
        echo -e "  ${WHITE}2${NC}) Regenerate PRD from code"
        echo ""
        echo -n "  Choice: "
        read -r prd_choice
        case "$prd_choice" in
            2)
                generate_prd_from_code "$MAIN_DIR" "$PROJECT_NAME"
                PRD_GENERATED=true
                PRD_REGENERATED=true
                ;;
            *)
                PRD_GENERATED=true
                echo -e "  ${GREEN}✓${NC} Using existing PRD"
                ;;
        esac
    else
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
        echo ""
        echo -e "  ${WHITE}Generate PRD?${NC} ${GRAY}(enables smart agent suggestions)${NC}"
        echo ""
        echo -e "  ${WHITE}1${NC}) Auto-Generate - AI reads your code and writes PRD ${GREEN}(recommended)${NC}"
        echo -e "  ${WHITE}2${NC}) PRD Wizard - Answer 5 questions"
        echo -e "  ${WHITE}3${NC}) Skip"
        echo ""
        echo -n "  Choice: "
        read -r prd_choice

        case "$prd_choice" in
            2)
                generate_prd_interactive "$MAIN_DIR" "$PROJECT_NAME"
                PRD_GENERATED=true
                ;;
            3)
                echo -e "  ${GRAY}Skipped PRD generation${NC}"
                ;;
            *)
                generate_prd_from_code "$MAIN_DIR" "$PROJECT_NAME"
                PRD_GENERATED=true
                ;;
        esac
    fi

    # If PRD was generated and no existing specialists, analyze for smart agent suggestions
    # (With existing specialists, the count screen shows all roles so suggestions aren't needed)
    if [ "$PRD_GENERATED" = true ] && [ -f "$MAIN_DIR/PRD.md" ] && [ ${#SPEC_DIRS[@]} -eq 0 ]; then
        echo ""
        local prd_content=$(cat "$MAIN_DIR/PRD.md")

        # Build list of existing specialist roles
        local existing_roles=""
        if [ ${#SPEC_DIRS[@]} -gt 0 ]; then
            for sd in "${SPEC_DIRS[@]}"; do
                local role_name=$(get_role_from_dir "$sd" "$MAIN_DIR")
                role_name=$(echo "$role_name" | tr '[:upper:]' '[:lower:]')
                [ -n "$existing_roles" ] && existing_roles="$existing_roles,$role_name" || existing_roles="$role_name"
            done
        fi

        local existing_context=""
        if [ -n "$existing_roles" ]; then
            existing_context="
EXISTING AGENTS ALREADY SET UP: $existing_roles
DO NOT re-suggest agents that already exist unless the project needs a SECOND one of that type (e.g., suggest 'ui' only if the project needs 2 UI agents and only 1 exists).
Only suggest NEW agents that are missing, or duplicates of existing ones if the workload justifies it."
        fi

        local analysis_prompt="Analyze this PRD and recommend specialist development agents.

PRD:
$prd_content

AVAILABLE AGENTS:
- ui: User interface, design system, visual components, styling
- frontend: Web frontend (React/Vue/etc), client-side logic
- backend: Server logic, business rules, services
- api: REST/GraphQL endpoints, API design
- database: Schema, queries, migrations, data modeling
- engine: Core processing logic, main algorithms
- dsp: Audio/signal processing, real-time audio
- mobile: iOS/Android development
- auth: Authentication, authorization, security
- tests: Unit, integration, E2E testing, QA
- devops: CI/CD, deployment, infrastructure
- docs: Documentation, API docs
- data: Data pipelines, analytics
- ml: Machine learning, AI features
- core: Core library code, shared utilities
- parser: Input parsing, syntax analysis
- synth: Sound synthesis, instrument design
$existing_context

RULES (FOLLOW STRICTLY):
1. For projects with NO existing agents: suggest 5-10 agents total
2. For projects WITH existing agents: only suggest what's MISSING or needs reinforcement
3. ALWAYS include 'ui' if project has a visual interface and no ui agent exists yet
4. ALWAYS include 'tests' if no tests agent exists yet
5. If project has multiple complex areas, suggest a second agent of that type (e.g., ui for complex UI)
6. Audio/music projects need: dsp, engine, ui, synth, tests
7. Web apps need: ui, frontend, backend, api, tests
8. DO NOT repeat existing agents unless a second one is genuinely needed
9. If existing agents already cover the project well, suggest 1-3 additions only
10. Return an EMPTY list if existing agents are sufficient (just return: none)

Return ONLY a comma-separated list of NEW agents to add. Example: synth,backend,api
Or return: none

Your agent list:"

        local tmp_agents="/tmp/agentic-agents-$$.txt"
        local tmp_aprompt="/tmp/agentic-aprompt-$$.txt"
        echo "$analysis_prompt" > "$tmp_aprompt"
        claude -p --model haiku --output-format text < "$tmp_aprompt" > "$tmp_agents" 2>/dev/null &
        local analyze_pid=$!
        spin_while $analyze_pid "Analyzing PRD for agent suggestions..."
        wait $analyze_pid
        # Extract comma-separated agent list, ignoring any preamble text from Claude
        local raw_agents=$(cat "$tmp_agents" 2>/dev/null)
        rm -f "$tmp_agents" "$tmp_aprompt"
        # Valid agent types
        local VALID_AGENTS="ui frontend backend api database engine dsp mobile auth tests devops docs data ml core parser synth utils"

        # Check if Claude said "none" (existing agents are sufficient)
        if echo "$raw_agents" | tr '[:upper:]' '[:lower:]' | grep -qiE '^\s*none\s*$|no additional|sufficient|well.covered'; then
            SMART_AGENTS=""
            echo -e "  ${GREEN}✓${NC} Existing agents cover this project well"
        else
            # First extract the comma-separated list from Claude's response
            local csv_line=$(echo "$raw_agents" | tr '[:upper:]' '[:lower:]' | grep -oE '\b[a-z]+(\s*,\s*[a-z]+){1,}' | tail -1 | tr -d ' ')
            # Now validate each item and filter out existing agents
            local found_agents=""
            IFS=',' read -ra suggested <<< "$csv_line"
            for agent in "${suggested[@]}"; do
                # Skip if not a valid agent type
                echo " $VALID_AGENTS " | grep -q " $agent " || continue
                # Skip if already in existing roles (allow through if user has 0 of this type)
                if [ -n "$existing_roles" ] && echo ",$existing_roles," | grep -qi ",$agent,"; then
                    continue
                fi
                [ -n "$found_agents" ] && found_agents="$found_agents,$agent" || found_agents="$agent"
            done
            SMART_AGENTS="$found_agents"
            if [ -n "$SMART_AGENTS" ]; then
                echo -e "  ${GREEN}✓${NC} Smart suggestions: ${CYAN}$SMART_AGENTS${NC}"
            fi
        fi
    fi

    # Add Cursor support now that we have PRD
    add_cursorrules_to_project "$MAIN_DIR" "$PROJECT_NAME" "qb"
    create_code_workspace "$MAIN_DIR" "$PROJECT_NAME" "$(basename "$MAIN_DIR")" "${SPEC_DIRS[*]}" > /dev/null 2>&1

    # ─── POST-IMPORT: Multi-agent setup ───
    local SETUP_MULTIAGENT=false
    local USER_QUIT_WIZARD=false
    local HAS_SPECIALISTS=${#SPEC_DIRS[@]}

    if [ $HAS_SPECIALISTS -gt 0 ]; then
        # Scenario A: Found specialists
        # If PRD was regenerated, go through the count screen flow
        # If kept existing, skip to final screen (user can press 'b' to add agents)
        if [ "$PRD_REGENERATED" = true ]; then
            SETUP_MULTIAGENT=true
        fi
    else
        # Scenario B: No specialists - offer to set up multi-agent
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
        echo ""
        echo -e "  ${WHITE}Found main project:${NC}"
        echo -e "    ${GREEN}✓${NC} $MAIN_DIR"
        echo ""

        # If we have smart suggestions, show them
        if [ -n "$SMART_AGENTS" ]; then
            echo -e "  ${WHITE}AI suggests these agents:${NC} ${CYAN}$SMART_AGENTS${NC}"
            echo ""
            echo -e "  ${WHITE}Create these agents?${NC}  ${GRAY}(y/n)${NC}"
        else
            echo -e "  ${GRAY}No specialist agents found.${NC}"
            echo ""
            echo -e "  ${WHITE}Would you like to set up multi-agent workflow?${NC}  ${GRAY}(y/n)${NC}"
        fi
        read -rsn1 setup_multi

        if [[ "$setup_multi" =~ [yY] ]]; then
            SETUP_MULTIAGENT=true
        fi
    fi

    # ─── MULTI-AGENT SETUP (reuse wizard components) ───
    if [ "$SETUP_MULTIAGENT" = true ]; then
        # Project type selection
        local NUM_T=${#PROJECT_TYPES[@]}
        local T_CUR=0 BACK_IDX=$NUM_T CUSTOM_IDX=$((NUM_T-1))
        local CUSTOM_INPUT="" SPECIALISTS_CSV=""
        local USE_WORKTREES="y"

        # Skip type selection if we have smart suggestions OR existing specialists
        if [ ${#SPEC_DIRS[@]} -gt 0 ]; then
            # Has existing agents - skip straight to count screen
            local SETUP_STAGE="import_counts"
        elif [ -n "$SMART_AGENTS" ]; then
            SPECIALISTS_CSV="$SMART_AGENTS"
            local SETUP_STAGE="roles"
        else
            local SETUP_STAGE="type"  # "type" or "roles"
        fi

        draw_type_select() {
            printf '\033[2J\033[3J\033[H'
            print_header
            echo ""
            echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
            echo ""
            echo -e "  ${WHITE}Project type?${NC}  ${GRAY}↑↓ enter=select q=quit${NC}"
            echo ""
            for i in "${!PROJECT_TYPES[@]}"; do
                IFS=':' read -r tid tname tagents <<< "${PROJECT_TYPES[$i]}"
                if [[ $i -eq $T_CUR ]]; then
                    if [[ $i -eq $CUSTOM_IDX ]]; then
                        echo -e "    ${REVERSE}${GREEN}${BOLD} ▸ $tname ${NC} ${GRAY}describe:${NC} ${GREEN}${CUSTOM_INPUT}${NC}"
                    else
                        echo -e "    ${REVERSE}${GREEN}${BOLD} ▸ $tname ${NC}  ${GREEN}$tagents${NC}"
                    fi
                else
                    if [[ $i -eq $CUSTOM_IDX ]]; then
                        echo -e "      ${WHITE}$tname${NC}  ${GRAY}describe your project${NC}"
                    else
                        echo -e "      ${WHITE}$tname${NC}  ${GRAY}$tagents${NC}"
                    fi
                fi
            done
            echo ""
            if [[ $T_CUR -eq $BACK_IDX ]]; then
                echo -e "    ${REVERSE}${ORANGE}${BOLD} ← SKIP ${NC}"
            else
                echo -e "      ${ORANGE}← SKIP${NC}"
            fi
        }

        # Main setup loop - allows going back between type and role selection
        while [ "$SETUP_STAGE" != "done" ]; do
            if [ "$SETUP_STAGE" = "type" ]; then
                tput civis; draw_type_select
                local type_done=0
                while [ $type_done -eq 0 ]; do
                    read -rsn1 key
                    if [[ "$key" = $'\x1b' ]]; then
                        read -rsn2 key
                        [[ "$key" = "[A" ]] && ((T_CUR=(T_CUR+BACK_IDX)%(BACK_IDX+1)))
                        [[ "$key" = "[B" ]] && ((T_CUR=(T_CUR+1)%(BACK_IDX+1)))
                        draw_type_select
                    elif [[ "$key" = "" ]]; then
                        if [[ $T_CUR -eq $BACK_IDX ]]; then
                            # SKIP selected - just skip wizard, don't abort import
                            SETUP_STAGE="done"
                            type_done=1
                        elif [[ $T_CUR -eq $CUSTOM_IDX ]]; then
                            printf '\033[2J\033[3J\033[H'
                            print_header
                            echo ""
                            echo -e "  ${CYAN}${BOLD}IMPORT: ${WHITE}$PROJECT_NAME${NC}"
                            echo ""
                            echo -e "  ${WHITE}Describe what you're building:${NC}"
                            echo -n "  > "
                            tput cnorm
                            read -r CUSTOM_INPUT
                            tput civis
                            if [[ -z "${CUSTOM_INPUT// /}" ]]; then
                                CUSTOM_INPUT=""
                                draw_type_select
                                continue
                            fi
                            SETUP_STAGE="roles"
                            type_done=1
                        else
                            SETUP_STAGE="roles"
                            type_done=1
                        fi
                    elif [[ "$key" =~ [qQ] ]]; then
                        tput cnorm
                        USER_QUIT_WIZARD=true
                        SETUP_STAGE="done"
                        type_done=1
                    fi
                done
                tput cnorm
            fi

        if [ "$SETUP_STAGE" = "import_counts" ]; then
            # Import flow: skip role checklist, go straight to count screen
            # Build list: existing agents at their count, all other roles at 0
            local ALL_ROLES=(frontend backend api database tests devops docs auth ui dsp engine mobile data ml review cloud sync core parser utils)
            local -a count_args=()
            local -a existing_roles_seen=()

            # Add existing agents with their counts
            for sd in "${SPEC_DIRS[@]}"; do
                local role=$(get_role_from_dir "$sd" "$MAIN_DIR")
                role="${role%%-[0-9]*}"
                local already=0
                for seen in "${existing_roles_seen[@]}"; do
                    [[ "$seen" = "$role" ]] && { already=1; break; }
                done
                [[ $already -eq 1 ]] && continue
                existing_roles_seen+=("$role")
                local role_count=0
                for sd2 in "${SPEC_DIRS[@]}"; do
                    local r2=$(get_role_from_dir "$sd2" "$MAIN_DIR")
                    r2="${r2%%-[0-9]*}"
                    [[ "$r2" = "$role" ]] && ((role_count++))
                done
                count_args+=("${role}:${role_count}")
            done

            # Add remaining roles at 0
            for r in "${ALL_ROLES[@]}"; do
                local is_existing=0
                for seen in "${existing_roles_seen[@]}"; do
                    [[ "$seen" = "$r" ]] && { is_existing=1; break; }
                done
                [[ $is_existing -eq 0 ]] && count_args+=("${r}:0")
            done

            local counts_result
            counts_result=$(show_agent_count_screen 11 "${count_args[@]}")

            if [[ "$counts_result" = "BACK" ]]; then
                SETUP_STAGE="done"
            elif [[ -n "$counts_result" ]]; then
                # Compute delta
                local -a NEW_AGENTS=()
                IFS=',' read -ra count_pairs <<< "$counts_result"
                for pair in "${count_pairs[@]}"; do
                    IFS=':' read -r agent count <<< "$pair"
                    local existing=0
                    for sd in "${SPEC_DIRS[@]}"; do
                        local r=$(get_role_from_dir "$sd" "$MAIN_DIR")
                        r="${r%%-[0-9]*}"
                        [[ "$r" = "$agent" ]] && ((existing++))
                    done
                    local delta=$((count - existing))
                    for ((c=0; c<delta; c++)); do
                        NEW_AGENTS+=("$agent")
                    done
                done

                if [ ${#NEW_AGENTS[@]} -gt 0 ]; then
                    local USE_WORKTREES="y"
                    # Ask about worktrees
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo -e "  ${WHITE}Create git worktrees for new agents?${NC}"
                    echo ""
                    for na in "${NEW_AGENTS[@]}"; do
                        echo -e "    ${GREEN}•${NC} $na"
                    done
                    echo ""
                    echo -e "  ${GREEN}y${NC}=yes (recommended)  ${ORANGE}n${NC}=no (simple directories)"
                    read -rsn1 wt_choice
                    [[ "$wt_choice" =~ [nN] ]] && USE_WORKTREES="n"

                    echo ""
                    echo -e "  ${PURPLE}Creating agents...${NC}"
                    local PROJECT_SLUG=$(basename "$MAIN_DIR")

                    if [ ! -d "$MAIN_DIR/.git" ]; then
                        git -C "$MAIN_DIR" init -q 2>/dev/null || true
                        touch "$MAIN_DIR/.gitkeep" 2>/dev/null || true
                        git -C "$MAIN_DIR" add . 2>/dev/null && git -C "$MAIN_DIR" commit -q -m "Initial commit" 2>/dev/null || true
                    fi

                    for spec in "${NEW_AGENTS[@]}"; do
                        local SPEC_SUFFIX=""
                        local base_dir="$(dirname "$MAIN_DIR")/${PROJECT_SLUG}-${spec}"
                        if [ -d "$base_dir" ]; then
                            local num=2
                            while [ -d "${base_dir}-${num}" ]; do ((num++)); done
                            SPEC_SUFFIX="-${num}"
                        fi
                        local SPEC_DIR="${base_dir}${SPEC_SUFFIX}"
                        local branch_name="feature/${spec}${SPEC_SUFFIX}"
                        local display_name="${spec}${SPEC_SUFFIX}"
                        if [ "$USE_WORKTREES" = "y" ]; then
                            git -C "$MAIN_DIR" branch "$branch_name" 2>/dev/null || true
                            git -C "$MAIN_DIR" worktree add -q "$SPEC_DIR" "$branch_name" 2>/dev/null || mkdir -p "$SPEC_DIR"
                        else
                            mkdir -p "$SPEC_DIR"
                        fi
                        setup_agent_config "$SPEC_DIR" "$spec" "$PROJECT_NAME" "$(get_role_description "$spec" "$PROJECT_NAME")"
                        SPEC_DIRS+=("$SPEC_DIR")
                        echo -e "  ${GREEN}✓${NC} Created $display_name"
                    done
                fi
                SETUP_STAGE="done"
            else
                SETUP_STAGE="done"
            fi
        fi

        if [ "$SETUP_STAGE" = "roles" ]; then
            # Use smart suggestions from PRD if available, otherwise fall back to type-based
            if [ -n "$SMART_AGENTS" ]; then
                SPECIALISTS_CSV="$SMART_AGENTS"
                echo -e "  ${GREEN}Using PRD-based suggestions: $SMART_AGENTS${NC}"
                sleep 1
            else
                # Get suggested agents based on type
                IFS=':' read -r PROJECT_TYPE _ SPECIALISTS_CSV <<< "${PROJECT_TYPES[$T_CUR]}"
                if [[ "$PROJECT_TYPE" = "custom" ]]; then
                    # Suggest based on description
                    local name_lower=$(echo "$PROJECT_NAME $CUSTOM_INPUT" | tr '[:upper:]' '[:lower:]')
                    if [[ "$name_lower" =~ (audio|sound|music|dsp|synth|plugin|vst) ]]; then SPECIALISTS_CSV="dsp,engine,ui,tests"
                    elif [[ "$name_lower" =~ (web|site|dashboard|admin) ]]; then SPECIALISTS_CSV="frontend,backend,api,tests"
                    elif [[ "$name_lower" =~ (mobile|app|ios|android) ]]; then SPECIALISTS_CSV="mobile,backend,api,tests"
                    elif [[ "$name_lower" =~ (game|gaming|unity) ]]; then SPECIALISTS_CSV="engine,graphics,audio,ui"
                    elif [[ "$name_lower" =~ (ml|ai|model|neural) ]]; then SPECIALISTS_CSV="ml,data,api,tests"
                    elif [[ "$name_lower" =~ (cli|tool|command) ]]; then SPECIALISTS_CSV="engine,parser,utils,tests"
                    elif [[ "$name_lower" =~ (api|server|backend) ]]; then SPECIALISTS_CSV="api,database,auth,tests"
                    elif [[ "$name_lower" =~ (cloud|sync) ]]; then SPECIALISTS_CSV="cloud,sync,api,tests"
                    else SPECIALISTS_CSV="frontend,backend,tests"; fi
                fi
            fi

            # Role selector with existing specialists pre-selected
            local ALL_ROLES=(frontend backend api database tests devops docs auth ui dsp engine mobile data ml review cloud sync core parser utils)
            local NUM_R=${#ALL_ROLES[@]} R_CUR=0
            declare -a SEL; for i in "${!ALL_ROLES[@]}"; do SEL[$i]=0; done

            # Mark existing specialists
            for sd in "${SPEC_DIRS[@]}"; do
                local spec_name=$(get_role_from_dir "$sd" "$MAIN_DIR")
                for i in "${!ALL_ROLES[@]}"; do
                    [[ "${ALL_ROLES[$i]}" = "$spec_name" ]] && SEL[$i]=2  # 2 = already exists
                done
            done

            # Pre-select suggested roles
            IFS=',' read -ra PRE <<< "$SPECIALISTS_CSV"
            for p in "${PRE[@]}"; do
                for i in "${!ALL_ROLES[@]}"; do
                    [[ "${ALL_ROLES[$i]}" = "$p" && "${SEL[$i]}" -eq 0 ]] && SEL[$i]=1
                done
            done

            local DONE_I=$NUM_R BACK_I=$((NUM_R+1)) TOT=$((NUM_R+2))
            local VISIBLE_ROLES=8  # Show 8 roles at a time
            local SCROLL_OFF=0     # Scroll offset

            draw_roles() {
                printf '\033[2J\033[3J\033[H'
                print_header
                echo ""
                echo -e "  ${WHITE}Select agents to add${NC}  ${GRAY}↑↓ Space=toggle Enter=done${NC}"
                echo ""

                # Calculate scroll window
                if [[ $R_CUR -lt $NUM_R ]]; then
                    # Cursor is on a role - adjust scroll to keep it visible
                    if [[ $R_CUR -lt $SCROLL_OFF ]]; then
                        SCROLL_OFF=$R_CUR
                    elif [[ $R_CUR -ge $((SCROLL_OFF + VISIBLE_ROLES)) ]]; then
                        SCROLL_OFF=$((R_CUR - VISIBLE_ROLES + 1))
                    fi
                fi

                # Show scroll indicator if there are items above
                if [[ $SCROLL_OFF -gt 0 ]]; then
                    echo -e "      ${GRAY}↑ $SCROLL_OFF more above${NC}"
                fi

                # Show visible roles
                local end_idx=$((SCROLL_OFF + VISIBLE_ROLES))
                [[ $end_idx -gt $NUM_R ]] && end_idx=$NUM_R

                for ((i=SCROLL_OFF; i<end_idx; i++)); do
                    local r="${ALL_ROLES[$i]}" cb="○" clr="$WHITE" suffix=""
                    local desc=$(get_role_desc "$r")
                    if [[ "${SEL[$i]}" -eq 2 ]]; then
                        cb="●"; clr="$GRAY"; suffix=" ${GRAY}(existing)${NC}"
                    elif [[ "${SEL[$i]}" -eq 1 ]]; then
                        cb="●"; clr="$GREEN"
                    fi
                    if [[ $i -eq $R_CUR ]]; then
                        printf "  ${REVERSE}${clr} $cb %-10s ${NC} ${GRAY}$desc${NC}$suffix\n" "$r"
                    else
                        printf "  ${clr} $cb %-10s${NC} ${GRAY}$desc${NC}$suffix\n" "$r"
                    fi
                done

                # Show scroll indicator if there are items below
                local remaining=$((NUM_R - end_idx))
                if [[ $remaining -gt 0 ]]; then
                    echo -e "      ${GRAY}↓ $remaining more below${NC}"
                fi

                echo ""
                [[ $R_CUR -eq $DONE_I ]] && echo -e "  ${REVERSE}${GREEN} ✓ DONE ${NC}" || echo -e "    ${GREEN}✓ DONE${NC}"
                [[ $R_CUR -eq $BACK_I ]] && echo -e "  ${REVERSE}${ORANGE} ← BACK ${NC}" || echo -e "    ${ORANGE}← BACK${NC}"
            }

            tput civis; draw_roles
            local role_done=0
            while [[ $role_done -eq 0 ]]; do
                read -rsn1 key
                [[ "$key" = $'\x1b' ]] && { read -rsn2 key; [[ "$key" = "[A" ]] && ((R_CUR=(R_CUR+TOT-1)%TOT)); [[ "$key" = "[B" ]] && ((R_CUR=(R_CUR+1)%TOT)); draw_roles; }
                [[ "$key" = " " && $R_CUR -lt $NUM_R && "${SEL[$R_CUR]}" -ne 2 ]] && { SEL[$R_CUR]=$((1-SEL[$R_CUR])); draw_roles; }
                [[ "$key" = "" ]] && {
                    [[ $R_CUR -eq $DONE_I ]] && role_done=1
                    [[ $R_CUR -eq $BACK_I ]] && role_done=2
                    [[ $R_CUR -lt $NUM_R && "${SEL[$R_CUR]}" -ne 2 ]] && { SEL[$R_CUR]=$((1-SEL[$R_CUR])); draw_roles; }
                }
                [[ "$key" =~ [qQ] ]] && { tput cnorm; role_done=2; }
            done
            tput cnorm

            if [ $role_done -eq 1 ]; then
                # Collect new agents to create
                local -a NEW_AGENTS=()
                for i in "${!ALL_ROLES[@]}"; do
                    [[ "${SEL[$i]}" -eq 1 ]] && NEW_AGENTS+=("${ALL_ROLES[$i]}")
                done

                if [ ${#NEW_AGENTS[@]} -gt 0 ] || [ ${#SPEC_DIRS[@]} -gt 0 ]; then
                    # Build combined agent list with existing counts
                    # Count existing specialists by role type
                    local -a count_args=()
                    local -a existing_roles_seen=()
                    for sd in "${SPEC_DIRS[@]}"; do
                        local role=$(get_role_from_dir "$sd" "$MAIN_DIR")
                        role="${role%%-[0-9]*}"   # Remove -2, -3 suffixes to get base role
                        # Check if we already counted this role
                        local already=0
                        for seen in "${existing_roles_seen[@]}"; do
                            [[ "$seen" = "$role" ]] && { already=1; break; }
                        done
                        [[ $already -eq 1 ]] && continue
                        existing_roles_seen+=("$role")
                        # Count how many of this role exist
                        local role_count=0
                        for sd2 in "${SPEC_DIRS[@]}"; do
                            local r2=$(get_role_from_dir "$sd2" "$MAIN_DIR")
                            r2="${r2%%-[0-9]*}"
                            [[ "$r2" = "$role" ]] && ((role_count++))
                        done
                        count_args+=("${role}:${role_count}")
                    done
                    # Add new agents (starting at 1)
                    for na in "${NEW_AGENTS[@]}"; do
                        count_args+=("$na")
                    done

                    # Show count screen with all agents, max 12 (includes QB)
                    local counts_result
                    counts_result=$(show_agent_count_screen 11 "${count_args[@]}")
                    if [[ -n "$counts_result" ]]; then
                        # Compute delta: only create dirs for counts above existing
                        NEW_AGENTS=()
                        IFS=',' read -ra count_pairs <<< "$counts_result"
                        for pair in "${count_pairs[@]}"; do
                            IFS=':' read -r agent count <<< "$pair"
                            # Find existing count for this agent
                            local existing=0
                            for sd in "${SPEC_DIRS[@]}"; do
                                local r=$(get_role_from_dir "$sd" "$MAIN_DIR")
                                r="${r%%-[0-9]*}"
                                [[ "$r" = "$agent" ]] && ((existing++))
                            done
                            # Only create directories for the delta
                            local delta=$((count - existing))
                            for ((c=0; c<delta; c++)); do
                                NEW_AGENTS+=("$agent")
                            done
                        done
                    fi
                fi

                if [ ${#NEW_AGENTS[@]} -gt 0 ]; then
                    # Ask about worktrees
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo -e "  ${WHITE}Create git worktrees for new agents?${NC}"
                    echo ""
                    for na in "${NEW_AGENTS[@]}"; do
                        echo -e "    ${GREEN}•${NC} $na"
                    done
                    echo ""
                    echo -e "  ${GREEN}y${NC}=yes (recommended)  ${ORANGE}n${NC}=no (simple directories)"
                    read -rsn1 wt_choice
                    [[ "$wt_choice" =~ [nN] ]] && USE_WORKTREES="n"

                    # Create new agent directories
                    echo ""
                    echo -e "  ${PURPLE}Creating agents...${NC}"
                    local PROJECT_SLUG=$(basename "$MAIN_DIR")

                    # Ensure git repo exists
                    if [ ! -d "$MAIN_DIR/.git" ]; then
                        git -C "$MAIN_DIR" init -q 2>/dev/null || true
                        touch "$MAIN_DIR/.gitkeep" 2>/dev/null || true
                        git -C "$MAIN_DIR" add . 2>/dev/null && git -C "$MAIN_DIR" commit -q -m "Initial commit" 2>/dev/null || true
                    fi

                    for spec in "${NEW_AGENTS[@]}"; do
                        # Number duplicates: first=no suffix, second=-2, third=-3
                        local SPEC_SUFFIX=""
                        local base_dir="$(dirname "$MAIN_DIR")/${PROJECT_SLUG}-${spec}"
                        if [ -d "$base_dir" ]; then
                            # Directory exists, find next available number
                            local num=2
                            while [ -d "${base_dir}-${num}" ]; do ((num++)); done
                            SPEC_SUFFIX="-${num}"
                        fi
                        local SPEC_DIR="${base_dir}${SPEC_SUFFIX}"
                        local branch_name="feature/${spec}${SPEC_SUFFIX}"
                        local display_name="${spec}${SPEC_SUFFIX}"
                        if [ "$USE_WORKTREES" = "y" ]; then
                            git -C "$MAIN_DIR" branch "$branch_name" 2>/dev/null || true
                            git -C "$MAIN_DIR" worktree add -q "$SPEC_DIR" "$branch_name" 2>/dev/null || mkdir -p "$SPEC_DIR"
                        else
                            mkdir -p "$SPEC_DIR"
                        fi
                        setup_agent_config "$SPEC_DIR" "$spec" "$PROJECT_NAME" "$(get_role_description "$spec" "$PROJECT_NAME")"
                        SPEC_DIRS+=("$SPEC_DIR")
                        echo -e "  ${GREEN}✓${NC} Created $display_name"
                    done
                fi
                SETUP_STAGE="done"
            elif [ $role_done -eq 2 ]; then
                # BACK selected - go back to type selection
                SETUP_STAGE="type"
            fi
        fi
        done  # End of main setup loop

        # If user explicitly quit from multi-agent setup (Q key), abort the import
        if [ "$USER_QUIT_WIZARD" = true ]; then
            return 1
        fi
    fi

    # ─── FINAL: Setup config for main dir and save ───
    setup_agent_config "$MAIN_DIR" "qb" "$PROJECT_NAME" "You are the QB (Quarterback) - the coordinator for $PROJECT_NAME. At the start of each session, read .claude/qb-dispatch.md for your specialist pane map and dispatch workflow. You coordinate by sending work to your existing specialist panes via tmux send-keys. Your specialists can use TeamCreate themselves for sub-agents."

    # Setup config for any existing specialists that weren't set up
    for sd in "${SPEC_DIRS[@]}"; do
        if [ ! -f "$sd/.claude/settings.local.json" ]; then
            local spec_name=$(get_role_from_dir "$sd" "$MAIN_DIR")
            setup_agent_config "$sd" "$spec_name" "$PROJECT_NAME" "$(get_role_description "$spec_name" "$PROJECT_NAME")"
        fi
    done

    # Save to config
    local SPEC_JSON="[]"
    for dir in "${SPEC_DIRS[@]}"; do
        local dir_short="${dir/$HOME/~}"
        SPEC_JSON=$(echo "$SPEC_JSON" | jq --arg d "$dir_short" '. + [$d]')
    done
    [ -z "$SPEC_JSON" ] && SPEC_JSON="[]"

    local main_dir_short="${MAIN_DIR/$HOME/~}"
    jq --arg name "$PROJECT_NAME" --arg main "$main_dir_short" --argjson specs "$SPEC_JSON" \
        '.projects += [{"name": $name, "main_dir": $main, "specialists": $specs}]' \
        "$CONFIG" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "$CONFIG"

    printf '\033[2J\033[3J\033[H'
    print_header
    echo ""
    echo -e "  ${GREEN}${BOLD}✓ Imported '$PROJECT_NAME'!${NC}"
    echo ""
    echo -e "  ${WHITE}Main:${NC} $MAIN_DIR"
    if [ ${#SPEC_DIRS[@]} -gt 0 ]; then
        echo -e "  ${WHITE}Specialists:${NC} ${#SPEC_DIRS[@]}"
        for sd in "${SPEC_DIRS[@]}"; do
            local spec_name=$(get_role_from_dir "$sd" "$MAIN_DIR")
            echo -e "    ${GREEN}•${NC} $spec_name"
        done
    fi

    # Add Cursor support for any new specialist directories
    for sd in "${SPEC_DIRS[@]}"; do
        if [ ! -f "$sd/.cursorrules" ]; then
            local spec_name=$(get_role_from_dir "$sd" "$MAIN_DIR")
            add_cursorrules_to_project "$sd" "$PROJECT_NAME" "$spec_name"
        fi
    done
    # Update workspace file with all specialists
    create_code_workspace "$MAIN_DIR" "$PROJECT_NAME" "$(basename "$MAIN_DIR")" "${SPEC_DIRS[*]}" > /dev/null 2>&1

    echo ""
    echo -e "  ${GREEN}y${NC}=launch  ${WHITE}n${NC}=menu  ${ORANGE}b${NC}=add/adjust agents"
    while true; do
        read -rsn1 launch
        if [[ "$launch" =~ [yY] ]]; then
            NUM_PROJECTS=$(jq '.projects | length' "$CONFIG")
            SELECTED_PROJECT=$NUM_PROJECTS
            echo "$PROJECT_NAME" > "$LAST_PROJECT_FILE"
            return 0
        elif [[ "$launch" =~ [bB] ]]; then
            # Go to count screen to add/adjust agents
            local ALL_ROLES=(frontend backend api database tests devops docs auth ui dsp engine mobile data ml review cloud sync core parser utils)
            local -a count_args=()
            local -a existing_roles_seen=()
            for sd in "${SPEC_DIRS[@]}"; do
                local role=$(get_role_from_dir "$sd" "$MAIN_DIR")
                role="${role%%-[0-9]*}"
                local already=0
                for seen in "${existing_roles_seen[@]}"; do
                    [[ "$seen" = "$role" ]] && { already=1; break; }
                done
                [[ $already -eq 1 ]] && continue
                existing_roles_seen+=("$role")
                local role_count=0
                for sd2 in "${SPEC_DIRS[@]}"; do
                    local r2=$(get_role_from_dir "$sd2" "$MAIN_DIR")
                    r2="${r2%%-[0-9]*}"
                    [[ "$r2" = "$role" ]] && ((role_count++))
                done
                count_args+=("${role}:${role_count}")
            done
            for r in "${ALL_ROLES[@]}"; do
                local is_existing=0
                for seen in "${existing_roles_seen[@]}"; do
                    [[ "$seen" = "$r" ]] && { is_existing=1; break; }
                done
                [[ $is_existing -eq 0 ]] && count_args+=("${r}:0")
            done

            local counts_result
            counts_result=$(show_agent_count_screen 11 "${count_args[@]}")
            if [[ "$counts_result" != "BACK" && -n "$counts_result" ]]; then
                local -a NEW_AGENTS=()
                IFS=',' read -ra count_pairs <<< "$counts_result"
                for pair in "${count_pairs[@]}"; do
                    IFS=':' read -r agent count <<< "$pair"
                    local existing=0
                    for sd in "${SPEC_DIRS[@]}"; do
                        local r=$(get_role_from_dir "$sd" "$MAIN_DIR")
                        r="${r%%-[0-9]*}"
                        [[ "$r" = "$agent" ]] && ((existing++))
                    done
                    local delta=$((count - existing))
                    for ((c=0; c<delta; c++)); do
                        NEW_AGENTS+=("$agent")
                    done
                done

                if [ ${#NEW_AGENTS[@]} -gt 0 ]; then
                    local USE_WORKTREES="y"
                    printf '\033[2J\033[3J\033[H'
                    print_header
                    echo ""
                    echo -e "  ${WHITE}Create git worktrees for new agents?${NC}"
                    echo ""
                    for na in "${NEW_AGENTS[@]}"; do
                        echo -e "    ${GREEN}•${NC} $na"
                    done
                    echo ""
                    echo -e "  ${GREEN}y${NC}=yes (recommended)  ${ORANGE}n${NC}=no (simple directories)"
                    read -rsn1 wt_choice
                    [[ "$wt_choice" =~ [nN] ]] && USE_WORKTREES="n"

                    echo ""
                    echo -e "  ${PURPLE}Creating agents...${NC}"
                    local PROJECT_SLUG=$(basename "$MAIN_DIR")
                    if [ ! -d "$MAIN_DIR/.git" ]; then
                        git -C "$MAIN_DIR" init -q 2>/dev/null || true
                        touch "$MAIN_DIR/.gitkeep" 2>/dev/null || true
                        git -C "$MAIN_DIR" add . 2>/dev/null && git -C "$MAIN_DIR" commit -q -m "Initial commit" 2>/dev/null || true
                    fi
                    for spec in "${NEW_AGENTS[@]}"; do
                        local SPEC_SUFFIX=""
                        local base_dir="$(dirname "$MAIN_DIR")/${PROJECT_SLUG}-${spec}"
                        if [ -d "$base_dir" ]; then
                            local num=2
                            while [ -d "${base_dir}-${num}" ]; do ((num++)); done
                            SPEC_SUFFIX="-${num}"
                        fi
                        local SPEC_DIR="${base_dir}${SPEC_SUFFIX}"
                        local branch_name="feature/${spec}${SPEC_SUFFIX}"
                        local display_name="${spec}${SPEC_SUFFIX}"
                        if [ "$USE_WORKTREES" = "y" ]; then
                            git -C "$MAIN_DIR" branch "$branch_name" 2>/dev/null || true
                            git -C "$MAIN_DIR" worktree add -q "$SPEC_DIR" "$branch_name" 2>/dev/null || mkdir -p "$SPEC_DIR"
                        else
                            mkdir -p "$SPEC_DIR"
                        fi
                        setup_agent_config "$SPEC_DIR" "$spec" "$PROJECT_NAME" "$(get_role_description "$spec" "$PROJECT_NAME")"
                        SPEC_DIRS+=("$SPEC_DIR")
                        echo -e "  ${GREEN}✓${NC} Created $display_name"
                    done
                    # Update config with new specialists
                    local SPEC_JSON="[]"
                    for dir in "${SPEC_DIRS[@]}"; do
                        local dir_short="${dir/$HOME/~}"
                        SPEC_JSON=$(echo "$SPEC_JSON" | jq --arg d "$dir_short" '. + [$d]')
                    done
                    local main_dir_short="${MAIN_DIR/$HOME/~}"
                    jq --arg name "$PROJECT_NAME" --arg main "$main_dir_short" --argjson specs "$SPEC_JSON" \
                        '(.projects[] | select(.name == $name)) .specialists = $specs' \
                        "$CONFIG" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "$CONFIG"
                    sleep 1
                fi
            fi
            # Re-display the final screen
            printf '\033[2J\033[3J\033[H'
            print_header
            echo ""
            echo -e "  ${GREEN}${BOLD}✓ Imported '$PROJECT_NAME'!${NC}"
            echo ""
            echo -e "  ${WHITE}Main:${NC} $MAIN_DIR"
            if [ ${#SPEC_DIRS[@]} -gt 0 ]; then
                echo -e "  ${WHITE}Specialists:${NC} ${#SPEC_DIRS[@]}"
                for sd in "${SPEC_DIRS[@]}"; do
                    local spec_name=$(get_role_from_dir "$sd" "$MAIN_DIR")
                    echo -e "    ${GREEN}•${NC} $spec_name"
                done
            fi
            echo ""
            echo -e "  ${GREEN}y${NC}=launch  ${WHITE}n${NC}=menu  ${ORANGE}b${NC}=add/adjust agents"
        elif [[ "$launch" =~ [nN] ]]; then
            exec "$0"
        fi
    done
}

delete_project() {
    local proj_idx=$1
    local proj_name=$(jq -r ".projects[$proj_idx].name" "$CONFIG")
    local main_dir=$(jq -r ".projects[$proj_idx].main_dir" "$CONFIG")
    main_dir="${main_dir/#\~/$HOME}"

    # Get specialist dirs
    local -a spec_dirs=()
    local num_specs=$(jq ".projects[$proj_idx].specialists | length" "$CONFIG")
    for ((s=0; s<num_specs; s++)); do
        local sd=$(jq -r ".projects[$proj_idx].specialists[$s]" "$CONFIG")
        spec_dirs+=("${sd/#\~/$HOME}")
    done

    # Draw delete confirmation
    printf '\033[2J\033[3J\033[H'
    print_header
    echo ""
    echo -e "  ${RED}${BOLD}⚠ DELETE PROJECT${NC}"
    echo ""
    echo -e "  ${WHITE}Project:${NC} ${CYAN}${BOLD}$proj_name${NC}"
    echo -e "  ${WHITE}Main dir:${NC} ${GRAY}$main_dir${NC}"
    echo -e "  ${WHITE}Specialists:${NC} ${GRAY}${num_specs} directories${NC}"
    echo ""
    echo -e "  ${GREEN}Enter${NC} = Remove from AGENTIC only"
    echo -e "  ${RED}d${NC}     = DELETE FILES FROM DISK TOO"
    echo -e "  ${ORANGE}Other${NC} = Cancel"
    echo ""

    read -rsn1 confirm_key
    if [ "$confirm_key" = "" ]; then
        # Remove from config only
        jq "del(.projects[$proj_idx])" "$CONFIG" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "$CONFIG"
        echo -e "  ${GREEN}✓${NC} Removed '$proj_name' from AGENTIC"
        echo -e "  ${GRAY}Files on disk were kept${NC}"
        sleep 1.5
        exec "$0"
    elif [ "$confirm_key" = "d" ] || [ "$confirm_key" = "D" ]; then
        # Second confirmation for disk deletion
        printf '\033[2J\033[3J\033[H'
        print_header
        echo ""
        echo -e "  ${RED}${BOLD}⚠⚠ PERMANENT DELETE ⚠⚠${NC}"
        echo ""
        echo -e "  ${WHITE}This will ${RED}PERMANENTLY DELETE${WHITE} these directories:${NC}"
        echo ""
        echo -e "    ${RED}$main_dir${NC}"
        for sd in "${spec_dirs[@]}"; do
            echo -e "    ${RED}$sd${NC}"
        done
        echo ""
        echo -e "  ${WHITE}Type ${RED}DELETE${WHITE} to confirm:${NC}"
        echo -n "  > "
        tput cnorm  # Show cursor for text input
        read -r delete_confirm

        if [ "$delete_confirm" = "DELETE" ]; then
            # Delete from config
            jq "del(.projects[$proj_idx])" "$CONFIG" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "$CONFIG"

            # Delete directories
            echo ""
            for sd in "${spec_dirs[@]}"; do
                if [ -d "$sd" ]; then
                    rm -rf "$sd"
                    echo -e "  ${RED}✗${NC} Deleted $sd"
                fi
            done
            if [ -d "$main_dir" ]; then
                rm -rf "$main_dir"
                echo -e "  ${RED}✗${NC} Deleted $main_dir"
            fi

            echo ""
            echo -e "  ${GREEN}✓${NC} '$proj_name' completely deleted"
            sleep 2
            exec "$0"
        else
            echo -e "  ${ORANGE}Cancelled - nothing deleted${NC}"
            sleep 1
        fi
    fi
}

if [ "$SKIP_MENU" = false ]; then
    # Enter alternate screen buffer (like vim/htop)
    printf '\033[?1049h'
    tput civis

    # Redraw on terminal resize
    trap 'draw_menu' WINCH

    # Resolve which section to start on based on last used project
    CURRENT_SECTION=0
    EXPANDED_SECTION=-1
    ITEM_SELECTION=0
    ITEM_SCROLL=0

    draw_menu

    MENU_RESULT_TYPE=""

    while true; do
        read -rsn1 key
        if [ "$key" = $'\x1b' ]; then
            read -rsn2 -t 1 key
            if [ -z "$key" ]; then
                # Bare Escape — collapse back to section headers
                if [ $EXPANDED_SECTION -ge 0 ]; then
                    EXPANDED_SECTION=-1
                    draw_menu
                fi
            else
            case "$key" in
                '[A')  # Up arrow
                    if [ $EXPANDED_SECTION -ge 0 ]; then
                        # Inside a section — wrap within items
                        count=$(section_item_count $EXPANDED_SECTION)
                        if [ $ITEM_SELECTION -gt 0 ]; then
                            ((ITEM_SELECTION--))
                        else
                            ITEM_SELECTION=$((count - 1))
                        fi
                        update_item_scroll
                    else
                        # Section-level — move between headers
                        CURRENT_SECTION=$(( (CURRENT_SECTION + SECTION_COUNT - 1) % SECTION_COUNT ))
                    fi
                    draw_menu
                    ;;
                '[B')  # Down arrow
                    if [ $EXPANDED_SECTION -ge 0 ]; then
                        # Inside a section — wrap within items
                        count=$(section_item_count $EXPANDED_SECTION)
                        if [ $count -gt 0 ] && [ $ITEM_SELECTION -lt $((count - 1)) ]; then
                            ((ITEM_SELECTION++))
                        else
                            ITEM_SELECTION=0
                        fi
                        update_item_scroll
                    else
                        # Section-level — move between headers
                        CURRENT_SECTION=$(( (CURRENT_SECTION + 1) % SECTION_COUNT ))
                    fi
                    draw_menu
                    ;;
            esac
            fi
        elif [ "$key" = "" ]; then
            # Enter key
            if [ $EXPANDED_SECTION -ge 0 ]; then
                # Inside a section — select the current item
                case $EXPANDED_SECTION in
                    0)  # PROJECTS
                        MENU_RESULT_TYPE="${SEC_PROJ_TYPES[$ITEM_SELECTION]}"
                        break
                        ;;
                    1)  # CREATE
                        MENU_RESULT_TYPE="${SEC_CREATE_TYPES[$ITEM_SELECTION]}"
                        break
                        ;;
                    2)  # LITE
                        MENU_RESULT_TYPE="${SEC_LITE_TYPES[$ITEM_SELECTION]}"
                        break
                        ;;
                esac
            else
                # Section-level — expand the current section (or open settings directly)
                if [ $CURRENT_SECTION -eq 3 ]; then
                    # SETTINGS — open directly
                    MENU_RESULT_TYPE="toggle_slow"
                    break
                else
                    count=$(section_item_count $CURRENT_SECTION)
                    if [ "$count" -gt 0 ]; then
                        EXPANDED_SECTION=$CURRENT_SECTION
                        ITEM_SELECTION=0
                        ITEM_SCROLL=0
                        draw_menu
                    fi
                fi
            fi
        elif [ "$key" = "d" ] || [ "$key" = "D" ]; then
            # Delete — only in PROJECTS section on actual project items
            if [ $EXPANDED_SECTION -eq 0 ] && [[ "${SEC_PROJ_TYPES[$ITEM_SELECTION]}" == project:* ]]; then
                proj_cfg_idx=$(( ${SEC_PROJ_TYPES[$ITEM_SELECTION]#project:} - 1 ))
                tput cnorm
                printf '\033[?1049l'
                delete_project $proj_cfg_idx
                # If we get here, delete was cancelled
                printf '\033[?1049h'
                tput civis
                draw_menu
            fi
        elif [ "$key" = "r" ] || [ "$key" = "R" ]; then
            # Rename — only in PROJECTS section on actual project items
            if [ $EXPANDED_SECTION -eq 0 ] && [[ "${SEC_PROJ_TYPES[$ITEM_SELECTION]}" == project:* ]]; then
                proj_cfg_idx=$(( ${SEC_PROJ_TYPES[$ITEM_SELECTION]#project:} - 1 ))
                tput cnorm
                printf '\033[?1049l'
                OLD_NAME=$(jq -r ".projects[$proj_cfg_idx].name" "$CONFIG")
                printf '\033[2J\033[3J\033[H'
                print_header
                echo ""
                echo -e "  ${CYAN}RENAME PROJECT${NC}"
                echo ""
                echo -e "  ${WHITE}Current name:${NC} ${GREEN}$OLD_NAME${NC}"
                echo ""
                echo -e "  ${GRAY}Leave empty and press Enter to go back${NC}"
                echo ""
                echo -ne "  ${WHITE}New name:${NC} "
                read -r NEW_NAME
                if [ -n "$NEW_NAME" ] && [ "$NEW_NAME" != "$OLD_NAME" ]; then
                    jq --arg new "$NEW_NAME" --argjson idx $proj_cfg_idx \
                        '.projects[$idx].name = $new' "$CONFIG" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "$CONFIG"
                    if [ "$OLD_NAME" = "$LAST_PROJECT" ]; then
                        echo "$NEW_NAME" > "$LAST_PROJECT_FILE"
                    fi
                    echo -e "  ${GREEN}✓${NC} Renamed to '$NEW_NAME'"
                    sleep 1
                fi
                # Restart to rebuild menu arrays
                exec "$0" "$@"
            fi
        elif [ "$key" = "q" ] || [ "$key" = "Q" ]; then
            tput cnorm
            printf '\033[?1049l'
            echo "Cancelled."
            exit 0
        fi
    done

    tput cnorm
    printf '\033[?1049l'

    SELECTED_TYPE="$MENU_RESULT_TYPE"
    case "$SELECTED_TYPE" in
        new)
            # Run the new project wizard
            if run_new_project_wizard; then
                :
            else
                exec "$0" "$@"
            fi
            ;;
        import)
            # Run the import wizard
            if import_existing_project; then
                # Refresh project count after import
                NUM_PROJECTS=$(jq '.projects | length' "$CONFIG")
            else
                exec "$0" "$@"
            fi
            ;;
        upgrade)
            # Project picker for upgrade
            printf '\033[2J\033[3J\033[H'
            print_header
            echo ""
            echo -e "  ${CYAN}${BOLD}UPGRADE PROJECTS${NC}"
            echo -e "  ${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo -e "  ${GRAY}↑↓ select   ⏎ upgrade   q=back${NC}"
            echo ""

            # Build list of projects with their upgrade status
            declare -a upgrade_projects=()
            declare -a upgrade_status=()
            for ((ui=0; ui<NUM_PROJECTS; ui++)); do
                PROJ_MAIN=$(jq -r ".projects[$ui].main_dir" "$CONFIG")
                PROJ_MAIN="${PROJ_MAIN/#\~/$HOME}"
                PROJ_NAME=$(jq -r ".projects[$ui].name" "$CONFIG")

                has_cursorrules=false
                has_prd=false
                [ -f "$PROJ_MAIN/.cursorrules" ] && has_cursorrules=true
                [ -f "$PROJ_MAIN/PRD.md" ] && has_prd=true

                upgrade_projects+=("$PROJ_NAME")
                if [ "$has_cursorrules" = true ] && [ "$has_prd" = true ]; then
                    upgrade_status+=("complete")
                elif [ "$has_cursorrules" = false ] && [ "$has_prd" = false ]; then
                    upgrade_status+=("both")
                elif [ "$has_cursorrules" = false ]; then
                    upgrade_status+=("cursor")
                else
                    upgrade_status+=("prd")
                fi
            done

            UP_CUR=0
            UP_NUM=${#upgrade_projects[@]}

            # Guard against no projects
            if [ $UP_NUM -eq 0 ]; then
                echo -e "  ${YELLOW}No projects configured.${NC}"
                echo -e "  ${GRAY}Add projects first using NEW PROJECT or IMPORT EXISTING.${NC}"
                sleep 2
                exec "$0" "$@"
            fi

            draw_upgrade_picker() {
                printf '\033[2J\033[3J\033[H'
                print_header
                echo ""
                echo -e "  ${CYAN}${BOLD}UPGRADE PROJECTS${NC}"
                echo -e "  ${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
                echo -e "  ${GRAY}↑↓ select   ⏎ upgrade   q=back${NC}"
                echo ""
                for ((pi=0; pi<UP_NUM; pi++)); do
                    status="${upgrade_status[$pi]}"
                    status_text=""
                    status_color=""
                    case "$status" in
                        complete) status_text="✓ fully upgraded"; status_color="$GREEN" ;;
                        both) status_text="needs: cursorrules, PRD"; status_color="$ORANGE" ;;
                        cursor) status_text="needs: cursorrules"; status_color="$YELLOW" ;;
                        prd) status_text="needs: PRD"; status_color="$YELLOW" ;;
                    esac
                    if [ $pi -eq $UP_CUR ]; then
                        echo -e "     ${REVERSE}${WHITE}${BOLD} ▸ ${upgrade_projects[$pi]} ${NC}  ${status_color}${status_text}${NC}"
                    else
                        echo -e "       ${WHITE}${upgrade_projects[$pi]}${NC}  ${status_color}${status_text}${NC}"
                    fi
                done
            }

            tput civis
            draw_upgrade_picker
            while true; do
                read -rsn1 key
                case "$key" in
                    $'\x1b')
                        read -rsn2 key
                        if [[ "$key" = "[A" ]]; then ((UP_CUR=(UP_CUR+UP_NUM-1)%UP_NUM)) || true; draw_upgrade_picker; fi
                        if [[ "$key" = "[B" ]]; then ((UP_CUR=(UP_CUR+1)%UP_NUM)) || true; draw_upgrade_picker; fi
                        ;;
                    q|Q) tput cnorm; exec "$0" "$@" ;;
                    "")
                        tput cnorm
                        sel_status="${upgrade_status[$UP_CUR]}"
                        sel_name="${upgrade_projects[$UP_CUR]}"
                        sel_main=$(jq -r ".projects[$UP_CUR].main_dir" "$CONFIG")
                        sel_main="${sel_main/#\~/$HOME}"

                        # Check if directory exists
                        if [ ! -d "$sel_main" ]; then
                            echo ""
                            echo -e "  ${RED}✗${NC} ${WHITE}$sel_name${NC} directory not found!"
                            echo -e "  ${GRAY}Path: $sel_main${NC}"
                            echo ""
                            echo -e "  ${YELLOW}This project may have been deleted.${NC}"
                            echo -e "  ${GRAY}Use Delete from main menu to clean up config.${NC}"
                            sleep 3
                            draw_upgrade_picker
                            tput civis
                            continue
                        fi

                        if [ "$sel_status" = "complete" ]; then
                            echo ""
                            echo -e "  ${GREEN}✓${NC} ${WHITE}$sel_name${NC} is already fully upgraded!"
                            sleep 1.5
                            draw_upgrade_picker
                            tput civis
                            continue
                        fi

                        # Show upgrade options for this specific project
                        printf '\033[2J\033[3J\033[H'
                        print_header
                        echo ""
                        echo -e "  ${CYAN}${BOLD}UPGRADE: ${WHITE}$sel_name${NC}"
                        echo -e "  ${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
                        echo ""

                        case "$sel_status" in
                            both)
                                echo -e "  ${RED}Missing:${NC} .cursorrules, PRD.md"
                                echo ""
                                echo -e "  ${WHITE}What would you like to add?${NC}"
                                echo -e "  ${CYAN}1${NC}) Cursorrules only"
                                echo -e "  ${CYAN}2${NC}) PRD only"
                                echo -e "  ${CYAN}3${NC}) Both"
                                echo -e "  ${CYAN}q${NC}) Back"
                                echo ""
                                echo -n "  > "
                                while true; do
                                    read -rsn1 choice
                                    case "$choice" in
                                        1)
                                            echo "1"
                                            add_cursorrules_to_project "$sel_main" "$sel_name"
                                            echo -e "  ${GREEN}✓${NC} Added .cursorrules"
                                            sleep 1
                                            break
                                            ;;
                                        2)
                                            echo "2"
                                            generate_prd "$sel_main" "$sel_name"
                                            echo -e "  ${GREEN}✓${NC} Added PRD.md"
                                            sleep 1
                                            break
                                            ;;
                                        3)
                                            echo "3"
                                            add_cursorrules_to_project "$sel_main" "$sel_name"
                                            generate_prd "$sel_main" "$sel_name"
                                            echo -e "  ${GREEN}✓${NC} Added .cursorrules and PRD.md"
                                            sleep 1
                                            break
                                            ;;
                                        q|Q) break ;;
                                    esac
                                done
                                ;;
                            cursor)
                                echo -e "  ${RED}Missing:${NC} .cursorrules"
                                echo -e "  ${GREEN}Has:${NC} PRD.md"
                                echo ""
                                echo -e "  ${WHITE}Add .cursorrules?${NC}"
                                echo -e "  ${CYAN}1${NC}) Yes, add it"
                                echo -e "  ${CYAN}q${NC}) Back"
                                echo ""
                                echo -n "  > "
                                while true; do
                                    read -rsn1 choice
                                    case "$choice" in
                                        1)
                                            echo "1"
                                            add_cursorrules_to_project "$sel_main" "$sel_name"
                                            echo -e "  ${GREEN}✓${NC} Added .cursorrules"
                                            sleep 1
                                            break
                                            ;;
                                        q|Q) break ;;
                                    esac
                                done
                                ;;
                            prd)
                                echo -e "  ${RED}Missing:${NC} PRD.md"
                                echo -e "  ${GREEN}Has:${NC} .cursorrules"
                                echo ""
                                echo -e "  ${WHITE}Add PRD.md?${NC}"
                                echo -e "  ${CYAN}1${NC}) Yes, add it"
                                echo -e "  ${CYAN}q${NC}) Back"
                                echo ""
                                echo -n "  > "
                                while true; do
                                    read -rsn1 choice
                                    case "$choice" in
                                        1)
                                            echo "1"
                                            generate_prd "$sel_main" "$sel_name"
                                            echo -e "  ${GREEN}✓${NC} Added PRD.md"
                                            sleep 1
                                            break
                                            ;;
                                        q|Q) break ;;
                                    esac
                                done
                                ;;
                        esac

                        # Refresh status and redraw
                        [ -f "$sel_main/.cursorrules" ] && upgrade_status[$UP_CUR]="cursor_done" || true
                        [ -f "$sel_main/PRD.md" ] && upgrade_status[$UP_CUR]="prd_done" || true
                        if [ -f "$sel_main/.cursorrules" ] && [ -f "$sel_main/PRD.md" ]; then
                            upgrade_status[$UP_CUR]="complete"
                        elif [ ! -f "$sel_main/.cursorrules" ] && [ ! -f "$sel_main/PRD.md" ]; then
                            upgrade_status[$UP_CUR]="both"
                        elif [ ! -f "$sel_main/.cursorrules" ]; then
                            upgrade_status[$UP_CUR]="cursor"
                        else
                            upgrade_status[$UP_CUR]="prd"
                        fi
                        draw_upgrade_picker
                        tput civis
                        ;;
                esac
            done
            ;;
        project:*) SELECTED_PROJECT="${SELECTED_TYPE#project:}" ;;
        mega) LOAD_ALL=true ;;
        multi_launch) MULTI_PROJECTS="$MULTI_PROJECT_SETTING" ;;
        lite:*) LITE_MODE=true; LITE_PROJECT="${SELECTED_TYPE#lite:}"; SELECTED_PROJECT="$LITE_PROJECT" ;;
        toggle_slow)
            # Settings menu with arrow key navigation
            # Note: NOT using local - nested function needs access
            SET_CUR=0

            # Read current values fresh from config (not cached globals)
            SET_SLOW=$(jq -r '.settings.slow_mode // false' "$CONFIG")
            SET_DANGER=$(jq -r '.settings.dangerous_mode // false' "$CONFIG")
            SET_RELAY=$(jq -r '.settings.auto_relay // false' "$CONFIG")
            SET_SOLO=$(jq -r '.settings.solo_mode // false' "$CONFIG")
            SET_MULTI=$(jq -r '.settings.multi_projects // ""' "$CONFIG")
            SET_DIAGRAM=$(jq -r '.settings.state_diagram // false' "$CONFIG")

            draw_settings() {
                # Full clear + logo on every redraw to prevent header stacking
                printf '\033[2J\033[3J\033[H'
                print_header
                printf "\033[9;1H"

                echo -e "  ${CYAN}${BOLD}SETTINGS${NC}  ${GRAY}↑↓ navigate  Enter=toggle  q=back${NC}\033[K"
                echo -e "\033[K"

                # Slow Startup
                local slow_status="OFF"; [ "$SET_SLOW" = "true" ] && slow_status="ON"
                if [ $SET_CUR -eq 0 ]; then
                    echo -e "  ${REVERSE}${WHITE} ▸ Slow Startup      ${NC}  ${YELLOW}[$slow_status]${NC}\033[K"
                else
                    echo -e "    Slow Startup        ${YELLOW}[$slow_status]${NC}\033[K"
                fi
                echo -e "      ${GRAY}Stagger agent launches to reduce CPU spike${NC}\033[K"

                # Dangerous Mode
                local danger_status="OFF"; [ "$SET_DANGER" = "true" ] && danger_status="ON"
                if [ $SET_CUR -eq 1 ]; then
                    echo -e "  ${REVERSE}${WHITE} ▸ Dangerous Mode    ${NC}  ${RED}[$danger_status]${NC}\033[K"
                else
                    echo -e "    Dangerous Mode      ${RED}[$danger_status]${NC}\033[K"
                fi
                echo -e "      ${GRAY}Run Claude with --dangerously-skip-permissions${NC}\033[K"

                # Auto-Relay
                local relay_status="OFF"; [ "$SET_RELAY" = "true" ] && relay_status="ON"
                if [ $SET_CUR -eq 2 ]; then
                    echo -e "  ${REVERSE}${WHITE} ▸ Auto-Relay        ${NC}  ${CYAN}[$relay_status]${NC}\033[K"
                else
                    echo -e "    Auto-Relay          ${CYAN}[$relay_status]${NC}\033[K"
                fi
                echo -e "      ${GRAY}QB auto-delegates to specialist panes via tmux${NC}\033[K"

                # Solo Mode
                local solo_status="OFF"; [ "$SET_SOLO" = "true" ] && solo_status="ON"
                if [ $SET_CUR -eq 3 ]; then
                    echo -e "  ${REVERSE}${WHITE} ▸ Solo Mode         ${NC}  ${GREEN}[$solo_status]${NC}\033[K"
                else
                    echo -e "    Solo Mode           ${GREEN}[$solo_status]${NC}\033[K"
                fi
                echo -e "      ${GRAY}Only load the selected project${NC}\033[K"

                # Multi-Project (Space=clear/off, Enter=pick projects)
                local multi_status="OFF"; [ -n "$SET_MULTI" ] && multi_status="${SET_MULTI}"
                if [ $SET_CUR -eq 4 ]; then
                    echo -e "  ${REVERSE}${WHITE} ▸ Multi-Project     ${NC}  ${ORANGE}[${multi_status}]${NC}\033[K"
                else
                    echo -e "    Multi-Project       ${ORANGE}[${multi_status}]${NC}\033[K"
                fi
                echo -e "      ${GRAY}Load specific projects — Enter to configure${NC}\033[K"

                # State Diagram
                local diagram_status="OFF"; [ "$SET_DIAGRAM" = "true" ] && diagram_status="ON"
                if [ $SET_CUR -eq 5 ]; then
                    echo -e "  ${REVERSE}${WHITE} ▸ State Diagram     ${NC}  ${PURPLE}[$diagram_status]${NC}\033[K"
                else
                    echo -e "    State Diagram       ${PURPLE}[$diagram_status]${NC}\033[K"
                fi
                echo -e "      ${GRAY}Generate visual state machine after each iteration${NC}\033[K"

                echo -e "\033[K"
                # Save/Back
                if [ $SET_CUR -eq 6 ]; then
                    echo -e "  ${REVERSE}${GREEN} ✓ SAVE & BACK ${NC}\033[K"
                else
                    echo -e "    ${GREEN}✓ SAVE & BACK${NC}\033[K"
                fi
                # Clear any remaining lines below
                printf '\033[J'
            }

            tput civis
            draw_settings

            while true; do
                read -rsn1 key
                if [[ "$key" = $'\x1b' ]]; then
                    read -rsn2 -t 1 key
                    if [ -n "$key" ]; then
                    case "$key" in
                        "[A") ((SET_CUR=(SET_CUR+6)%7)); draw_settings ;;  # Up
                        "[B") ((SET_CUR=(SET_CUR+1)%7)); draw_settings ;;  # Down
                    esac
                    fi
                elif [[ "$key" = "" ]]; then
                    # Enter = toggle or open picker or save
                    if [ $SET_CUR -eq 0 ]; then
                        [ "$SET_SLOW" = "true" ] && SET_SLOW="false" || SET_SLOW="true"
                        draw_settings
                    elif [ $SET_CUR -eq 1 ]; then
                        [ "$SET_DANGER" = "true" ] && SET_DANGER="false" || SET_DANGER="true"
                        draw_settings
                    elif [ $SET_CUR -eq 2 ]; then
                        [ "$SET_RELAY" = "true" ] && SET_RELAY="false" || SET_RELAY="true"
                        draw_settings
                    elif [ $SET_CUR -eq 3 ]; then
                        # Solo Mode — toggle, and if turning on, disable Multi
                        if [ "$SET_SOLO" = "true" ]; then
                            SET_SOLO="false"
                        else
                            SET_SOLO="true"
                            SET_MULTI=""
                        fi
                        draw_settings
                    elif [ $SET_CUR -eq 4 ]; then
                        # Multi-project picker
                        proj_count=$(jq '.projects | length' "$CONFIG")
                        mp_selected=()
                        if [ -n "$SET_MULTI" ]; then
                            IFS=',' read -ra mp_selected <<< "$SET_MULTI"
                        fi
                        # 0 = ON/OFF toggle, 1..proj_count = projects, proj_count+1 = DONE
                        mp_total=$((proj_count + 2))
                        mp_cur=0
                        # Cache project names once
                        declare -a mp_names=()
                        for ((pi=0; pi<proj_count; pi++)); do
                            mp_names+=("$(jq -r ".projects[$pi].name" "$CONFIG")")
                        done
                        draw_multi_picker() {
                            printf '\033[H\033[J'
                            echo -e "  ${ORANGE}${BOLD}MULTI-PROJECT${NC}  ${GRAY}↑↓ navigate  Enter=select  q=back${NC}"
                            echo ""
                            # ON/OFF toggle at top
                            local onoff_label="OFF"
                            [ ${#mp_selected[@]} -gt 0 ] && onoff_label="ON"
                            if [ $mp_cur -eq 0 ]; then
                                echo -e "  ${REVERSE}${WHITE} ▸ Multi-Project: ${onoff_label} ${NC}"
                            else
                                echo -e "    Multi-Project: ${ORANGE}${onoff_label}${NC}"
                            fi
                            echo ""
                            # Project list
                            for ((pi=0; pi<proj_count; pi++)); do
                                local checked=" "
                                local pidx=$((pi+1))
                                for sel in "${mp_selected[@]}"; do
                                    [ "$sel" = "$pidx" ] && checked="✓"
                                done
                                if [ $mp_cur -eq $((pi+1)) ]; then
                                    echo -e "  ${REVERSE}${WHITE} [$checked] ${mp_names[$pi]} ${NC}"
                                else
                                    echo -e "    [$checked] ${mp_names[$pi]}"
                                fi
                            done
                            echo ""
                            # DONE button
                            if [ $mp_cur -eq $((mp_total-1)) ]; then
                                echo -e "  ${REVERSE}${GREEN} ✓ DONE ${NC}"
                            else
                                echo -e "    ${GREEN}✓ DONE${NC}"
                            fi
                        }
                        draw_multi_picker
                        while true; do
                            read -rsn1 mpkey
                            if [[ "$mpkey" = $'\x1b' ]]; then
                                read -rsn2 -t 1 mpkey
                                if [ -n "$mpkey" ]; then
                                    case "$mpkey" in
                                        "[A") ((mp_cur=(mp_cur+mp_total-1)%mp_total)); draw_multi_picker ;;
                                        "[B") ((mp_cur=(mp_cur+1)%mp_total)); draw_multi_picker ;;
                                    esac
                                fi
                            elif [[ "$mpkey" = "" ]]; then
                                if [ $mp_cur -eq 0 ]; then
                                    # ON/OFF toggle — if any selected, clear all. If none, do nothing (pick projects below)
                                    if [ ${#mp_selected[@]} -gt 0 ]; then
                                        mp_selected=()
                                    fi
                                    draw_multi_picker
                                elif [ $mp_cur -eq $((mp_total-1)) ]; then
                                    # DONE — save and exit picker
                                    IFS=','; SET_MULTI="${mp_selected[*]}"; unset IFS
                                    [ -n "$SET_MULTI" ] && SET_SOLO="false"
                                    break
                                else
                                    # Toggle project selection
                                    pidx=$mp_cur
                                    found=false
                                    new_sel=()
                                    for sel in "${mp_selected[@]}"; do
                                        if [ "$sel" = "$pidx" ]; then
                                            found=true
                                        else
                                            new_sel+=("$sel")
                                        fi
                                    done
                                    [ "$found" = false ] && new_sel+=("$pidx")
                                    mp_selected=("${new_sel[@]}")
                                    draw_multi_picker
                                fi
                            elif [[ "$mpkey" =~ [qQ] ]]; then
                                break
                            fi
                        done
                        unset mp_names
                        SETTINGS_DRAWN=false
                        draw_settings
                    elif [ $SET_CUR -eq 5 ]; then
                        [ "$SET_DIAGRAM" = "true" ] && SET_DIAGRAM="false" || SET_DIAGRAM="true"
                        draw_settings
                    elif [ $SET_CUR -eq 6 ]; then
                        # Save settings and exit
                        multi_val="$SET_MULTI"
                        [ -z "$multi_val" ] && multi_val=""
                        jq --argjson slow "$SET_SLOW" --argjson danger "$SET_DANGER" --argjson relay "$SET_RELAY" --argjson solo "$SET_SOLO" --arg multi "$multi_val" --argjson diagram "$SET_DIAGRAM" \
                            '.settings = (.settings // {}) | .settings.slow_mode = $slow | .settings.dangerous_mode = $danger | .settings.auto_relay = $relay | .settings.solo_mode = $solo | .settings.multi_projects = $multi | .settings.state_diagram = $diagram' \
                            "$CONFIG" > "$CONFIG.tmp" && mv "$CONFIG.tmp" "$CONFIG"
                        tput cnorm
                        break
                    fi
                elif [[ "$key" =~ [qQ] ]]; then
                    tput cnorm
                    break
                fi
            done
            exec "$0" "$@"
            ;;
    esac
fi

# Guard: if no projects exist, go back to menu
if [ "$NUM_PROJECTS" -eq 0 ]; then
    if [ "$SWITCH_MODE" = true ]; then
        # Already in menu mode with no projects — exit cleanly
        echo -e "  ${YELLOW}No projects configured. Create one from the menu.${NC}"
        exit 0
    fi
    echo -e "  ${YELLOW}No projects configured. Opening menu...${NC}"
    sleep 1
    printf '\033[?1049l' 2>/dev/null
    tput cnorm 2>/dev/null
    exec "$0" -s
fi

# If multi-project setting is configured and no CLI override, use it
if [ -z "$SELECTED_PROJECT" ] && [ -z "$MULTI_PROJECTS" ] && [ "$LOAD_ALL" = false ]; then
    if [ -n "$MULTI_PROJECT_SETTING" ] && [ "$SOLO_MODE" != "true" ]; then
        MULTI_PROJECTS="$MULTI_PROJECT_SETTING"
    else
        SELECTED_PROJECT=1
    fi
fi

if [ -n "$MULTI_PROJECTS" ]; then
    # Multi-project mode: save first project as last, skip editor selection
    FIRST_PROJ=$(echo "$MULTI_PROJECTS" | cut -d',' -f1)
    LAST_NAME=$(jq -r ".projects[$((FIRST_PROJ-1))].name" "$CONFIG")
    echo "$LAST_NAME" > "$LAST_PROJECT_FILE"
elif [ -n "$SELECTED_PROJECT" ]; then
    LAST_NAME=$(jq -r ".projects[$((SELECTED_PROJECT-1))].name" "$CONFIG")
    echo "$LAST_NAME" > "$LAST_PROJECT_FILE"

    # Show editor selection (skip if --editor was passed)
    if [ "$EDITOR_SET" = false ]; then
        show_editor_selection
    fi

    # Get project info
    PROJ_MAIN=$(jq -r ".projects[$((SELECTED_PROJECT-1))].main_dir" "$CONFIG")
    PROJ_MAIN="${PROJ_MAIN/#\~/$HOME}"
    PROJ_NAME=$(jq -r ".projects[$((SELECTED_PROJECT-1))].name" "$CONFIG")
    PROJ_SLUG=$(echo "$PROJ_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

    # Branch based on editor selection
    if [ "$SELECTED_EDITOR" = "cursor" ]; then
        # Check for .cursorrules and show tip if missing
        if [ ! -f "$PROJ_MAIN/.cursorrules" ]; then
            echo ""
            echo -e "  ${GRAY}💡 Tip: This project predates Cursor support.${NC}"
            echo -e "  ${GRAY}   Run \"Upgrade Projects\" from CREATE menu to add .cursorrules${NC}"
            sleep 2
        fi
        open_in_cursor "$PROJ_MAIN" "$PROJ_NAME" "$PROJ_SLUG"
        exit 0
    fi

    # Terminal mode - check for .cursorrules tip
    if [ ! -f "$PROJ_MAIN/.cursorrules" ]; then
        echo ""
        echo -e "  ${GRAY}💡 Tip: This project predates Cursor support.${NC}"
        echo -e "  ${GRAY}   Run \"Upgrade Projects\" from CREATE menu to add .cursorrules${NC}"
        sleep 2
    fi
fi

# ═══════════════════════════════════════════════════════════════════════════════
# WAVE-BASED TASK DECOMPOSITION
# ═══════════════════════════════════════════════════════════════════════════════

generate_wave_plan() {
    local prompt_text="$1"
    local specialist_list="$2"
    local project_name="$3"

    # Create waves directory
    local waves_dir="/tmp/agentic-waves/${project_name}"
    mkdir -p "$waves_dir"

    # Convert prompt to lowercase for matching
    local prompt_lower
    prompt_lower=$(echo "$prompt_text" | tr '[:upper:]' '[:lower:]')

    # Convert specialist list to array
    local IFS=','
    local available_specs=($specialist_list)
    unset IFS

    # Track which specialist types are mentioned
    local has_dsp=false has_ui=false has_frontend=false has_backend=false
    local has_tests=false has_docs=false has_engine=false has_ml=false
    local has_parser=false has_database=false has_auth=false has_devops=false
    local has_security=false has_mobile=false

    # Match keywords to specialist types (word-start boundary, allow plurals/suffixes)
    if echo "$prompt_lower" | grep -qE '\b(dsp|audio|signals?|filters?|saturation)'; then has_dsp=true; fi
    if echo "$prompt_lower" | grep -qE '\b(ui|interfaces?|components?|panels?|buttons?|knobs?)'; then has_ui=true; fi
    if echo "$prompt_lower" | grep -qE '\b(frontend|react|pages?|layouts?|css)\b'; then has_frontend=true; fi
    if echo "$prompt_lower" | grep -qE '\b(backend|servers?|api|endpoints?|routes?)'; then has_backend=true; fi
    if echo "$prompt_lower" | grep -qE '\b(tests?|specs?|coverage|assertions?)'; then has_tests=true; fi
    if echo "$prompt_lower" | grep -qE '\b(docs?|readme|guides?|references?)'; then has_docs=true; fi
    if echo "$prompt_lower" | grep -qE '\b(engine|core|pipelines?|chains?)'; then has_engine=true; fi
    if echo "$prompt_lower" | grep -qE '\b(ml|models?|train|predict|recommend)'; then has_ml=true; fi
    if echo "$prompt_lower" | grep -qE '\b(parse[rs]?|commands?|voice|intent|nlp)'; then has_parser=true; fi
    if echo "$prompt_lower" | grep -qE '\b(database|schema|migrations?|quer)'; then has_database=true; fi
    if echo "$prompt_lower" | grep -qE '\b(auth|login|permissions?|tokens?)'; then has_auth=true; fi
    if echo "$prompt_lower" | grep -qE '\b(deploy|ci|docker|infra)\b'; then has_devops=true; fi
    if echo "$prompt_lower" | grep -qE '\b(security|audit|vulnerab)'; then has_security=true; fi
    if echo "$prompt_lower" | grep -qE '\b(mobile|ios|android|app)\b'; then has_mobile=true; fi

    # Classify specialists into waves based on dependency rules
    local wave1=() wave2=() wave_last=()

    for spec in "${available_specs[@]}"; do
        local spec_trimmed
        spec_trimmed=$(echo "$spec" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
        local matched=false

        case "$spec_trimmed" in
            dsp)      $has_dsp && matched=true ;;
            ui)       $has_ui && matched=true ;;
            frontend) $has_frontend && matched=true ;;
            backend)  $has_backend && matched=true ;;
            tests)    $has_tests && matched=true ;;
            docs)     $has_docs && matched=true ;;
            engine)   $has_engine && matched=true ;;
            ml)       $has_ml && matched=true ;;
            parser)   $has_parser && matched=true ;;
            database) $has_database && matched=true ;;
            auth)     $has_auth && matched=true ;;
            devops)   $has_devops && matched=true ;;
            security) $has_security && matched=true ;;
            mobile)   $has_mobile && matched=true ;;
            *)        matched=true ;;
        esac

        if [ "$matched" = true ]; then
            case "$spec_trimmed" in
                tests|docs)
                    wave_last+=("$spec_trimmed")
                    ;;
                ui|frontend)
                    if $has_backend || $has_dsp; then
                        wave2+=("$spec_trimmed")
                    else
                        wave1+=("$spec_trimmed")
                    fi
                    ;;
                engine)
                    if $has_dsp; then
                        wave2+=("$spec_trimmed")
                    else
                        wave1+=("$spec_trimmed")
                    fi
                    ;;
                *)
                    wave1+=("$spec_trimmed")
                    ;;
            esac
        fi
    done

    # If nothing matched, put all available specialists in wave 1
    if [ ${#wave1[@]} -eq 0 ] && [ ${#wave2[@]} -eq 0 ] && [ ${#wave_last[@]} -eq 0 ]; then
        for spec in "${available_specs[@]}"; do
            local spec_trimmed
            spec_trimmed=$(echo "$spec" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
            wave1+=("$spec_trimmed")
        done
    fi

    # Build JSON output
    local json='{"waves":['
    local wave_num=0
    local has_prev=false

    if [ ${#wave1[@]} -gt 0 ]; then
        wave_num=1
        local specs_json=""
        for s in "${wave1[@]}"; do
            [ -n "$specs_json" ] && specs_json+=","
            specs_json+="\"$s\""
        done
        json+="{\"wave\":1,\"specialists\":[$specs_json]}"
        has_prev=true
    fi

    if [ ${#wave2[@]} -gt 0 ]; then
        wave_num=$((wave_num + 1))
        local specs_json=""
        for s in "${wave2[@]}"; do
            [ -n "$specs_json" ] && specs_json+=","
            specs_json+="\"$s\""
        done
        $has_prev && json+=","
        json+="{\"wave\":$wave_num,\"specialists\":[$specs_json],\"depends_on\":$((wave_num - 1))}"
        has_prev=true
    fi

    if [ ${#wave_last[@]} -gt 0 ]; then
        wave_num=$((wave_num + 1))
        local specs_json=""
        for s in "${wave_last[@]}"; do
            [ -n "$specs_json" ] && specs_json+=","
            specs_json+="\"$s\""
        done
        $has_prev && json+=","
        json+="{\"wave\":$wave_num,\"specialists\":[$specs_json],\"depends_on\":$((wave_num - 1))}"
    fi

    json+=']}'

    echo "$json" > "$waves_dir/waves.json"
}

echo ""
echo -e "${PURPLE}Starting agents session...${NC}"

# ═══════════════════════════════════════════════════════════════════════════════
# CREATE TMUX SESSION
# ═══════════════════════════════════════════════════════════════════════════════

TMUX_SESSION_CREATED=false
SESSION_OPTIONS_CONFIGURED=false

# If --no-kill and session exists, mark session as already created and find next window index
if [ "$NO_KILL" = true ] && [ "$EXISTING_SESSION" = true ]; then
    TMUX_SESSION_CREATED=true
    SESSION_OPTIONS_CONFIGURED=true
    # Find the next available window index
    NO_KILL_WIN_IDX=$(tmux list-windows -t $SESSION -F '#{window_index}' 2>/dev/null | sort -n | tail -1)
    NO_KILL_WIN_IDX=$((NO_KILL_WIN_IDX + 1))
fi

for ((i=0; i<NUM_PROJECTS; i++)); do
    # Solo mode: skip non-selected projects entirely (no tmux window created)
    if [ "$SOLO_MODE" = "true" ]; then
        if [ -n "$MULTI_PROJECTS" ]; then
            is_in_list "$MULTI_PROJECTS" "$((i+1))" || continue
        elif [ -n "$SELECTED_PROJECT" ] && [ $i -ne $((SELECTED_PROJECT-1)) ]; then
            continue
        fi
    fi
    # Multi-project mode (non-solo): skip projects not in the list
    if [ -n "$MULTI_PROJECTS" ] && [ "$SOLO_MODE" != "true" ]; then
        is_in_list "$MULTI_PROJECTS" "$((i+1))" || continue
    fi

    DISPLAY_NAME=$(jq -r ".projects[$i].name" "$CONFIG")
    NAME=$(echo "$DISPLAY_NAME" | tr ' .:' '---')
    MAIN=$(jq -r ".projects[$i].main_dir" "$CONFIG")
    MAIN="${MAIN/#\~/$HOME}"
    NUM_SPEC=$(jq ".projects[$i].specialists | length" "$CONFIG")
    [ $NUM_SPEC -gt 12 ] && NUM_SPEC=12

    echo -e "  ${GREEN}$DISPLAY_NAME${NC}: 1 QB + $NUM_SPEC specialists"

    if [ "$NO_KILL" = true ] && [ "$EXISTING_SESSION" = true ]; then
        WIN_IDX=$NO_KILL_WIN_IDX
        NO_KILL_WIN_IDX=$((NO_KILL_WIN_IDX + 1))
    else
        WIN_IDX=$((i + 1))
    fi
    if [ "$TMUX_SESSION_CREATED" = false ]; then
        # Detect terminal size (default 200x50 for detached sessions)
        TERM_COLS=$(stty size 2>/dev/null | awk '{print $2}')
        TERM_ROWS=$(stty size 2>/dev/null | awk '{print $1}')
        [ -z "$TERM_COLS" ] || [ "$TERM_COLS" -lt 80 ] 2>/dev/null && TERM_COLS=200
        [ -z "$TERM_ROWS" ] || [ "$TERM_ROWS" -lt 24 ] 2>/dev/null && TERM_ROWS=50
        tmux new-session -d -s $SESSION -n "$NAME" -c "$MAIN" -x "$TERM_COLS" -y "$TERM_ROWS"
        TMUX_SESSION_CREATED=true
    else
        mkdir -p "$MAIN"
        tmux new-window -t "$SESSION:$WIN_IDX" -n "$NAME" -c "$MAIN"
    fi

    # Configure tmux session options (only once on first window created)
    if [ "$SESSION_OPTIONS_CONFIGURED" = false ]; then
        SESSION_OPTIONS_CONFIGURED=true
        tmux set-option -t $SESSION mouse on
        tmux set-option -t $SESSION set-clipboard on
        # Let panes close when their process exits (allows TeamCreate sub-agents to clean up)
        # Agentic specialist panes stay alive because Claude Code is interactive and keeps running
        tmux set-option -t $SESSION remain-on-exit off
        # Copy to system clipboard on mouse drag end
        tmux bind-key -T copy-mode MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
        tmux bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"
        # Add token stats, relay status (if enabled), and QUIT button to status bar
        if [ "$AUTO_RELAY" = "true" ]; then
            tmux set-option -t $SESSION status-right '#(~/.local/bin/agentic-relay-status) #(~/.local/bin/agentic-session-stats) #[fg=colour196,bold][quit]#[default]'
            tmux set-option -t $SESSION status-right-length 80
        else
            tmux set-option -t $SESSION status-right '#(~/.local/bin/agentic-session-stats) #[fg=colour196,bold][quit]#[default]'
            tmux set-option -t $SESSION status-right-length 60
        fi
        tmux set-option -t $SESSION status-interval 5
        # Bind mouse click on [quit] button — set flag then kill session (goes to homepage)
        tmux bind-key -n MouseDown1StatusRight run-shell "echo switch > /tmp/agentic-restart-flag; tmux kill-session -t $SESSION"
        tmux bind-key -n MouseUp1StatusRight run-shell "echo switch > /tmp/agentic-restart-flag; tmux kill-session -t $SESSION"
        # Also bind Ctrl-Q as backup quit method
        tmux bind-key -n C-q confirm-before -p "Kill agentic session? (y/n)" "run-shell 'echo switch > /tmp/agentic-restart-flag; tmux kill-session -t $SESSION'"
    fi

    # Set pane border options for THIS window (must be done per-window)
    tmux set-window-option -t "$SESSION:$NAME" pane-border-status top
    tmux set-window-option -t "$SESSION:$NAME" pane-border-format '#[fg=cyan] #{b:pane_current_path} #[fg=colour245]│ #(~/.local/bin/agentic-pane-stats #{pane_id}) #[default]'
    tmux set-window-option -t "$SESSION:$NAME" pane-active-border-style 'fg=cyan'
    tmux set-window-option -t "$SESSION:$NAME" pane-border-style 'fg=colour238'
    sleep 0.2

    if [ $NUM_SPEC -eq 0 ]; then
        tmux send-keys -t "$SESSION:$NAME.1" "$CLAUDE_CMD" Enter 2>/dev/null
        # Detect ready state then send identify (with auto trust approval)
        nohup bash -c "
            trust_approved=false
            for attempt in {1..180}; do
                sleep 1
                pane_content=\$(tmux capture-pane -t '$SESSION:$NAME.1' -p 2>/dev/null)
                # Auto-approve trust prompt
                if [ \"\$trust_approved\" = false ] && echo \"\$pane_content\" | grep -q 'Yes, proceed'; then
                    tmux send-keys -t '$SESSION:$NAME.1' Enter
                    trust_approved=true
                    continue
                fi
                if echo \"\$pane_content\" | grep -qE '(for shortcuts|❯)'; then
                    sleep 3
                    pane_check=\$(tmux capture-pane -t '$SESSION:$NAME.1' -p 2>/dev/null)
                    if echo \"\$pane_check\" | grep -qE '(for shortcuts|❯)'; then
                        tmux send-keys -t '$SESSION:$NAME.1' 'identify yourself'; sleep 0.3; tmux send-keys -t '$SESSION:$NAME.1' Enter
                        exit 0
                    fi
                fi
            done
        " >/dev/null 2>&1 &
        continue
    elif [ $NUM_SPEC -le 5 ]; then
        SPEC_DIR=$(jq -r ".projects[$i].specialists[0]" "$CONFIG")
        SPEC_DIR="${SPEC_DIR/#\~/$HOME}"
        mkdir -p "$SPEC_DIR"
        tmux split-window -v -t "$SESSION:$NAME.1" -c "$SPEC_DIR" -l $((TERM_ROWS * 70 / 100))
        sleep 0.1

        for ((j=1; j<NUM_SPEC; j++)); do
            SPEC_DIR=$(jq -r ".projects[$i].specialists[$j]" "$CONFIG")
            SPEC_DIR="${SPEC_DIR/#\~/$HOME}"
            mkdir -p "$SPEC_DIR"
            tmux split-window -h -t "$SESSION:$NAME.$((j+1))" -c "$SPEC_DIR"
            sleep 0.1
        done

        WINDOW_WIDTH=$(tmux display-message -t "$SESSION:$NAME" -p '#{window_width}')
        PANE_WIDTH=$((WINDOW_WIDTH / NUM_SPEC))
        for ((j=0; j<NUM_SPEC-1; j++)); do
            tmux resize-pane -t "$SESSION:$NAME.$((j+2))" -x $PANE_WIDTH
        done
        tmux resize-pane -t "$SESSION:$NAME.1" -y $((TERM_ROWS * 30 / 100)) 2>/dev/null
    else
        HALF=$((NUM_SPEC / 2))
        REMAINDER=$((NUM_SPEC % 2))
        ROW1_COUNT=$((HALF + REMAINDER))
        ROW2_COUNT=$HALF

        SPEC_DIR=$(jq -r ".projects[$i].specialists[0]" "$CONFIG")
        SPEC_DIR="${SPEC_DIR/#\~/$HOME}"
        mkdir -p "$SPEC_DIR"
        tmux split-window -v -t "$SESSION:$NAME" -c "$SPEC_DIR" -l $((TERM_ROWS * 75 / 100))
        sleep 0.1

        if [ $ROW2_COUNT -gt 0 ]; then
            SPEC_DIR=$(jq -r ".projects[$i].specialists[$ROW1_COUNT]" "$CONFIG")
            SPEC_DIR="${SPEC_DIR/#\~/$HOME}"
            mkdir -p "$SPEC_DIR"
            tmux split-window -v -t "$SESSION:$NAME.2" -c "$SPEC_DIR" -l $((TERM_ROWS * 38 / 100))
            sleep 0.1
        fi

        for ((j=1; j<ROW1_COUNT; j++)); do
            SPEC_DIR=$(jq -r ".projects[$i].specialists[$j]" "$CONFIG")
            SPEC_DIR="${SPEC_DIR/#\~/$HOME}"
            mkdir -p "$SPEC_DIR"
            tmux split-window -h -t "$SESSION:$NAME.2" -c "$SPEC_DIR"
            sleep 0.1
        done

        ROW2_START_PANE=$((ROW1_COUNT + 2))
        for ((j=1; j<ROW2_COUNT; j++)); do
            SPEC_DIR=$(jq -r ".projects[$i].specialists[$((ROW1_COUNT + j))]" "$CONFIG")
            SPEC_DIR="${SPEC_DIR/#\~/$HOME}"
            mkdir -p "$SPEC_DIR"
            tmux split-window -h -t "$SESSION:$NAME.$ROW2_START_PANE" -c "$SPEC_DIR"
            sleep 0.1
        done

        tmux resize-pane -t "$SESSION:$NAME.1" -y $((TERM_ROWS * 25 / 100)) 2>/dev/null
        WINDOW_WIDTH=$(tmux display-message -t "$SESSION:$NAME" -p '#{window_width}')
        ROW1_PANE_WIDTH=$((WINDOW_WIDTH / ROW1_COUNT))
        for ((j=0; j<ROW1_COUNT-1; j++)); do
            tmux resize-pane -t "$SESSION:$NAME.$((j+2))" -x $ROW1_PANE_WIDTH
        done
        if [ $ROW2_COUNT -gt 1 ]; then
            ROW2_PANE_WIDTH=$((WINDOW_WIDTH / ROW2_COUNT))
            for ((j=0; j<ROW2_COUNT-1; j++)); do
                tmux resize-pane -t "$SESSION:$NAME.$((ROW1_COUNT + 2 + j))" -x $ROW2_PANE_WIDTH
            done
        fi
    fi

    # Save the original tmux layout so it can be restored after TeamCreate scrambles it
    if [ $NUM_SPEC -gt 0 ]; then
        sleep 0.3  # Let tmux settle
        ORIGINAL_LAYOUT=$(tmux display-message -t "$SESSION:$NAME" -p '#{window_layout}')
        ORIGINAL_PANE_COUNT=$((NUM_SPEC + 1))  # QB + specialists
    fi

    # Generate pane-map.json (always — used by QB for dispatch + relay when enabled)
    if [ $NUM_SPEC -gt 0 ]; then
        RELAY_DIR="/tmp/agentic-relay/$NAME"
        mkdir -p "$RELAY_DIR/queue" "$RELAY_DIR/sent"
        PANE_MAP="{"
        SPEC_LIST=""
        for ((j=0; j<NUM_SPEC; j++)); do
            SPEC_DIR=$(jq -r ".projects[$i].specialists[$j]" "$CONFIG")
            SPEC_DIR="${SPEC_DIR/#\~/$HOME}"
            SPEC_ROLE=$(get_role_from_dir "$SPEC_DIR" "$MAIN")
            PANE_NUM=$((j + 2))  # Pane 1 is QB, specialists start at 2
            [ $j -gt 0 ] && PANE_MAP="$PANE_MAP,"
            PANE_MAP="$PANE_MAP \"$SPEC_ROLE\": \"$SESSION:$NAME.$PANE_NUM\""
            [ $j -gt 0 ] && SPEC_LIST="$SPEC_LIST, "
            SPEC_LIST="${SPEC_LIST}${SPEC_ROLE} (pane $PANE_NUM)"
        done
        PANE_MAP="$PANE_MAP }"
        echo "$PANE_MAP" | jq '.' > "$RELAY_DIR/pane-map.json"

        # Save original layout for restoration after TeamCreate
        echo "$ORIGINAL_LAYOUT" > "$RELAY_DIR/original-layout.txt"
        echo "$ORIGINAL_PANE_COUNT" > "$RELAY_DIR/original-pane-count.txt"

        # Write QB dispatch instructions to the main project directory
        mkdir -p "$MAIN/.claude"

        # Generate restore-layout.sh for this project
        cat > "$RELAY_DIR/restore-layout.sh" << RESTOREEOF
#!/bin/bash
# Restore tmux layout to original state for $NAME
# This removes any extra panes added by TeamCreate sub-agents and
# restores the original QB-on-top, specialists-below grid layout.

SESSION="$SESSION"
WINDOW="$NAME"
RELAY_DIR="$RELAY_DIR"

ORIGINAL_COUNT=\$(cat "\$RELAY_DIR/original-pane-count.txt")
ORIGINAL_LAYOUT=\$(cat "\$RELAY_DIR/original-layout.txt")

# Kill extra panes from highest index down (avoids shifting lower indices)
CURRENT=\$(tmux list-panes -t "\$SESSION:\$WINDOW" | wc -l | tr -d ' ')
while [ "\$CURRENT" -gt "\$ORIGINAL_COUNT" ]; do
  HIGHEST=\$(tmux list-panes -t "\$SESSION:\$WINDOW" -F '#{pane_index}' | sort -rn | head -1)
  tmux kill-pane -t "\$SESSION:\$WINDOW.\$HIGHEST" 2>/dev/null
  CURRENT=\$((CURRENT - 1))
done

# Apply the saved layout geometry (pixel-perfect snapshot from launch)
tmux select-layout -t "\$SESSION:\$WINDOW" "\$ORIGINAL_LAYOUT"
echo "Layout restored to original state."
RESTOREEOF
        chmod +x "$RELAY_DIR/restore-layout.sh"

        cat > "$MAIN/.claude/qb-dispatch.md" << QBEOF
# QB Dispatch Guide

You are the QB (Quarterback/Coordinator) for **$NAME**. Your specialist agents are already running in tmux panes below you, ready to work. You do NOT use TeamCreate or the Agent tool — your team is already set up.

## Your Specialists
$SPEC_LIST

Pane map JSON: /tmp/agentic-relay/$NAME/pane-map.json

---

## PHASE 1: DISPATCH (do this IMMEDIATELY)

**CRITICAL: Dispatch to ALL relevant specialists at once. Send multiple tmux commands in a SINGLE response using parallel Bash tool calls. NEVER send to one specialist and wait for them to finish before sending to the next. Every independent task goes out simultaneously.**

For short prompts (under 500 chars):
\`\`\`
tmux send-keys -t "$SESSION:$NAME.PANE_NUMBER" "Your detailed instructions here. Commit all changes when you finish. Do not run tests. For any task that involves 3+ files, use TeamCreate to spin up a team of sub-agents. For simple single-file edits (1-2 files), you can work solo." Enter
\`\`\`

For long prompts (over 500 chars), use load-buffer:
\`\`\`
cat > /tmp/qb-prompt-ROLE.txt << 'PROMPT'
Your long instructions here...
Commit all changes when you finish. Do not run tests. For any task that involves 3+ files, use TeamCreate to spin up a team of sub-agents. For simple single-file edits (1-2 files), you can work solo.
PROMPT
tmux load-buffer /tmp/qb-prompt-ROLE.txt && tmux paste-buffer -t "$SESSION:$NAME.PANE_NUMBER" && sleep 0.3 && tmux send-keys -t "$SESSION:$NAME.PANE_NUMBER" Enter
\`\`\`

### Dispatch rules
- Analyze the user's request, break it into specialist tasks, and dispatch ALL of them in ONE response
- Do NOT check if specialists are ready first — they are ready, they launched idle
- Do NOT dispatch one specialist and wait to see what happens before dispatching others
- Each specialist prompt must be self-contained with full context (file paths, tech stack, design decisions, existing patterns)
- Include enough detail so the specialist can work independently without asking questions
- End each prompt with: "Make reasonable assumptions for any ambiguous details. Do not ask clarifying questions — just build it. Commit all changes when you finish. Do not run tests. For any task that involves 3+ files, use TeamCreate to spin up a team of sub-agents. For simple single-file edits (1-2 files), you can work solo."

---

## PHASE 2: MONITOR (after all dispatches are sent)

Start monitoring right away — don't wait for the user to ask.

1. Wait about 60 seconds after dispatching
2. Check each specialist pane:
\`\`\`
tmux capture-pane -t "$SESSION:$NAME.PANE_NUMBER" -p -S -30 2>/dev/null
\`\`\`
3. Look for completion indicators: commits made, "What can I help you with?", idle prompts, "Brewed/Crunched/Cooked/Baked for"
4. If any specialist is still working, wait 30 more seconds and check again
5. Repeat until all specialists are done

### If a specialist is stuck or erroring
- Read their pane output to understand the error
- Send them a targeted fix prompt
- Continue monitoring other specialists in parallel

---

## PHASE 3: WRAP UP (after ALL specialists finish)

Do these steps automatically — no need to ask the user for permission:

**a. Restore the pane layout:**
\`\`\`
bash /tmp/agentic-relay/$NAME/restore-layout.sh
\`\`\`

**b. Merge all branches into main:**
\`\`\`
cd $MAIN && git checkout main && git merge --no-ff feature/BRANCH_NAME -m "Merge SPECIALIST_NAME work"
\`\`\`
Do this for every specialist branch. If there are merge conflicts, report them to the user.

**c. Report a summary** — what was built, key files changed, branches merged.

**d. State Machine Diagram** — Check the setting: \`jq -r '.settings.state_diagram // false' ~/.config/agents-projects.json\`. If it returns "true", generate a state machine diagram:

1. Read the actual source files in the project — routes, components, API endpoints, database models, imports, exports. Use REAL names from the code, not placeholders.
2. Read the app's styling: check tailwind.config, globals.css, theme files, or any CSS variables to extract the app's ACTUAL color palette, fonts, and design tokens. The diagram must visually feel like it belongs to THIS app, not a generic template.
3. Create a standalone HTML file at \`$MAIN/STATE-MACHINE.html\` with:
   - Background and styling that matches the app's own design system (use the app's primary colors, fonts, border radius, shadows — read them from the source)
   - A simplified, easily digestible visual diagram showing how data flows through the app: user actions → frontend components → API endpoints → backend handlers → database
   - Every node labeled with the REAL component name, endpoint path, or table name from the codebase — keep labels short and clear
   - Nodes styled to LOOK like simplified versions of the actual UI components (if the app has cards with rounded corners and shadows, the diagram nodes should have rounded corners and shadows; if the app uses gradients, the nodes use similar gradients)
   - Connection lines with arrows showing data flow direction between nodes
   - Nodes added or changed in THIS iteration highlighted with a glowing border so anyone can instantly see what's new
   - A clean header: project name, date, what was built this iteration
   - A simple legend explaining what each node type represents
   - Clicking a node shows: file path, brief description of what it does
   - Pure inline HTML/CSS/JS — no external dependencies, no CDN links
   - The layout should be clean and spacious — not cramped. Use generous padding and whitespace. Anyone should understand the full architecture in 30 seconds.
4. Open it automatically: \`open $MAIN/STATE-MACHINE.html\` (macOS) or \`xdg-open $MAIN/STATE-MACHINE.html\` (Linux)
5. Also save a copy to \`/tmp/agentic-diagrams/$NAME/iteration-{N}.html\`

If state_diagram setting is false or missing, skip this step entirely.

---

## Guidelines

1. Your team is already running — use tmux send-keys to dispatch, NOT TeamCreate or Agent tool.
2. Dispatch everything to specialists, even single-file tasks.
3. You can read files to understand the codebase before dispatching, but delegate ALL changes.
4. Your specialists will use TeamCreate on their own for complex subtasks — that's expected.
5. After wrap-up, proceed directly — no need to ask permission.
QBEOF

        # Write project-level CLAUDE.md so the QB auto-reads dispatch instructions
        # Only write if no existing CLAUDE.md or if it doesn't already have QB instructions
        if [ ! -f "$MAIN/CLAUDE.md" ] || ! grep -q "QB Dispatch" "$MAIN/CLAUDE.md" 2>/dev/null; then
            # Prepend QB instructions to existing CLAUDE.md or create new one
            QB_BLOCK="# QB Coordination Guide

You are the QB (Quarterback) for this agentic session. Your specialist agents are already running in tmux panes. You do NOT use TeamCreate or the Agent tool — your team is already set up.

**Read .claude/qb-dispatch.md for your specialist pane map and full dispatch instructions.**

**CRITICAL RULE: When you receive a task, dispatch to ALL relevant specialists simultaneously in a SINGLE response. Never send to one and wait before sending to the next. Parallel dispatch is mandatory.**

Your workflow has three phases:
1. **DISPATCH** — Break the task into specialist assignments and send ALL of them at once via parallel tmux send-keys calls
2. **MONITOR** — Check specialist panes every 30-60 seconds until all are done
3. **WRAP UP** — Restore layout, merge branches, report results (no need to ask permission)
"
            if [ -f "$MAIN/CLAUDE.md" ]; then
                EXISTING=$(cat "$MAIN/CLAUDE.md")
                echo "${QB_BLOCK}
${EXISTING}" > "$MAIN/CLAUDE.md"
            else
                echo "$QB_BLOCK" > "$MAIN/CLAUDE.md"
            fi
        fi
    fi

done

# ═══════════════════════════════════════════════════════════════════════════════
# LAUNCH AGENTS - Clean idle pane display
# ═══════════════════════════════════════════════════════════════════════════════

# Create idle display script in temp location (runs once at startup)
IDLE_SCRIPT_DIR="/tmp/agentic-idle"
mkdir -p "$IDLE_SCRIPT_DIR"

# Generate the idle display script
cat > "$IDLE_SCRIPT_DIR/idle.sh" << IDLESCRIPT
#!/bin/bash
SLOT="\$1"
SESSION="agentic"
CLAUDE_CMD="$CLAUDE_CMD"
sleep 0.5
clear
printf '\033[2J\033[3J\033[H'
echo ""
echo "┌─────────────────────────────────────────┐"
echo "│                                         │"
printf "│  SLOT %-2s                      IDLE    │\n" "\$SLOT"
echo "│                                         │"
echo "│         ENTER = activate                │"
echo "│             H = HOME (pick project)     │"
echo "│             Q = QUIT (exit)             │"
echo "│                                         │"
echo "└─────────────────────────────────────────┘"
echo ""
while true; do
    read -rsn1 key
    case "\$key" in
        "")
            (
                for attempt in {1..180}; do
                    sleep 1
                    if tmux capture-pane -p 2>/dev/null | grep -q 'for shortcuts'; then
                        tmux send-keys 'identify yourself'; sleep 0.3; tmux send-keys Enter
                        break
                    fi
                done
            ) &
            \$CLAUDE_CMD
            ;;
        h|H) echo switch > /tmp/agentic-restart-flag; tmux detach-client; exit ;;
        q|Q) echo switch > /tmp/agentic-restart-flag; tmux kill-session -t "\$SESSION" 2>/dev/null; exit ;;
    esac
done
IDLESCRIPT
chmod +x "$IDLE_SCRIPT_DIR/idle.sh"

sleep 0.5

# Helper function: wait for agent to be ready (detects Claude startup complete)
wait_for_agent_ready() {
    local target="$1"
    local max_wait=150  # Max 150 seconds per agent (Claude can be slow to start)
    local trust_approved=false
    for ((attempt=1; attempt<=max_wait; attempt++)); do
        local pane_content
        # Capture with history to catch prompt in small panes
        pane_content=$(tmux capture-pane -t "$target" -p -S -20 2>/dev/null)

        # Auto-approve workspace trust prompt if detected
        if [ "$trust_approved" = false ] && echo "$pane_content" | grep -q 'Yes, proceed'; then
            tmux send-keys -t "$target" Enter 2>/dev/null
            trust_approved=true
            sleep 1
            continue
        fi

        # Check for Claude ready state - multiple patterns for different pane sizes
        # ❯ = prompt char, "? for" = shortcut hint, "bypass" = permissions bar, "Try" = prompt hint
        if echo "$pane_content" | grep -qE '(❯|bypass|\? for|Try ")'; then
            return 0
        fi
        sleep 1
    done
    return 1  # Timeout
}

# Display slow mode status
if [ "$SLOW_MODE" = true ]; then
    echo -e "  ${YELLOW}Slow Startup enabled${NC} - agents will load one at a time"
fi
if [ "$SOLO_MODE" = "true" ]; then
    echo -e "  ${GREEN}Solo Mode enabled${NC} - only loading selected project"
fi

if [ "$LOAD_ALL" = true ]; then
    echo -e "${RED}${BOLD}MEGA MODE: Launching all agents...${NC}"
    for ((i=0; i<NUM_PROJECTS; i++)); do
        NAME=$(jq -r ".projects[$i].name" "$CONFIG" | tr ' .:' '---')
        NUM_SPEC=$(jq ".projects[$i].specialists | length" "$CONFIG")
        [ $NUM_SPEC -gt 12 ] && NUM_SPEC=12
        TOTAL=$((NUM_SPEC + 1))
        for ((p=1; p<=TOTAL; p++)); do
            tmux send-keys -t "$SESSION:$NAME.$p" "$CLAUDE_CMD" Enter 2>/dev/null
            if [ "$SLOW_MODE" = true ]; then
                echo -ne "  ${GRAY}Starting $NAME agent $p/$TOTAL...${NC}"
                if wait_for_agent_ready "$SESSION:$NAME.$p"; then
                    echo -e " ${GREEN}ready${NC}"
                    # Send identify immediately when ready
                    tmux send-keys -t "$SESSION:$NAME.$p" 'identify yourself' 2>/dev/null; sleep 0.3; tmux send-keys -t "$SESSION:$NAME.$p" Enter 2>/dev/null
                else
                    echo -e " ${YELLOW}timeout${NC}"
                fi
            else
                sleep 0.3
            fi
        done
        # In fast mode, detect "for shortcuts" then send identify (staggered by pane and project)
        if [ "$SLOW_MODE" = false ]; then
            PROJECT_OFFSET=$((i * TOTAL))
            for ((p=1; p<=TOTAL; p++)); do
                STAGGER=$((PROJECT_OFFSET + p - 1))
                nohup bash -c "
                    trust_approved=false
                    for attempt in {1..180}; do
                        sleep 1
                        pane_content=\$(tmux capture-pane -t '$SESSION:$NAME.$p' -p 2>/dev/null)
                        # Auto-approve trust prompt
                        if [ \"\$trust_approved\" = false ] && echo \"\$pane_content\" | grep -q 'Yes, proceed'; then
                            tmux send-keys -t '$SESSION:$NAME.$p' Enter
                            trust_approved=true
                            continue
                        fi
                        if echo \"\$pane_content\" | grep -qE '(for shortcuts|❯)'; then
                            # Verify it's still ready after a pause (not a loading flash)
                            sleep 3
                            pane_check=\$(tmux capture-pane -t '$SESSION:$NAME.$p' -p 2>/dev/null)
                            if echo \"\$pane_check\" | grep -qE '(for shortcuts|❯)'; then
                                sleep $STAGGER
                                tmux send-keys -t '$SESSION:$NAME.$p' 'identify yourself'
                                sleep 0.3
                                tmux send-keys -t '$SESSION:$NAME.$p' Enter
                                exit 0
                            fi
                        fi
                    done
                " >/dev/null 2>&1 &
            done
        fi
    done
elif [ "$LITE_MODE" = true ]; then
    LITE_IDX=$((LITE_PROJECT - 1))
    LITE_NAME=$(jq -r ".projects[$LITE_IDX].name" "$CONFIG")
    echo -e "${ORANGE}LITE MODE: QB only for $LITE_NAME${NC}"

    for ((i=0; i<NUM_PROJECTS; i++)); do
        NAME=$(jq -r ".projects[$i].name" "$CONFIG" | tr ' .:' '---')
        NUM_SPEC=$(jq ".projects[$i].specialists | length" "$CONFIG")
        [ $NUM_SPEC -gt 12 ] && NUM_SPEC=12
        TOTAL=$((NUM_SPEC + 1))

        if [ $i -eq $LITE_IDX ]; then
            tmux send-keys -t "$SESSION:$NAME.1" "$CLAUDE_CMD" Enter 2>/dev/null
            # Detect ready state then send identify for QB (with auto trust approval)
            nohup bash -c "
                trust_approved=false
                for attempt in {1..180}; do
                    sleep 1
                    pane_content=\$(tmux capture-pane -t '$SESSION:$NAME.1' -p 2>/dev/null)
                    # Auto-approve trust prompt
                    if [ \"\$trust_approved\" = false ] && echo \"\$pane_content\" | grep -q 'Yes, proceed'; then
                        tmux send-keys -t '$SESSION:$NAME.1' Enter
                        trust_approved=true
                        continue
                    fi
                    if echo \"\$pane_content\" | grep -qE '(for shortcuts|❯)'; then
                        sleep 3
                        pane_check=\$(tmux capture-pane -t '$SESSION:$NAME.1' -p 2>/dev/null)
                        if echo \"\$pane_check\" | grep -qE '(for shortcuts|❯)'; then
                            tmux send-keys -t '$SESSION:$NAME.1' 'identify yourself'; sleep 0.3; tmux send-keys -t '$SESSION:$NAME.1' Enter
                            exit 0
                        fi
                    fi
                done
            " >/dev/null 2>&1 &
            for ((p=2; p<=TOTAL; p++)); do
                SLOT_NUM=$((p-1))
                tmux send-keys -t "$SESSION:$NAME.$p" "$IDLE_SCRIPT_DIR/idle.sh $SLOT_NUM" Enter 2>/dev/null
            done
        else
            # Delay for non-lite projects to let shells and direnv settle
            DELAY_TIME=$(( 2 + i ))
            sleep $DELAY_TIME
            for ((p=1; p<=TOTAL; p++)); do
                if [ $p -eq 1 ]; then
                    SLOT_LABEL="QB"
                else
                    SLOT_LABEL=$((p-1))
                fi
                tmux send-keys -t "$SESSION:$NAME.$p" "$IDLE_SCRIPT_DIR/idle.sh $SLOT_LABEL" Enter 2>/dev/null
                sleep 0.1
            done
        fi
    done
else
    if [ -n "$MULTI_PROJECTS" ]; then
        echo -e "  ${GREEN}Loading agents for projects: $MULTI_PROJECTS${NC}"
    else
        SELECTED_IDX=$((SELECTED_PROJECT - 1))
        SELECTED_NAME=$(jq -r ".projects[$SELECTED_IDX].name" "$CONFIG")
        echo -e "  ${GREEN}Loading all agents for $SELECTED_NAME${NC}"
        SELECTED_NAME=$(echo "$SELECTED_NAME" | tr ' .:' '---')
    fi

    for ((i=0; i<NUM_PROJECTS; i++)); do
        # Solo mode: skip non-selected projects (no window exists for them)
        if [ "$SOLO_MODE" = "true" ]; then
            if [ -n "$MULTI_PROJECTS" ]; then
                is_in_list "$MULTI_PROJECTS" "$((i+1))" || continue
            elif [ -n "$SELECTED_PROJECT" ] && [ $i -ne $SELECTED_IDX ]; then
                continue
            fi
        fi
        # Multi-project mode (non-solo): skip projects not in the list
        if [ -n "$MULTI_PROJECTS" ] && [ "$SOLO_MODE" != "true" ]; then
            is_in_list "$MULTI_PROJECTS" "$((i+1))" || continue
        fi

        NAME=$(jq -r ".projects[$i].name" "$CONFIG" | tr ' .:' '---')
        NUM_SPEC=$(jq ".projects[$i].specialists | length" "$CONFIG")
        [ $NUM_SPEC -gt 12 ] && NUM_SPEC=12
        TOTAL=$((NUM_SPEC + 1))

        # Determine if this project should have agents launched
        IS_ACTIVE=false
        if [ -n "$MULTI_PROJECTS" ]; then
            is_in_list "$MULTI_PROJECTS" "$((i+1))" && IS_ACTIVE=true
        elif [ $i -eq $SELECTED_IDX ]; then
            IS_ACTIVE=true
        fi

        if [ "$IS_ACTIVE" = true ]; then
            for ((p=1; p<=TOTAL; p++)); do
                tmux send-keys -t "$SESSION:$NAME.$p" "$CLAUDE_CMD" Enter 2>/dev/null
                if [ "$SLOW_MODE" = true ]; then
                    echo -ne "  ${GRAY}Starting $NAME agent $p/$TOTAL...${NC}"
                    if wait_for_agent_ready "$SESSION:$NAME.$p"; then
                        echo -e " ${GREEN}ready${NC}"
                        # Send identify immediately when ready
                        tmux send-keys -t "$SESSION:$NAME.$p" 'identify yourself' 2>/dev/null; sleep 0.3; tmux send-keys -t "$SESSION:$NAME.$p" Enter 2>/dev/null
                    else
                        echo -e " ${YELLOW}timeout${NC}"
                    fi
                else
                    sleep 0.3
                fi
            done
            # In fast mode, detect ready state then send identify (staggered, via nohup to survive)
            if [ "$SLOW_MODE" = false ]; then
                for ((p=1; p<=TOTAL; p++)); do
                    STAGGER=$((p - 1))
                    nohup bash -c "
                        trust_approved=false
                        for i in {1..180}; do
                            sleep 1
                            pane_content=\$(tmux capture-pane -t '$SESSION:$NAME.$p' -p 2>/dev/null)
                            # Auto-approve trust prompt
                            if [ \"\$trust_approved\" = false ] && echo \"\$pane_content\" | grep -q 'Yes, proceed'; then
                                tmux send-keys -t '$SESSION:$NAME.$p' Enter
                                trust_approved=true
                                continue
                            fi
                            if echo \"\$pane_content\" | grep -qE '(for shortcuts|❯)'; then
                                sleep 3
                                pane_check=\$(tmux capture-pane -t '$SESSION:$NAME.$p' -p 2>/dev/null)
                                if echo \"\$pane_check\" | grep -qE '(for shortcuts|❯)'; then
                                    sleep $STAGGER
                                    tmux send-keys -t '$SESSION:$NAME.$p' 'identify yourself'; sleep 0.3; tmux send-keys -t '$SESSION:$NAME.$p' Enter
                                    exit 0
                                fi
                            fi
                        done
                    " >/dev/null 2>&1 &
                done
            fi
        else
            # Delay for non-selected projects to let shells and direnv settle
            DELAY_TIME=$(( 2 + i ))
            sleep $DELAY_TIME
            for ((p=1; p<=TOTAL; p++)); do
                if [ $p -eq 1 ]; then
                    SLOT_LABEL="QB"
                else
                    SLOT_LABEL=$((p-1))
                fi
                tmux send-keys -t "$SESSION:$NAME.$p" "$IDLE_SCRIPT_DIR/idle.sh $SLOT_LABEL" Enter 2>/dev/null
                sleep 0.1
            done
        fi
    done
fi

# ═══════════════════════════════════════════════════════════════════════════════
# BULLETIN BOARD: Shared context for specialist completion tracking
# ═══════════════════════════════════════════════════════════════════════════════

# Initialize the bulletin board directory and empty board.json for a project
# Usage: bulletin_board_init "ProjectName"
bulletin_board_init() {
    local project_name="$1"
    local bulletin_dir="/tmp/agentic-bulletin/$project_name"
    mkdir -p "$bulletin_dir"
    echo '{}' > "$bulletin_dir/board.json"
}

# Clean up the bulletin board directory after a run completes
# Usage: bulletin_board_cleanup "ProjectName"
bulletin_board_cleanup() {
    local project_name="$1"
    local bulletin_dir="/tmp/agentic-bulletin/$project_name"
    rm -rf "$bulletin_dir"
}

# ═══════════════════════════════════════════════════════════════════════════════
# AUTO-RELAY: Send direct tmux delegation instructions to QB
# QB sends prompts directly to specialist panes via tmux send-keys
# ═══════════════════════════════════════════════════════════════════════════════

if [ "$AUTO_RELAY" = "true" ]; then
    # Determine which project to relay for (disabled in LITE_MODE to avoid conflicts)
    RELAY_PROJECT_IDX=""
    if [ "$LITE_MODE" = true ]; then
        : # Auto-relay disabled in lite mode — only QB pane is active
    elif [ -n "$MULTI_PROJECTS" ]; then
        # Multi-project: relay for the first project in the list
        RELAY_PROJECT_IDX=$(( $(echo "$MULTI_PROJECTS" | cut -d',' -f1) - 1 ))
    elif [ -n "$SELECTED_PROJECT" ]; then
        RELAY_PROJECT_IDX=$((SELECTED_PROJECT-1))
    fi

    if [ -n "$RELAY_PROJECT_IDX" ]; then
        RELAY_PROJECT_NAME=$(jq -r ".projects[$RELAY_PROJECT_IDX].name" "$CONFIG" | tr ' .:' '---')
        RELAY_MAIN_DIR=$(jq -r ".projects[$RELAY_PROJECT_IDX].main_dir" "$CONFIG")
        RELAY_MAIN_DIR="${RELAY_MAIN_DIR/#\~/$HOME}"
        RELAY_NUM_SPEC=$(jq ".projects[$RELAY_PROJECT_IDX].specialists | length" "$CONFIG")
        [ $RELAY_NUM_SPEC -gt 12 ] && RELAY_NUM_SPEC=12
        RELAY_PANE_MAP="/tmp/agentic-relay/$RELAY_PROJECT_NAME/pane-map.json"

        # Build specialist info with pane targets and directories
        SPEC_INFO=""
        for ((j=0; j<RELAY_NUM_SPEC; j++)); do
            SPEC_DIR=$(jq -r ".projects[$RELAY_PROJECT_IDX].specialists[$j]" "$CONFIG")
            SPEC_DIR="${SPEC_DIR/#\~/$HOME}"
            SPEC_ROLE=$(get_role_from_dir "$SPEC_DIR" "$RELAY_MAIN_DIR")
            PANE_TARGET=$(jq -r --arg role "$SPEC_ROLE" '.[$role] // "unknown"' "$RELAY_PANE_MAP" 2>/dev/null)
            SPEC_INFO="${SPEC_INFO}
- ${SPEC_ROLE} | pane: ${PANE_TARGET} | dir: ${SPEC_DIR}"
        done

        # NOTE: QB already reads .claude/qb-dispatch.md via CLAUDE.md on startup.
        # The relay watcher handles user prompts sent DURING a session (via Telegram/relay).
        # We do NOT send a startup dispatch message here — that caused duplicate dispatch prompts.
        # The relay system at /tmp/agentic-relay/ handles ongoing prompt delivery separately.
    fi
fi

if [ -n "$MULTI_PROJECTS" ]; then
    FIRST_PROJ=$(echo "$MULTI_PROJECTS" | cut -d',' -f1)
    FIRST_NAME=$(jq -r ".projects[$((FIRST_PROJ-1))].name" "$CONFIG" | tr ' .:' '---')
    tmux select-window -t "$SESSION:$FIRST_NAME" 2>/dev/null
    tmux select-pane -t "$SESSION:$FIRST_NAME.1" 2>/dev/null
elif [ -n "$SELECTED_PROJECT" ]; then
    SELECTED_NAME=$(jq -r ".projects[$((SELECTED_PROJECT-1))].name" "$CONFIG" | tr ' .:' '---')
    tmux select-window -t "$SESSION:$SELECTED_NAME" 2>/dev/null
    tmux select-pane -t "$SESSION:$SELECTED_NAME.1" 2>/dev/null
else
    DFLT_NAME=$(jq -r '.projects[0].name' "$CONFIG" | tr ' .:' '---')
    tmux select-window -t "$SESSION:$DFLT_NAME" 2>/dev/null
    tmux select-pane -t "$SESSION:$DFLT_NAME.1" 2>/dev/null
fi

echo ""
echo -e "${PURPLE}════════════════════════════════════════════════════════════════${NC}"
echo -e "${PURPLE}${BOLD}Ready!${NC}"
echo -e "${PURPLE}════════════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "  • Press ${CYAN}ENTER${NC} in any idle pane to activate"
echo -e "  • Use ${CYAN}Alt+1-9${NC} to switch project windows"
echo -e "  • Press ${CYAN}Ctrl+B then H${NC} to go HOME (pick project)"
echo -e "  • Press ${CYAN}Ctrl+B then D${NC} to DETACH (auto-kills session)"
if [ "$AUTO_RELAY" = "true" ]; then
    echo -e "  • ${CYAN}Auto-Relay is ON${NC} - QB prompts auto-distribute to specialists"
fi
echo ""

# Safety net: after 30 seconds, send identify to any pane that still hasn't received it
# Check full scrollback (-S -100) to avoid re-sending when identify scrolled out of view
nohup bash -c "
    sleep 30
    tmux has-session -t '$SESSION' 2>/dev/null || exit 0
    for pane_target in \$(tmux list-panes -s -t '$SESSION' -F '#{session_name}:#{window_name}.#{pane_index}' 2>/dev/null); do
        content=\$(tmux capture-pane -t \"\$pane_target\" -p -S -100 2>/dev/null)
        # Skip if identify was already sent (check full scrollback, not just last 5 lines)
        if echo \"\$content\" | grep -q 'identify yourself'; then
            continue
        fi
        # Skip idle panes (running idle.sh, not Claude)
        if echo \"\$content\" | grep -q 'IDLE'; then
            continue
        fi
        # If pane has the ready prompt but identify was never sent
        if echo \"\$content\" | grep -qE '(❯|for shortcuts)'; then
            tmux send-keys -t \"\$pane_target\" 'identify yourself'
            sleep 0.3
            tmux send-keys -t \"\$pane_target\" Enter
            sleep 1
        fi
    done
" >/dev/null 2>&1 &
track_bg_pid $!

# ═══════════════════════════════════════════════════════════════════════════════
# TMUX HOOKS & KEYBINDINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Auto-kill session on detach (stop relay watchers, show final stats, kill session)
tmux set-hook -t "$SESSION" client-detached "run-shell 'for pidfile in /tmp/agentic-relay/*/relay.pid; do [ -f \"\$pidfile\" ] && kill \$(cat \"\$pidfile\") 2>/dev/null; done; ~/.local/bin/agentic-stats --final 2>/dev/null; tmux kill-session -t $SESSION 2>/dev/null || true'"

# Home key (Ctrl+B, H) - detach and restart with project picker
tmux bind-key -T prefix H run-shell "echo switch > /tmp/agentic-restart-flag; tmux detach-client"

tmux attach -t $SESSION

# Go back to homepage if quit or H was pressed, otherwise clean exit
if [ -f /tmp/agentic-restart-flag ]; then
    rm /tmp/agentic-restart-flag
    exec "$0" -s
fi
