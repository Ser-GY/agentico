#!/bin/bash
# Bulletin board writer for specialists
# Usage: agentic-bulletin-write ProjectName specialist-role "files_created" "exports" "notes"
#
# Writes/updates the specialist's key in board.json using jq
# files_created and exports are comma-separated strings that get converted to JSON arrays

PROJECT="$1"
ROLE="$2"
FILES_CREATED="$3"
EXPORTS="$4"
NOTES="$5"

if [ -z "$PROJECT" ] || [ -z "$ROLE" ]; then
    echo "Usage: agentic-bulletin-write ProjectName specialist-role \"files_created\" \"exports\" \"notes\""
    exit 1
fi

BULLETIN_DIR="/tmp/agentic-bulletin/$PROJECT"
BOARD_FILE="$BULLETIN_DIR/board.json"

# Ensure directory and board.json exist
mkdir -p "$BULLETIN_DIR"
[ ! -f "$BOARD_FILE" ] && echo '{}' > "$BOARD_FILE"

# Convert comma-separated strings to JSON arrays
FILES_JSON=$(echo "$FILES_CREATED" | jq -R 'split(",") | map(select(length > 0) | ltrimstr(" ") | rtrimstr(" "))')
EXPORTS_JSON=$(echo "$EXPORTS" | jq -R 'split(",") | map(select(length > 0) | ltrimstr(" ") | rtrimstr(" "))')

# Write the specialist's entry to board.json
jq --arg role "$ROLE" \
   --argjson files "$FILES_JSON" \
   --argjson exports "$EXPORTS_JSON" \
   --arg notes "$NOTES" \
   '.[$role] = {"status": "done", "files_created": $files, "exports": $exports, "notes": $notes}' \
   "$BOARD_FILE" > "$BOARD_FILE.tmp" && mv "$BOARD_FILE.tmp" "$BOARD_FILE"
